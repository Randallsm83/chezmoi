{{- if eq .chezmoi.os "windows" -}}
# WSL2 Configuration
# https://docs.microsoft.com/en-us/windows/wsl/wsl-config

[wsl2]
# Limit processors (adjust based on your CPU)
processors=8

# Memory allocation (50% of system RAM recommended)
memory=16GB

# Disable swap file
swap=0

# Networking
localhostForwarding=true

# NOTE: systemd belongs in /etc/wsl.conf inside the distro, NOT here.
# Per Microsoft's WSL docs, the .wslconfig [boot] section only accepts
# `command=`; placing `systemd=true` here is a silent no-op. The Arch
# WSL reset script (scripts/reset-wsl-arch.ps1) seeds /etc/wsl.conf
# with [boot] systemd=true, [automount] metadata, [network]
# generateResolvConf=false, and [interop] appendWindowsPath=false on
# every reinstall.

[experimental]
# Enable experimental features
# autoMemoryReclaim=gradual
# sparseVhd=true
{{- end -}}

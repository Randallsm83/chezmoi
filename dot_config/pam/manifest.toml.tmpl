[servers]
{{- if not .is_wsl }}
  # Skipped on WSL: @1password/sdk's native addon needs the 1Password desktop
  # app on the same OS. The Windows-side app can't broker this socket into
  # WSL (npiperelay only wraps the SSH agent pipe). Secrets are still
  # available via the `op` CLI through chezmoi's $secretsTpl pipeline.
  [servers.1password]
    transport = "stdio"
    command = "npx"
    args = ["-y", "mcp-1password@beta", "--auth-mode=desktop", "--account=my"]
    idle_timeout_s = 300
    quota_per_minute = 0
{{- end }}
  [servers.chrome-devtools]
    transport = "stdio"
    command = "npx"
    args = ["-y", "chrome-devtools-mcp@latest", "--acceptInsecureCerts"]
    idle_timeout_s = 300
    quota_per_minute = 0
  [servers.clickup]
    transport = "stdio"
    command = "npx"
    args = ["-y", "clickup-mcp-server@latest"]
    idle_timeout_s = 300
    quota_per_minute = 0
    [servers.clickup.env]
      CLICKUP_API_TOKEN = "op://DH/fw4qmg4qxp4pjzatmwpcvkodym/credential"
      CLICKUP_TEAM_ID = "9014072269"
  [servers.context7]
    transport = "stdio"
    command = "npx"
    args = ["-y", "@upstash/context7-mcp@latest"]
    idle_timeout_s = 300
    quota_per_minute = 0
  [servers.mcp-deepwiki]
    transport = "stdio"
    command = "npx"
    args = ["-y", "mcp-deepwiki"]
    idle_timeout_s = 300
    quota_per_minute = 0
  [servers.memory]
    transport = "stdio"
    command = "npx"
    args = ["-y", "@modelcontextprotocol/server-memory"]
    idle_timeout_s = 300
    quota_per_minute = 0
  [servers.neon]
    transport = "http"
    url = "https://mcp.neon.tech/mcp"
    idle_timeout_s = 300
    quota_per_minute = 0
    [servers.neon.headers]
      Authorization = "Bearer ${op://Personal/3yw46z74dhivcxqbzzmomcw5v4/credential}"
  [servers.qdrant]
    transport = "stdio"
    command = "uvx"
    args = ["--managed-python", "--python", "3.12", "mcp-server-qdrant"]
    idle_timeout_s = 300
    quota_per_minute = 0

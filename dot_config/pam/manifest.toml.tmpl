      COLLECTION_NAME = "memories"
      EMBEDDING_MODEL = "sentence-transformers/all-MiniLM-L6-v2"
      QDRANT_API_KEY = "op://Homelab/qz56qks54oy6p6l4rytgbjgjn4/credential"
      QDRANT_URL = "http://***REMOVED***:6333"
  [servers.tavily]
    transport = "http"
    url = "https://mcp.tavily.com/mcp/"
    idle_timeout_s = 300
    quota_per_minute = 0
    [servers.tavily.headers]
      Authorization = "Bearer ${op://Personal/63ydj7e44lzuwzjr4fnjrvmqvu/credential}"
  [servers.vercel]
    transport = "http"
    url = "https://mcp.vercel.com"
    idle_timeout_s = 300
    quota_per_minute = 0

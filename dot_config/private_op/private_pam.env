# Personal Agent Multiplexer (MCP proxy daemon).
#

# Secrets injected into the `pam` daemon process via:
#   op run --env-file=~/.config/op/pam.env -- pam.exe start
#
# Each line: VAR=op://<vault>/<item>/<field>
# Values are resolved from 1Password at process spawn and exist only in the
# child process's environment. They are NOT persisted to disk or to the parent
# shell's environment.
#
# pam resolves most secrets inline in ~/.config/pam/manifest.toml via
# `${op://...}` placeholders at backend-spawn time. The variables below are
# the ones the manifest pulls from the process environment via `env://`
# references (currently: the clickup backend's CLICKUP_API_KEY mapping).
# Mirror the rest of the set referenced by claude.env / opencode.env so any
# future backend that switches to `env://` Just Works.
#
# Requires: 1Password CLI (`op`) signed in. With Windows desktop-app
# integration enabled, biometric unlock makes the lookup invisible.

# AI / agent provider credentials.
ANTHROPIC_API_KEY=op://Personal/Anthropic API/credential
TAVILY_API_KEY=op://Personal/Tavily MCP/credential
VERCEL_TOKEN=op://Personal/Vercel/credential
NEON_API_KEY=op://Personal/Neon API/credential
QDRANT_API_KEY=op://Homelab/Qdrant Pi/credential

# 1Password Environments MCP (desktop-auth). Account shortname only.
OP_ACCOUNT=my

# DreamHost workspace ClickUp (used by the clickup MCP server).
DH_CLICKUP_API_KEY=op://DH/fw4qmg4qxp4pjzatmwpcvkodym/credential
# Workspace ID — public identifier (it appears in every ClickUp URL), not a secret.
CLICKUP_TEAM_ID=9014072269

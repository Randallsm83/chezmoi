# OMP Auth Broker Configuration
#
# These variables configure OMP clients
# to securely connect to the OMP auth-broker running on your Raspberry Pi homelab.
#
# OMP_AUTH_BROKER_URL: The IP/hostname of the machine running `omp auth-broker serve`
# OMP_AUTH_BROKER_TOKEN: The secure token generated by the broker to allow connections

OMP_AUTH_BROKER_URL="http://raspi.***REMOVED***.ts.net:8765"
OMP_AUTH_BROKER_TOKEN=op://Personal/OMP Auth Broker/credential
TAVILY_API_KEY=op://Personal/63ydj7e44lzuwzjr4fnjrvmqvu/credential
QDRANT_API_KEY=op://Homelab/qz56qks54oy6p6l4rytgbjgjn4/credential

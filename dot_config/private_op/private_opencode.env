# AI coding agent built for the terminal.
#

# Secrets injected into the `opencode` process via:
#   op run --env-file=~/.config/op/opencode.env -- opencode.exe ...
#
# Each line: VAR=op://<vault>/<item>/<field>
# Values are resolved from 1Password at process spawn and exist only in the
# child process's environment. They are NOT persisted to disk or to the parent
# shell's environment.
#
# These match the secrets referenced by entries in .chezmoidata/mcp.yaml.
# opencode resolves `{env:VAR}` placeholders against this injected env at MCP
# connection time, mirroring the pattern Claude Code uses with `${VAR}` and
# ~/.config/op/claude.env.
#
# Requires: 1Password CLI (`op`) signed in. With Windows desktop-app
# integration enabled, biometric unlock makes the lookup invisible.

# AI / agent provider credentials.
ANTHROPIC_API_KEY=op://DH/DH Anthropic/credential
OPENAI_API_KEY=op://DH/DH Open AI/credential
TAVILY_API_KEY=op://Personal/63ydj7e44lzuwzjr4fnjrvmqvu/credential
VERCEL_TOKEN=op://Personal/Vercel/credential
NEON_API_KEY=op://Personal/Neon API/credential
QDRANT_API_KEY=op://Homelab/Qdrant Pi/credential

# Google Gemini API (DH workspace key from Google AI Studio).
# Two names because consumers diverge:
#   GEMINI_API_KEY              — opencode `google` provider, official Gemini CLI/SDK
#   GOOGLE_GENERATIVE_AI_API_KEY — Vercel @ai-sdk/google (opencode is built on AI-SDK)
GEMINI_API_KEY=op://DH/DH Gemini/credential
GOOGLE_GENERATIVE_AI_API_KEY=op://DH/DH Gemini/credential

# Git forge tokens.
# GitHub: single Personal token used by gh CLI + git push helpers.
GH_TOKEN=op://Personal/GitHub Token/token
GITHUB_TOKEN=op://Personal/GitHub Token/token
# GitLab: DH token is the default (work). Personal exposed as *_PERSONAL.
# glab CLI reads GITLAB_TOKEN; some tools read GLAB_TOKEN.
GITLAB_TOKEN=op://DH/DH Gitlab PAT/credential
GLAB_TOKEN=op://DH/DH Gitlab PAT/credential
GITLAB_TOKEN_PERSONAL=op://Personal/Gitlab PAT/credential
GLAB_TOKEN_PERSONAL=op://Personal/Gitlab PAT/credential

# Morph Fast Apply (opencode-morph-fast-apply plugin).
# Used by the `morph_edit` tool for 10x faster code edits via lazy-edit markers.
MORPH_API_KEY=op://Personal/Morph LLM/credential

# 1Password Environments MCP (desktop-auth). Account shortname only.
OP_ACCOUNT=my

# DreamHost workspace ClickUp (used by the clickup MCP server).
DH_CLICKUP_API_KEY=op://DH/fw4qmg4qxp4pjzatmwpcvkodym/credential
# Workspace ID — public identifier (it appears in every ClickUp URL), not a secret.
CLICKUP_TEAM_ID=9014072269

# oh-my-openagent: disable anonymous telemetry / PostHog reporting.
OMO_DISABLE_POSTHOG=1
OMO_SEND_ANONYMOUS_TELEMETRY=0

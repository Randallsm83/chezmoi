{
  "$schema": "https://opencode.ai/config.json",
  "shell": {{- if eq .chezmoi.os "windows" }} {{ printf "%s/.local/bin/pwsh-profile.cmd" .chezmoi.homeDir | replace "/" "\\" | toJson }}{{- else }} "zsh"{{- end }},
  "username": "ranmil",
  "autoupdate": "notify",
  "share": "disabled",
  "snapshot": true,

  "model": "anthropic/claude-opus-4-7",
  "small_model": "anthropic/claude-sonnet-4-5",
  "default_agent": "sisyphus",

  "plugin": [
    "@warp-dot-dev/opencode-warp",
    "oh-my-openagent@latest",
    "opencode-antigravity-auth@latest"
  ],

  "provider": {
    "anthropic": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000,
        "setCacheKey": true
      }
    }
  },

  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "external_directory": {
      "*": "allow",
      "~/.ssh/**": "ask",
      "~/.gnupg/**": "ask",
      "~/.aws/**": "ask",
      "~/.config/op/**": "ask",
      "~/.config/1Password/**": "ask",
      "~/.password-store/**": "ask"
    },
    "bash": {
      "*": "allow",

      "sudo *": "ask",
      "gsudo *": "ask",
      "doas *": "ask",
      "su *": "ask",
      "su": "ask",

      "rm -rf *": "ask",
      "rm -fr *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "chgrp *": "ask",

      "git push --force*": "ask",
      "git push -f*": "ask",
      "git push --force-with-lease*": "ask",
      "git reset --hard*": "ask",
      "git clean -fd*": "ask",
      "git clean -df*": "ask",
      "git clean -ffd*": "ask",
      "git clean -xfd*": "ask",
      "git filter-branch*": "ask",
      "git update-ref -d*": "ask",
      "git -C * push --force*": "ask",
      "git -C * push -f*": "ask",
      "git -C * reset --hard*": "ask",
      "git -C * clean -fd*": "ask",

      "apt *": "ask",
      "apt-get *": "ask",
      "pacman *": "ask",
      "dnf *": "ask",
      "yum *": "ask",
      "snap install*": "ask",
      "snap remove*": "ask",
      "winget install*": "ask",
      "winget uninstall*": "ask",
      "scoop install*": "ask",
      "scoop uninstall*": "ask",
      "brew install*": "ask",
      "brew uninstall*": "ask",
      "brew remove*": "ask",
      "pipx install*": "ask",
      "pipx uninstall*": "ask",
      "pip install*": "ask",
      "npm install -g*": "ask",
      "npm i -g*": "ask",
      "pnpm add -g*": "ask",
      "yarn global add*": "ask",
      "cargo install*": "ask",
      "go install*": "ask",

      "curl * | sh*": "ask",
      "curl * | bash*": "ask",
      "curl * | zsh*": "ask",
      "curl * | pwsh*": "ask",
      "wget * | sh*": "ask",
      "wget * | bash*": "ask",
      "iwr * | iex*": "ask",
      "Invoke-Expression*": "ask",
      "iex *": "ask",

      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      "rm -rf $HOME*": "deny",
      "rm -rf --no-preserve-root*": "deny",
      ":(){ :|:& };:": "deny",
      "dd if=*": "deny",
      "mkfs*": "deny",
      "shred*": "deny"
    }
  },

  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/build/**",
      "**/target/**",
      "**/.venv/**",
      "**/venv/**",
      "**/__pycache__/**",
      "**/.next/**",
      "**/.nuxt/**",
      "**/.cache/**",
      "**/.turbo/**",
      "**/.parcel-cache/**",
      "**/coverage/**",
      "**/.pytest_cache/**",
      "**/.mypy_cache/**",
      "**/.ruff_cache/**",
      "**/.idea/**",
      "**/.vscode/**"
    ]
  },

  "tools": {
    "write": true,
    "edit": true,
    "bash": true,
    "webfetch": true
  },

  "agent": {
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-7",
      "prompt": "You are in planning mode. Research thoroughly and produce a clear, concise plan. Do NOT modify any files.",
      "tools": { "write": false, "edit": false }
    },
    "main": {
      "mode": "primary",
      "description": "Primary build/dev agent.",
      "model": "anthropic/claude-opus-4-7"
    }
  },

  {{- /*
    MCP servers are owned by pam (~/.config/pam/manifest.toml). Each enabled
    client gets exactly one pointer entry named `pam`, injected by
    `pam sync`. Do NOT render the .chezmoidata/mcp.yaml inventory here — that
    file still drives Claude Code, but opencode talks to pam exclusively.

    The `pam` entry below is intentionally left out: `pam sync` performs an
    atomic, format-aware merge against this file after chezmoi apply and
    writes the pointer with its per-client auth token. The chezmoi script
    run_onchange_after_70_pam_sync.ps1 invokes that automatically.
  */ -}}
  "mcp": {},

  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md",
    ".cursor/rules/*.mdc",
    "WARP.md"
  ],

  "skills": {
    "paths": [
      {{- if eq .chezmoi.os "windows" }} "{{ .chezmoi.homeDir }}\\.agents\\skills"
      {{- else }} "{{ .chezmoi.homeDir }}/.agents/skills"{{- end }}
    ]
  },

  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs"]
    },
    "python": {
      "command": [
        {{- if eq .chezmoi.os "windows" }} "{{ .chezmoi.homeDir }}\\.local\\share\\mise\\installs\\python\\3.14.5\\Scripts\\basedpyright-langserver.exe"
        {{- else }} "basedpyright-langserver"{{- end }},
        "--stdio"
      ],
      "extensions": [".py", ".pyi"]
    },
    "rust": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "go": {
      "command": ["gopls", "serve"],
      "extensions": [".go"]
    },
    "json": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "yaml": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "html": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html", ".htm"]
    },
    "css": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"]
    },
    "perl": {
      "command": ["perlnavigator", "--stdio"],
      "extensions": [".pl", ".pm", ".t"]
    },
    "lua": {
      "command": ["lua-language-server"],
      "extensions": [".lua"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh", ".ksh"]
    },
    "zig": {
      "command": ["zls"],
      "extensions": [".zig", ".zon"]
    },
    "toml": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"]
    }
  }
}

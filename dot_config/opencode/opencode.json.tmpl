{
  "$schema": "https://opencode.ai/config.json",
  "shell": {{- if eq .chezmoi.os "windows" }} "pwsh"{{- else }} "zsh"{{- end }},
  "username": "ranmil",
  "autoupdate": "notify",
  "share": "disabled",
  "snapshot": true,

  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "build",

  "plugin": [
    "@warp-dot-dev/opencode-warp",
    "oh-my-openagent@latest",
    "opencode-antigravity-auth@latest"
  ],

  "provider": {
    "anthropic": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000,
        "setCacheKey": true
      }
    }
  },

  "permission": {
    "edit": "ask",
    "webfetch": "allow",
    "bash": {
      "ls *": "allow",
      "ll *": "allow",
      "eza *": "allow",
      "cat *": "allow",
      "bat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "which *": "allow",
      "where *": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "Get-Location": "allow",
      "Get-ChildItem *": "allow",
      "Get-Content *": "allow",
      "Test-Path *": "allow",

      "git status": "allow",
      "git status *": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git rev-parse*": "allow",
      "git ls-files*": "allow",
      "git config --get*": "allow",
      "git stash list*": "allow",
      "gh repo view*": "allow",
      "gh pr view*": "allow",
      "gh pr list*": "allow",
      "gh issue view*": "allow",
      "gh issue list*": "allow",

      "chezmoi diff*": "allow",
      "chezmoi status*": "allow",
      "chezmoi data*": "allow",
      "chezmoi execute-template*": "allow",
      "chezmoi managed*": "allow",
      "chezmoi unmanaged*": "allow",

      "scoop list*": "allow",
      "scoop status*": "allow",
      "scoop info*": "allow",
      "mise ls*": "allow",
      "mise current*": "allow",
      "mise which*": "allow",
      "node --version": "allow",
      "npm --version": "allow",
      "yarn --version": "allow",
      "python --version": "allow",
      "go version": "allow",
      "rustc --version": "allow",
      "cargo --version": "allow",

      "*": "ask"
    }
  },

  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/build/**",
      "**/target/**",
      "**/.venv/**",
      "**/venv/**",
      "**/__pycache__/**",
      "**/.next/**",
      "**/.nuxt/**",
      "**/.cache/**",
      "**/.turbo/**",
      "**/.parcel-cache/**",
      "**/coverage/**",
      "**/.pytest_cache/**",
      "**/.mypy_cache/**",
      "**/.ruff_cache/**",
      "**/.idea/**",
      "**/.vscode/**"
    ]
  },

  "tools": {
    "write": true,
    "edit": true,
    "bash": true,
    "webfetch": true
  },

  "agent": {
    "plan": {
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "You are in planning mode. Research thoroughly and produce a clear, concise plan. Do NOT modify any files.",
      "tools": { "write": false, "edit": false }
    },
    "build": {
      "model": "anthropic/claude-sonnet-4-5"
    },
    "code-reviewer": {
      "description": "Reviews code for security, performance, maintainability, and style. Read-only.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "Review code for correctness, security, performance, and maintainability. Be specific and cite file paths and line numbers. Do not modify files.",
      "tools": { "write": false, "edit": false, "bash": false }
    },
    "explore": {
      "description": "Investigates and explains a codebase or topic without making changes.",
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-5",
      "prompt": "Investigate the codebase and answer questions. Do not modify any files.",
      "tools": { "write": false, "edit": false }
    }
  },

  "mcp": {
    "filesystem": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem",
        {{- if eq .chezmoi.os "windows" }} "{{ .chezmoi.homeDir }}\\projects"
        {{- else }} "{{ .chezmoi.homeDir }}/projects"{{- end }}]
    }
  },

  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md",
    ".cursor/rules/*.mdc",
    "WARP.md"
  ],

  "skills": {
    "paths": [
      {{- if eq .chezmoi.os "windows" }} "{{ .chezmoi.homeDir }}\\.agents\\skills"
      {{- else }} "{{ .chezmoi.homeDir }}/.agents/skills"{{- end }}
    ]
  }
}

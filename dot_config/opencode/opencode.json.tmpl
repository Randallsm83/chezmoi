{
  "$schema": "https://opencode.ai/config.json",
  "shell": {{- if eq .chezmoi.os "windows" }} "pwsh"{{- else }} "zsh"{{- end }},
  "username": "ranmil",
  "autoupdate": "notify",
  "share": "disabled",
  "snapshot": true,

  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "build",

  "plugin": [
    "@warp-dot-dev/opencode-warp",
    "oh-my-openagent@latest",
    "opencode-antigravity-auth@latest"
  ],

  "provider": {
    "anthropic": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000,
        "setCacheKey": true
      }
    }
  },

  "permission": {
    "edit": "ask",
    "webfetch": "allow",
    "bash": {
      "ls *": "allow",
      "ll *": "allow",
      "eza *": "allow",
      "cat *": "allow",
      "bat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "which *": "allow",
      "where *": "allow",
      "echo *": "allow",
      "pwd": "allow",

      "Get-Location": "allow",
      "Get-ChildItem*": "allow",
      "Get-Content*": "allow",
      "Get-Item*": "allow",
      "Get-Process*": "allow",
      "Get-Date*": "allow",
      "Get-Command*": "allow",
      "Get-Module*": "allow",
      "Get-History*": "allow",
      "Test-Path*": "allow",
      "Select-String*": "allow",
      "Select-Object*": "allow",
      "Where-Object*": "allow",
      "ForEach-Object*": "allow",
      "Format-Table*": "allow",
      "Format-List*": "allow",
      "Out-String*": "allow",
      "Out-Host*": "allow",
      "Measure-Object*": "allow",
      "Compare-Object*": "allow",
      "Sort-Object*": "allow",
      "Group-Object*": "allow",
      "ConvertFrom-Json*": "allow",
      "ConvertTo-Json*": "allow",
      "Resolve-Path*": "allow",
      "Split-Path*": "allow",
      "Join-Path*": "allow",
      "Write-Host*": "allow",
      "Write-Output*": "allow",

      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git rev-parse*": "allow",
      "git ls-files*": "allow",
      "git config --get*": "allow",
      "git stash list*": "allow",
      "git add*": "allow",
      "git commit*": "allow",
      "git restore --staged*": "allow",
      "git -C * status*": "allow",
      "git -C * diff*": "allow",
      "git -C * log*": "allow",
      "git -C * show*": "allow",
      "git -C * branch*": "allow",
      "git -C * remote*": "allow",
      "git -C * rev-parse*": "allow",
      "git -C * ls-files*": "allow",
      "git -C * config --get*": "allow",
      "git -C * stash list*": "allow",
      "git -C * add*": "allow",
      "git -C * commit*": "allow",
      "git -C * restore --staged*": "allow",

      "gh repo view*": "allow",
      "gh pr view*": "allow",
      "gh pr list*": "allow",
      "gh pr diff*": "allow",
      "gh pr checks*": "allow",
      "gh issue view*": "allow",
      "gh issue list*": "allow",
      "gh api repos/*/pulls/*/comments*": "allow",
      "gh run view*": "allow",
      "gh run list*": "allow",

      "chezmoi diff*": "allow",
      "chezmoi status*": "allow",
      "chezmoi data*": "allow",
      "chezmoi execute-template*": "allow",
      "chezmoi managed*": "allow",
      "chezmoi unmanaged*": "allow",
      "chezmoi cat*": "allow",
      "chezmoi apply*": "allow",
      "chezmoi update*": "allow",
      "chezmoi verify*": "allow",
      "chezmoi state*": "allow",
      "chezmoi source-path*": "allow",
      "chezmoi target-path*": "allow",

      "scoop list*": "allow",
      "scoop status*": "allow",
      "scoop info*": "allow",
      "scoop search*": "allow",
      "scoop bucket list*": "allow",
      "winget list*": "allow",
      "winget search*": "allow",
      "mise ls*": "allow",
      "mise current*": "allow",
      "mise which*": "allow",
      "mise tasks*": "allow",
      "mise env*": "allow",
      "mise config*": "allow",
      "node --version": "allow",
      "npm --version": "allow",
      "npm root*": "allow",
      "npm ls*": "allow",
      "npm view*": "allow",
      "yarn --version": "allow",
      "yarn list*": "allow",
      "yarn info*": "allow",
      "pnpm --version": "allow",
      "pnpm list*": "allow",
      "python --version": "allow",
      "python -V": "allow",
      "go version": "allow",
      "rustc --version": "allow",
      "cargo --version": "allow",

      "op whoami*": "allow",
      "op account list*": "allow",
      "op account get*": "allow",
      "op vault list*": "allow",
      "op item list*": "allow",
      "op item get*": "allow",
      "op signin*": "allow",
      "op read*": "allow",

      "Remove-Item env:*": "allow",
      "$env:* = *": "allow",

      "*": "ask"
    }
  },

  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/build/**",
      "**/target/**",
      "**/.venv/**",
      "**/venv/**",
      "**/__pycache__/**",
      "**/.next/**",
      "**/.nuxt/**",
      "**/.cache/**",
      "**/.turbo/**",
      "**/.parcel-cache/**",
      "**/coverage/**",
      "**/.pytest_cache/**",
      "**/.mypy_cache/**",
      "**/.ruff_cache/**",
      "**/.idea/**",
      "**/.vscode/**"
    ]
  },

  "tools": {
    "write": true,
    "edit": true,
    "bash": true,
    "webfetch": true
  },

  "agent": {
    "plan": {
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "You are in planning mode. Research thoroughly and produce a clear, concise plan. Do NOT modify any files.",
      "tools": { "write": false, "edit": false }
    },
    "build": {
      "model": "anthropic/claude-sonnet-4-5"
    },
    "code-reviewer": {
      "description": "Reviews code for security, performance, maintainability, and style. Read-only.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "Review code for correctness, security, performance, and maintainability. Be specific and cite file paths and line numbers. Do not modify files.",
      "tools": { "write": false, "edit": false, "bash": false }
    },
    "explore": {
      "description": "Investigates and explains a codebase or topic without making changes.",
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-5",
      "prompt": "Investigate the codebase and answer questions. Do not modify any files.",
      "tools": { "write": false, "edit": false }
    }
  },

  "mcp": {
    "filesystem": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem",
        {{- if eq .chezmoi.os "windows" }} "{{ .chezmoi.homeDir }}\\projects"
        {{- else }} "{{ .chezmoi.homeDir }}/projects"{{- end }}]
    }
  },

  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md",
    ".cursor/rules/*.mdc",
    "WARP.md"
  ],

  "skills": {
    "paths": [
      {{- if eq .chezmoi.os "windows" }} "{{ .chezmoi.homeDir }}\\.agents\\skills"
      {{- else }} "{{ .chezmoi.homeDir }}/.agents/skills"{{- end }}
    ]
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "shell": {{- if eq .chezmoi.os "windows" }} "pwsh"{{- else }} "zsh"{{- end }},
  "username": "ranmil",
  "autoupdate": "notify",
  "share": "disabled",
  "snapshot": true,

  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  "default_agent": "main",

  "plugin": [
    "@warp-dot-dev/opencode-warp",
    "oh-my-openagent@latest",
    "opencode-antigravity-auth@latest"
  ],

  "provider": {
    "anthropic": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000,
        "setCacheKey": true
      }
    }
  },

  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "external_directory": {
      "*": "ask",
      "~/projects/**": "allow",
      "~/.local/share/chezmoi/**": "allow",
      "~/.config/**": "allow",
      "~/.local/share/**": "allow",
      "~/.local/state/**": "allow",
      "~/.cache/**": "allow",
      "/tmp/**": "allow",
      "/var/folders/**": "allow",
      "~/.ssh/**": "ask",
      "~/.gnupg/**": "ask",
      "~/.aws/**": "ask",
      "~/.config/op/**": "ask",
      "~/.config/1Password/**": "ask",
      "~/.password-store/**": "ask"
    },
    "bash": {
      "*": "allow",

      "sudo *": "ask",
      "gsudo *": "ask",
      "doas *": "ask",
      "su *": "ask",
      "su": "ask",

      "rm -rf *": "ask",
      "rm -fr *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "chgrp *": "ask",

      "git push --force*": "ask",
      "git push -f*": "ask",
      "git push --force-with-lease*": "ask",
      "git reset --hard*": "ask",
      "git clean -fd*": "ask",
      "git clean -df*": "ask",
      "git clean -ffd*": "ask",
      "git clean -xfd*": "ask",
      "git filter-branch*": "ask",
      "git update-ref -d*": "ask",
      "git -C * push --force*": "ask",
      "git -C * push -f*": "ask",
      "git -C * reset --hard*": "ask",
      "git -C * clean -fd*": "ask",

      "apt *": "ask",
      "apt-get *": "ask",
      "pacman *": "ask",
      "dnf *": "ask",
      "yum *": "ask",
      "snap install*": "ask",
      "snap remove*": "ask",
      "winget install*": "ask",
      "winget uninstall*": "ask",
      "scoop install*": "ask",
      "scoop uninstall*": "ask",
      "brew install*": "ask",
      "brew uninstall*": "ask",
      "brew remove*": "ask",
      "pipx install*": "ask",
      "pipx uninstall*": "ask",
      "pip install*": "ask",
      "npm install -g*": "ask",
      "npm i -g*": "ask",
      "pnpm add -g*": "ask",
      "yarn global add*": "ask",
      "cargo install*": "ask",
      "go install*": "ask",

      "curl * | sh*": "ask",
      "curl * | bash*": "ask",
      "curl * | zsh*": "ask",
      "curl * | pwsh*": "ask",
      "wget * | sh*": "ask",
      "wget * | bash*": "ask",
      "iwr * | iex*": "ask",
      "Invoke-Expression*": "ask",
      "iex *": "ask",

      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      "rm -rf $HOME*": "deny",
      "rm -rf --no-preserve-root*": "deny",
      ":(){ :|:& };:": "deny",
      "dd if=*": "deny",
      "mkfs*": "deny",
      "shred*": "deny"
    }
  },

  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/build/**",
      "**/target/**",
      "**/.venv/**",
      "**/venv/**",
      "**/__pycache__/**",
      "**/.next/**",
      "**/.nuxt/**",
      "**/.cache/**",
      "**/.turbo/**",
      "**/.parcel-cache/**",
      "**/coverage/**",
      "**/.pytest_cache/**",
      "**/.mypy_cache/**",
      "**/.ruff_cache/**",
      "**/.idea/**",
      "**/.vscode/**"
    ]
  },

  "tools": {
    "write": true,
    "edit": true,
    "bash": true,
    "webfetch": true
  },

  "agent": {
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "You are in planning mode. Research thoroughly and produce a clear, concise plan. Do NOT modify any files.",
      "tools": { "write": false, "edit": false }
    },
    "main": {
      "mode": "primary",
      "description": "Primary build/dev agent.",
      "model": "anthropic/claude-sonnet-4-5"
    },
    "code-reviewer": {
      "description": "Reviews code for security, performance, maintainability, and style. Read-only.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "prompt": "Review code for correctness, security, performance, and maintainability. Be specific and cite file paths and line numbers. Do not modify files.",
      "tools": { "write": false, "edit": false, "bash": false }
    },
    "explore": {
      "description": "Investigates and explains a codebase or topic without making changes.",
      "mode": "subagent",
      "model": "anthropic/claude-haiku-4-5",
      "prompt": "Investigate the codebase and answer questions. Do not modify any files.",
      "tools": { "write": false, "edit": false }
    }
  },

  {{- /*
    MCP servers are rendered from .chezmoidata/mcp.yaml (single source of truth
    shared with Claude Code). Translation rules for opencode shape:
      stdio  -> type: "local",  args folded into command, env -> environment
      http   -> type: "remote", oauth: false (suppresses 401-auto-OAuth)
    Secret placeholders are rewritten ${VAR} -> {env:VAR} so opencode resolves
    them against the env injected by the `opencode` op-run wrapper (see
    SECRETS.md, ~/.config/op/opencode.env).
  */ -}}
  {{- $mcp := dict -}}
  {{- $_ := set $mcp "filesystem" (dict
      "type" "local"
      "enabled" true
      "command" (list "npx" "-y" "@modelcontextprotocol/server-filesystem"
        (eq .chezmoi.os "windows" | ternary (printf "%s\\projects" .chezmoi.homeDir) (printf "%s/projects" .chezmoi.homeDir)))) -}}
  {{- range $name, $cfg := .mcp.servers -}}
    {{- $entry := dict "enabled" true -}}
    {{- if eq $cfg.type "stdio" -}}
      {{- $args := default (list) $cfg.args -}}
      {{- $cmd := concat (list $cfg.command) $args -}}
      {{- $_ := set $entry "type" "local" -}}
      {{- $_ := set $entry "command" $cmd -}}
      {{- if $cfg.env -}}
        {{- $envMap := dict -}}
        {{- range $k, $v := $cfg.env -}}
          {{- $_ := set $envMap $k (regexReplaceAll "\\$\\{([A-Za-z_][A-Za-z0-9_]*)\\}" $v "{env:${1}}") -}}
        {{- end -}}
        {{- $_ := set $entry "environment" $envMap -}}
      {{- end -}}
    {{- else if eq $cfg.type "http" -}}
      {{- $_ := set $entry "type" "remote" -}}
      {{- $_ := set $entry "url" $cfg.url -}}
      {{- $_ := set $entry "oauth" false -}}
      {{- if $cfg.headers -}}
        {{- $headersMap := dict -}}
        {{- range $k, $v := $cfg.headers -}}
          {{- $_ := set $headersMap $k (regexReplaceAll "\\$\\{([A-Za-z_][A-Za-z0-9_]*)\\}" $v "{env:${1}}") -}}
        {{- end -}}
        {{- $_ := set $entry "headers" $headersMap -}}
      {{- end -}}
    {{- end -}}
    {{- $_ := set $mcp $name $entry -}}
  {{- end }}
  "mcp": {{ $mcp | toPrettyJson | indent 2 | trim }},

  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md",
    ".cursor/rules/*.mdc",
    "WARP.md"
  ],

  "skills": {
    "paths": [
      {{- if eq .chezmoi.os "windows" }} "{{ .chezmoi.homeDir }}\\.agents\\skills"
      {{- else }} "{{ .chezmoi.homeDir }}/.agents/skills"{{- end }}
    ]
  }
}

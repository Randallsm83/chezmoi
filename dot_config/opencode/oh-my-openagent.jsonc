// ██╔═══██╗██╔══██╗██╔════╝████╗  ██║██╔════╝██╔═══██╗██╔══██╗██╔════╝
// ██║   ██║██████╔╝█████╗  ██╔██╗ ██║██║     ██║   ██║██║  ██║█████╗
// ██║   ██║██╔═══╝ ██╔══╝  ██║╚██╗██║██║     ██║   ██║██║  ██║██╔══╝
// ╚██████╔╝██║     ███████╗██║ ╚████║╚██████╗╚██████╔╝██████╔╝███████╗
//  ╚═════╝ ╚═╝     ╚══════╝╚═╝  ╚═══╝ ╚═════╝ ╚═════╝ ╚═════╝ ╚══════╝
// AI coding agent built for the terminal.
//

{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/main/oh-my-opencode.schema.json",

  // Disable the plugin's automatic merge of `mcpServers` from ~/.claude.json
  // into opencode's MCP map. opencode now talks to pam exclusively for MCP;
  // there is no longer any inline MCP inventory in opencode.json (it ships
  // as `"mcp": {}` and pam-sync injects the single `pam` pointer afterwards).
  "claude_code": {
    "mcp": false
  },

  // Agent and category models intentionally NOT overridden:
  // OmO ships a provider-aware fallback chain per agent/category that picks
  // the right model for the role given your authenticated providers
  // (anthropic, openai, google). Defaults are codified in OmO's
  // AGENT_MODEL_REQUIREMENTS / CATEGORY_MODEL_REQUIREMENTS tables.

  // Keep all built-in skills enabled (playwright, git-master, frontend-ui-ux).
  "disabled_skills": [],

  // Drop the install-time toast; keep update checks otherwise.
  "disabled_hooks": ["startup-toast"],

  "disabled_agents": [],

  // pam already provides context7; suppress OmO's duplicate.
  "disabled_mcps": ["context7"],

  // No commit footer / no Co-authored-by trailer.
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false
  },

  "experimental": {
    "aggressive_truncation": false,
    "auto_resume": false
  }

  // Telemetry is controlled by env vars, not this file. Set in your shell
  // profile (chezmoi-managed pwsh/zsh):
  //   OMO_DISABLE_POSTHOG=1
  //   OMO_SEND_ANONYMOUS_TELEMETRY=0
}

// ██╔═══██╗██╔══██╗██╔════╝████╗  ██║██╔════╝██╔═══██╗██╔══██╗██╔════╝
// ██║   ██║██████╔╝█████╗  ██╔██╗ ██║██║     ██║   ██║██║  ██║█████╗
// ██║   ██║██╔═══╝ ██╔══╝  ██║╚██╗██║██║     ██║   ██║██║  ██║██╔══╝
// ╚██████╔╝██║     ███████╗██║ ╚████║╚██████╗╚██████╔╝██████╔╝███████╗
//  ╚═════╝ ╚═╝     ╚══════╝╚═╝  ╚═══╝ ╚═════╝ ╚═════╝ ╚═════╝ ╚══════╝
// AI coding agent built for the terminal.
//

{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/main/assets/oh-my-opencode.schema.json",

  // Disable the plugin's automatic merge of `mcpServers` from ~/.claude.json
  // into opencode's MCP map. opencode now talks to pam exclusively for MCP;
  // there is no longer any inline MCP inventory in opencode.json (it ships
  // as `"mcp": {}` and pam-sync injects the single `pam` pointer afterwards).
  "claude_code": {
    "mcp": false
  },

  // Preferred model-routing philosophy:
  // - Default/main work: openai/gpt-5.5
  // - Heavy reasoning/critique: openai/gpt-5.5-pro
  // - Fast agents: openai/gpt-5.5-fast
  // - Cheap codebase search: openai/gpt-5.4-mini-fast
  // - External docs/reference: google/gemini-2.5-flash with OpenAI fallback.
  "default_run_agent": "sisyphus",

  "agents": {
    "build": {
      "model": "openai/gpt-5.5"
    },
    "plan": {
      "model": "openai/gpt-5.5"
    },
    "sisyphus": {
      "model": "openai/gpt-5.5",
      "ultrawork": {
        "model": "openai/gpt-5.5-pro"
      }
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.5-fast"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5"
    },
    "oracle": {
      "model": "openai/gpt-5.5-pro"
    },
    "metis": {
      "model": "openai/gpt-5.5-pro"
    },
    "momus": {
      "model": "openai/gpt-5.5-pro"
    },
    "atlas": {
      "model": "openai/gpt-5.5"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "librarian": {
      "model": "google/gemini-2.5-flash",
      "fallback_models": ["openai/gpt-5.5-fast"]
    },
    "multimodal-looker": {
      "model": "google/gemini-2.5-flash",
      "fallback_models": ["openai/gpt-5.5-fast"]
    }
  },

  "categories": {
    "artistry": {
      "model": "openai/gpt-5.5"
    },
    "deep": {
      "model": "openai/gpt-5.5"
    },
    "quick": {
      "model": "openai/gpt-5.5-fast"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5-pro"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.5-fast"
    },
    "visual-engineering": {
      "model": "openai/gpt-5.5"
    },
    "writing": {
      "model": "openai/gpt-5.5-fast"
    }
  },

  // Keep all built-in skills enabled (playwright, git-master, frontend-ui-ux).
  "disabled_skills": [],

  // Drop the install-time toast; keep update checks otherwise.
  "disabled_hooks": ["startup-toast"],

  "disabled_agents": [],

  // pam already provides context7; suppress OmO's duplicate.
  "disabled_mcps": ["context7"],

  // No commit footer / no Co-authored-by trailer.
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false
  },

  "experimental": {
    "aggressive_truncation": false,
    "auto_resume": false
  }

  // Telemetry is controlled by env vars, not this file. Set in your shell
  // profile (chezmoi-managed pwsh/zsh):
  //   OMO_DISABLE_POSTHOG=1
  //   OMO_SEND_ANONYMOUS_TELEMETRY=0
}

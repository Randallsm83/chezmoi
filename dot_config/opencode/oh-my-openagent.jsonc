//  ██████╗ ██████╗ ███████╗███╗   ██╗ ██████╗ ██████╗ ██████╗ ███████╗
// ██╔═══██╗██╔══██╗██╔════╝████╗  ██║██╔════╝██╔═══██╗██╔══██╗██╔════╝
// ██║   ██║██████╔╝█████╗  ██╔██╗ ██║██║     ██║   ██║██║  ██║█████╗
// ██║   ██║██╔═══╝ ██╔══╝  ██║╚██╗██║██║     ██║   ██║██║  ██║██╔══╝
// ╚██████╔╝██║     ███████╗██║ ╚████║╚██████╗╚██████╔╝██████╔╝███████╗
//  ╚═════╝ ╚═╝     ╚══════╝╚═╝  ╚═══╝ ╚═════╝ ╚═════╝ ╚═════╝ ╚══════╝
// AI coding agent built for the terminal.
//

{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/main/oh-my-opencode.schema.json",

  // Disable the plugin's automatic merge of `mcpServers` from ~/.claude.json
  // into opencode's MCP map. opencode now talks to pam exclusively for MCP;
  // there is no longer any inline MCP inventory in opencode.json (it ships
  // as `"mcp": {}` and pam-sync injects the single `pam` pointer afterwards).
  "claude_code": {
    "mcp": false
  },

  // Heavy / orchestrator agents -> Opus 4.7 (max reasoning).
  // Fast / research agents      -> Haiku 4.5.
  "agents": {
    "sisyphus":          { "model": "anthropic/claude-opus-4-7" },
    "hephaestus":        { "model": "anthropic/claude-opus-4-7" },
    "prometheus":        { "model": "anthropic/claude-opus-4-7" },
    "oracle":            { "model": "anthropic/claude-opus-4-7" },
    "atlas":             { "model": "anthropic/claude-opus-4-7" },
    "metis":             { "model": "anthropic/claude-opus-4-7" },
    "momus":             { "model": "anthropic/claude-opus-4-7" },

    "librarian":         { "model": "anthropic/claude-haiku-4-5" },
    "sisyphus-junior":   { "model": "anthropic/claude-haiku-4-5" },
    "multimodal-looker": { "model": "anthropic/claude-haiku-4-5" },
    "explore":           { "model": "anthropic/claude-haiku-4-5" }
  },

  // Category defaults used by OmO's delegate_task tool. Same tiering.
  "categories": {
    "quick":              { "model": "anthropic/claude-haiku-4-5" },
    "unspecified-low":    { "model": "anthropic/claude-haiku-4-5" },
    "writing":            { "model": "anthropic/claude-haiku-4-5" },
    "unspecified-high":   { "model": "anthropic/claude-opus-4-7" },
    "deep":               { "model": "anthropic/claude-opus-4-7" },
    "ultrabrain":         { "model": "anthropic/claude-opus-4-7" },
    "visual-engineering": { "model": "anthropic/claude-opus-4-7" }
  },

  // Keep all built-in skills enabled (playwright, git-master, frontend-ui-ux).
  "disabled_skills": [],

  // Drop the install-time toast; keep update checks otherwise.
  "disabled_hooks": ["startup-toast"],

  "disabled_agents": [],

  // pam already provides context7; suppress OmO's duplicate.
  "disabled_mcps": ["context7"],

  // No commit footer / no Co-authored-by trailer.
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false
  },

  "experimental": {
    "aggressive_truncation": true,
    "auto_resume": true
  }

  // Telemetry is controlled by env vars, not this file. Set in your shell
  // profile (chezmoi-managed pwsh/zsh):
  //   OMO_DISABLE_POSTHOG=1
  //   OMO_SEND_ANONYMOUS_TELEMETRY=0
}

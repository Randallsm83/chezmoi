{{- /* chezmoi:modify-template */ -}}
{{- /* chezmoi:template:line-endings=lf */ -}}
{{- /*
  ~/.config/opencode/opencode.json is partially chezmoi-managed via this
  modify-template (no .tmpl extension; the directive comment above triggers
  template processing). The file is *not* fully template-rendered:

    - All chezmoi-managed keys (LSP, agents, permissions, plugins, watcher,
      tools, instructions, skills, provider, model defaults, etc.) come from
      the literal JSON below and are authoritative on every `chezmoi apply`.
    - The `mcp` key is preserved verbatim from the live file (received on
      `.chezmoi.stdin`). The per-machine pam auth token lives inside
      `mcp.pam.command` and is injected/refreshed by `pam sync --client opencode`
      (see .chezmoiscripts/run_after_71_opencode_pam_sync_windows.ps1.tmpl).
      Keeping mcp out of the template ensures that token never enters chezmoi
      source / git history.
    - Output is alphabetical at every level (`toPrettyJson` sorts map keys).
      opencode preserves the nested key order it reads, so after the first
      apply the live file converges on this same alphabetical layout and
      subsequent applies become byte-stable no-ops.

  See chezmoi docs: "Manage part, but not all, of a file" — modify templates.
*/ -}}
{{- $preservedMcp := dict -}}
{{- if ne .chezmoi.stdin "" -}}
{{-   $current := fromJson .chezmoi.stdin -}}
{{-   if hasKey $current "mcp" -}}
{{-     $preservedMcp = index $current "mcp" -}}
{{-   end -}}
{{- end -}}

{{- /* OS-specific values overlaid onto the JSON literal below */ -}}
{{- $shell := "zsh" -}}
{{- $pythonLspPath := "basedpyright-langserver" -}}
{{- $skillsPath := printf "%s/.agents/skills" .chezmoi.homeDir -}}
{{- if eq .chezmoi.os "windows" -}}
{{-   $shell = printf "%s/.local/bin/pwsh-profile.cmd" .chezmoi.homeDir | replace "/" "\\" -}}
{{-   $pythonLspPath = printf "%s\\.local\\share\\mise\\installs\\python\\3.14.5\\Scripts\\basedpyright-langserver.exe" .chezmoi.homeDir -}}
{{-   $skillsPath = printf "%s\\.agents\\skills" .chezmoi.homeDir -}}
{{- end -}}

{{- $desired := `{
  "$schema": "https://opencode.ai/config.json",
  "shell": "__SHELL_PLACEHOLDER__",
  "username": "ranmil",
  "autoupdate": "notify",
  "share": "disabled",
  "snapshot": true,

  "model": "anthropic/claude-opus-4-7",
  "small_model": "anthropic/claude-sonnet-4-5",
  "default_agent": "sisyphus",

  "plugin": [
    "@warp-dot-dev/opencode-warp",
    "oh-my-openagent@latest",
    "opencode-antigravity-auth@latest"
  ],

  "provider": {
    "anthropic": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000,
        "setCacheKey": true
      }
    }
  },

  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "external_directory": {
      "*": "allow",
      "~/.ssh/**": "ask",
      "~/.gnupg/**": "ask",
      "~/.aws/**": "ask",
      "~/.config/op/**": "ask",
      "~/.config/1Password/**": "ask",
      "~/.password-store/**": "ask"
    },
    "bash": {
      "*": "allow",

      "sudo *": "ask",
      "gsudo *": "ask",
      "doas *": "ask",
      "su *": "ask",
      "su": "ask",

      "rm -rf *": "ask",
      "rm -fr *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "chgrp *": "ask",

      "git push --force*": "ask",
      "git push -f*": "ask",
      "git push --force-with-lease*": "ask",
      "git reset --hard*": "ask",
      "git clean -fd*": "ask",
      "git clean -df*": "ask",
      "git clean -ffd*": "ask",
      "git clean -xfd*": "ask",
      "git filter-branch*": "ask",
      "git update-ref -d*": "ask",
      "git -C * push --force*": "ask",
      "git -C * push -f*": "ask",
      "git -C * reset --hard*": "ask",
      "git -C * clean -fd*": "ask",

      "apt *": "ask",
      "apt-get *": "ask",
      "pacman *": "ask",
      "dnf *": "ask",
      "yum *": "ask",
      "snap install*": "ask",
      "snap remove*": "ask",
      "winget install*": "ask",
      "winget uninstall*": "ask",
      "scoop install*": "ask",
      "scoop uninstall*": "ask",
      "brew install*": "ask",
      "brew uninstall*": "ask",
      "brew remove*": "ask",
      "pipx install*": "ask",
      "pipx uninstall*": "ask",
      "pip install*": "ask",
      "npm install -g*": "ask",
      "npm i -g*": "ask",
      "pnpm add -g*": "ask",
      "yarn global add*": "ask",
      "cargo install*": "ask",
      "go install*": "ask",

      "curl * | sh*": "ask",
      "curl * | bash*": "ask",
      "curl * | zsh*": "ask",
      "curl * | pwsh*": "ask",
      "wget * | sh*": "ask",
      "wget * | bash*": "ask",
      "iwr * | iex*": "ask",
      "Invoke-Expression*": "ask",
      "iex *": "ask",

      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      "rm -rf $HOME*": "deny",
      "rm -rf --no-preserve-root*": "deny",
      ":(){ :|:& };:": "deny",
      "dd if=*": "deny",
      "mkfs*": "deny",
      "shred*": "deny"
    }
  },

  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/.git/**",
      "**/dist/**",
      "**/build/**",
      "**/target/**",
      "**/.venv/**",
      "**/venv/**",
      "**/__pycache__/**",
      "**/.next/**",
      "**/.nuxt/**",
      "**/.cache/**",
      "**/.turbo/**",
      "**/.parcel-cache/**",
      "**/coverage/**",
      "**/.pytest_cache/**",
      "**/.mypy_cache/**",
      "**/.ruff_cache/**",
      "**/.idea/**",
      "**/.vscode/**"
    ]
  },

  "tools": {
    "write": true,
    "edit": true,
    "bash": true,
    "webfetch": true
  },

  "agent": {
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-7",
      "prompt": "You are in planning mode. Research thoroughly and produce a clear, concise plan. Do NOT modify any files.",
      "tools": { "write": false, "edit": false }
    },
    "main": {
      "mode": "primary",
      "description": "Primary build/dev agent.",
      "model": "anthropic/claude-opus-4-7"
    }
  },

  "mcp": {},

  "instructions": [
    "AGENTS.md",
    ".github/copilot-instructions.md",
    ".cursor/rules/*.mdc",
    "WARP.md"
  ],

  "skills": {
    "paths": ["__SKILLS_PATH_PLACEHOLDER__"]
  },

  "lsp": {
    "typescript": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs"]
    },
    "python": {
      "command": ["__PYTHON_LSP_PLACEHOLDER__", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    "rust": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "go": {
      "command": ["gopls", "serve"],
      "extensions": [".go"]
    },
    "json": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"]
    },
    "yaml": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "html": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html", ".htm"]
    },
    "css": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"]
    },
    "perl": {
      "command": ["perlnavigator", "--stdio"],
      "extensions": [".pl", ".pm", ".t"]
    },
    "lua": {
      "command": ["lua-language-server"],
      "extensions": [".lua"]
    },
    "bash": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh", ".ksh"]
    },
    "zig": {
      "command": ["zls"],
      "extensions": [".zig", ".zon"]
    },
    "toml": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"]
    }
  }
}` | fromJson -}}

{{- /* Overlay OS-specific values */ -}}
{{- $_ := set $desired "shell" $shell -}}
{{- $_ = set $desired "skills" (dict "paths" (list $skillsPath)) -}}
{{- $_ = set (index $desired "lsp") "python" (dict "command" (list $pythonLspPath "--stdio") "extensions" (list ".py" ".pyi")) -}}

{{- /* Preserve `mcp` from the live file (pam sync owns this key). */ -}}
{{- $_ = set $desired "mcp" $preservedMcp -}}

{{ $desired | toPrettyJson }}

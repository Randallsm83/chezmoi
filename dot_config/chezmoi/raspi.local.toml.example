# ██║     ██╔══██║██╔══╝   ███╔╝  ██║╚██╔╝██║██║   ██║██║
# ╚██████╗██║  ██║███████╗███████╗██║ ╚═╝ ██║╚██████╔╝██║
#  ╚═════╝╚═╝  ╚═╝╚══════╝╚══════╝╚═╝     ╚═╝ ╚═════╝ ╚═╝
# Manage your dotfiles across multiple machines.
#

# ============================================================================
# Raspberry Pi homelab zsh-only - .chezmoi.local.toml example
# ============================================================================
# Copy to ~/.config/chezmoi/.chezmoi.local.toml on a Raspberry Pi to use the
# lightweight homelab zsh loader without installing the medium-tier tool set.
#
# `setup.sh` will write this file automatically when invoked with RASPI=1
# (or when it auto-detects a Pi via /proc/device-tree/model or aarch64+Debian).
#
# Usage:
#   mkdir -p ~/.config/chezmoi
#   cp ~/.local/share/chezmoi/dot_config/chezmoi/raspi.local.toml.example \
#      ~/.config/chezmoi/.chezmoi.local.toml
#   chezmoi apply
# ============================================================================

[data]
    is_raspi = true
    # Keep medium for the lightweight zsh loader, but do not install tools.
    remote_tier = "medium"      # minimal | medium | full
    remote_minimal = false
    install_packages = false
    setup_1password = false
    has_sudo = true
    theme = "spaceduck"

    [data.package_features]
        # essentials on
        git = true
        ssh = true
        mise = true
        direnv = false
        # editors
        nvim = false
        vim = false
        vscode = false
        # shells/tools
        zsh = true
        starship = false
        fzf = false
        rust_alternatives = false
        thefuck = false
        fastfetch = false
        # languages off by default; enable only what this host needs
        node = false
        python = false
        rust = false
        golang = false
        ruby = false
        lua = false
        perl = false
        julia = false
        php = false
        # off entirely on Pi
        warp = false
        wezterm = false
        windows_terminal = false
        ai_tools = false
        gaming = false
        docker = false
        hardware_tools = false
        windows_utilities = false
        sysinternals = false
        network_tools = false
        dev_extras = false
        nerd_fonts = false
        "1password" = false
        homebrew = false

# Distributed version control system.
#

# Git configuration
# Managed by chezmoi - https://www.chezmoi.io/

[user]
	name = {{ .name }}
	email = {{ .email }}

[core]
	editor = nvim
	pager = delta
	# Personal global gitattributes (LF everywhere, CRLF only for .bat/.cmd/.ps1).
	# Per-repo .gitattributes always overrides this, so no team impact.
	attributesFile = {{ .chezmoi.homeDir }}/.config/git/attributes
{{- if eq .chezmoi.os "windows" }}
	# Windows: Normalize line endings (LF in repo, no CRLF conversion on checkout)
	autocrlf = input
	# Windows: Disable file mode tracking (no chmod)
	filemode = false
	# Windows: Enable long path support (>260 characters)
	longpaths = true
{{- else }}
	# Unix: Keep LF line endings
	autocrlf = input
{{- end }}
{{- if .setup_1password }}
{{- if eq .chezmoi.os "windows" }}
	# Windows: Use native OpenSSH which reads ~/.ssh/config for 1Password agent
	sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
{{- else if and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
	# WSL: Use Windows SSH to access 1Password agent on Windows host
	sshCommand = /mnt/c/Windows/System32/OpenSSH/ssh.exe
{{- else if eq .chezmoi.os "darwin" }}
	# macOS: 1Password SSH agent path contains spaces (Group Container), which git
	# cannot quote inside core.sshCommand. IdentityAgent is declared in
	# ~/.ssh/config.d/10-1password-darwin.conf, and SSH_AUTH_SOCK is exported by
	# the zsh 1Password integration (10-1password-ssh-agent.zsh).
{{- else }}
	# Native Linux: 1Password SSH agent via socket
	sshCommand = ssh -o IdentityAgent=~/.1password/agent.sock
{{- end }}
{{- end }}

# ============================================================================
# Aliases
# ============================================================================
# `git pushall [<ref>]` ‚ÄĒ push the current branch (or the given ref) to every
# mirror remote serially, retrying transient SSH-agent failures.
#
# Background: on Windows the 1Password SSH agent runs as a named-pipe service
# (\\.\pipe\openssh-ssh-agent). Issuing two signing requests in quick
# succession through that pipe occasionally returns "communication with agent
# failed" on the second one ‚ÄĒ most often when an upstream multi-pushurl on
# `origin` fans out to two remotes in the same `git push` invocation. To make
# multi-host pushes durable we (1) split `origin` so it points only at GitLab,
# (2) keep a separate `github` remote, and (3) push to both via this alias so
# each push is its own SSH session and individually retryable.
#
# Environment knobs:
#   GIT_PUSHALL_REMOTES   space-separated list (default: "origin github")
#   GIT_PUSHALL_MAX       max attempts per remote (default: 4)
#   GIT_PUSHALL_SLEEP     base sleep (s) for linear backoff (default: 2)
#
# `git land <branch>` ‚ÄĒ canonical "merge a feature branch into main" flow for
# the mirrored repo: merge locally, then `pushall` so both remotes converge on
# the same SHA. Never click "Merge" in the web UI; each host creates its own
# squash commit with a different SHA and `main` diverges.
#
#   git land feature/foo            # default --no-ff merge
#   GIT_LAND_FF=1 git land foo      # force --ff-only (rebased branches)
#   GIT_LAND_KEEP=1 git land foo    # don't delete the local branch after
[alias]
	pushall = "!f() { \
		set -e; \
		ref=\"${1:-HEAD}\"; shift 2>/dev/null || true; \
		remotes=\"${GIT_PUSHALL_REMOTES:-origin github}\"; \
		max=\"${GIT_PUSHALL_MAX:-4}\"; \
		base=\"${GIT_PUSHALL_SLEEP:-2}\"; \
		for r in $remotes; do \
			n=1; \
			while :; do \
				if git push \"$r\" \"$ref\" \"$@\"; then break; fi; \
				if [ \"$n\" -ge \"$max\" ]; then \
					echo \"[pushall] $r: failed after $n attempts\" >&2; exit 1; \
				fi; \
				sleep $((n*base)); \
				echo \"[pushall] $r: retry $((n+1))/$max...\" >&2; \
				n=$((n+1)); \
			done; \
		done; \
	}; f"
	land = "!f() { \
		set -e; \
		branch=\"$1\"; \
		if [ -z \"$branch\" ]; then echo 'usage: git land <branch>' >&2; exit 2; fi; \
		if [ \"$branch\" = main ] || [ \"$branch\" = master ]; then echo 'refusing to land main/master onto itself' >&2; exit 2; fi; \
		git checkout main; \
		git pull --ff-only; \
		if [ -n \"$GIT_LAND_FF\" ]; then \
			git merge --ff-only \"$branch\"; \
		else \
			git merge --no-ff --no-edit \"$branch\"; \
		fi; \
		git pushall main; \
		if [ -z \"$GIT_LAND_KEEP\" ]; then git branch -d \"$branch\"; fi; \
	}; f"

[init]
	defaultBranch = main

[push]
	default = simple
	autoSetupRemote = true

[pull]
	rebase = true

[fetch]
	prune = true

[grep]
	lineNumber = true

[branch]
	sort = -committerdate

[merge]
	tool = nvim
	conflictstyle = zdiff3

[mergetool]
	keepBackup = false
	prompt = false

[mergetool "nvim"]
	cmd = nvim -d -c \"wincmd l\" -c \"norm ]c\" \"$LOCAL\" \"$MERGED\" \"$REMOTE\"

[diff]
	algorithm = histogram
	colorMoved = default

[rebase]
	autosquash = true
	autostash = true

[log]
	date = relative

{{- if eq .chezmoi.os "windows" }}
[credential]
	# Windows: Git Credential Manager handles HTTPS auth (push goes over SSH via
	# 1Password agent; this only covers HTTPS fetches that need a token).
	helper = manager
[credential "helperselector"]
	# Pin the helper choice so GCM doesn't prompt when multiple helpers exist.
	selected = manager
{{- end }}

# Delta (diff tool) configuration
{{- $delta_theme := index .theme_mappings.delta .theme.name }}
[delta]
	navigate = true
	line-numbers = true
	side-by-side = false
	syntax-theme = {{ $delta_theme }}
	features = decorations
	pager = less -RFX
	true-color = always
	inspect-raw-lines = false
	plus-style = syntax "#1a3a2a"
	plus-emph-style = syntax "#2a5a3a"
	minus-style = syntax "#3a1a2a"
	minus-emph-style = syntax "#5a2a3a"
	line-numbers-plus-style = "#5ccc96"
	line-numbers-minus-style = "#ce6f8f"

[delta "decorations"]
	commit-decoration-style = bold "#e39400" box
	file-style = bold "#e39400"
	file-decoration-style = "#e39400" box
	hunk-header-decoration-style = "#42b3c2" box

[interactive]
	diffFilter = delta --color-only

# Color configuration (spaceduck-harmonious)
# NOTE: [color "diff"] intentionally omitted ‚ÄĒ delta handles all diff coloring
# via syntax-theme + minus/plus styles. Git's color.diff.old interferes with
# delta's syntax highlighting on removed lines.
[color]
	ui = auto
	status = auto
	branch = auto

[color "status"]
	added = "#5ccc96" bold
	changed = "#e39400" bold
	untracked = "#ce6f8f" bold

[color "branch"]
	current = "#e39400" bold
	local = "#5ccc96" bold
	remote = "#42b3c2" bold

# 1Password SSH Agent: push over SSH (auth via 1Password), fetch over HTTPS
# (auth via GCM if a private repo needs a token). Symmetric for every host
# below to keep behaviour predictable.
{{- if .setup_1password }}
[url "git@github.com:"]
	pushInsteadOf = https://github.com/
[url "git@git.dreamhost.com:"]
	pushInsteadOf = https://git.dreamhost.com/
{{- end }}
{{- if eq .chezmoi.os "windows" }}
[safe]
	# Wildcard allows repos on drives with ownership mismatches (e.g. files
	# originally created under a different Windows user SID). Safe on a
	# personal developer machine where you control what repos you clone.
	directory = *
{{- end }}

{
  "$schema": "https://zed.dev/schema/settings.json",

  // ── Theme & UI ────────────────────────────────────────────────
  "theme": {
    "mode": "dark",
    "light": "Spaceduck",
    "dark": "Spaceduck"
  },
  "icon_theme": "Material Icon Theme",
  "ui_font_family": "Hack Nerd Font",
  "ui_font_size": 15,
  "buffer_font_family": "Hack Nerd Font Mono",
  "buffer_font_fallbacks": ["Fira Code", "Symbols Nerd Font Mono", "Noto Color Emoji"],
  "buffer_font_size": 14,
  "buffer_font_features": {
    "calt": true,
    "ss02": true,
    "ss03": true,
    "ss04": true,
    "ss05": true,
    "ss08": true,
    "cv15": true,
    "cv24": true,
    "cv29": true
  },
  "buffer_line_height": "comfortable",

  // ── Editor behavior ──────────────────────────────────────────
  "vim_mode": true,
  "relative_line_numbers": true,
  "cursor_blink": false,
  "show_whitespaces": "boundary",
  "soft_wrap": "editor_width",
  "preferred_line_length": 100,
  "wrap_guides": [80, 100],
  "tab_size": 2,
  "hard_tabs": false,
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "restore_on_startup": "last_workspace",
  "confirm_quit": false,
  "use_smartcase_search": true,

  // ── Files & exclusions ───────────────────────────────────────
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    "**/target",
    "**/dist",
    "**/build",
    "**/.venv",
    "**/__pycache__"
  ],
  "auto_update": true,

  // ── Terminal ─────────────────────────────────────────────────
  "terminal": {
    "shell": {
      "program": "/bin/zsh"
    },
    "font_family": "Hack Nerd Font Mono",
    "font_size": 13,
    "copy_on_select": false,
    "blinking": "off",
    "working_directory": "current_project_directory"
  },

  // ── Git & version control ────────────────────────────────────
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 600
    }
  },

  // ── Project panel & UI ───────────────────────────────────────
  "project_panel": {
    "dock": "left",
    "default_width": 280,
    "git_status": true,
    "indent_size": 16
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": true
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "close_position": "right"
  },
  "scrollbar": {
    "show": "auto",
    "git_diff": true,
    "selected_symbol": true
  },
  "minimap": {
    "show": "auto"
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },

  // ── Language defaults ────────────────────────────────────────
  "languages": {
    "Rust": {
      "tab_size": 4,
      "format_on_save": "on"
    },
    "Python": {
      "tab_size": 4,
      "format_on_save": "on",
      "language_servers": ["pyright", "ruff"],
      "formatter": [
        { "language_server": { "name": "ruff" } }
      ]
    },
    "Go": {
      "tab_size": 4,
      "hard_tabs": true,
      "format_on_save": "on"
    },
    "Ruby": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "Perl": {
      "tab_size": 4
    },
    "Lua": {
      "tab_size": 2
    },
    "Zig": {
      "tab_size": 4,
      "format_on_save": "on"
    },
    "JavaScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JSON": {
      "tab_size": 2
    },
    "TOML": {
      "tab_size": 2
    },
    "YAML": {
      "tab_size": 2
    },
    "Markdown": {
      "soft_wrap": "preferred_line_length",
      "format_on_save": "off"
    }
  },

  // ── LSP tweaks ───────────────────────────────────────────────
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": { "command": "clippy" },
        "cargo": { "features": "all" }
      }
    },
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "typeCheckingMode": "basic"
          }
        }
      }
    }
  },

  // ── AI / Agent ───────────────────────────────────────────────
  "features": {
    "edit_prediction_provider": "zed"
  },
  "agent": {
    "default_profile": "ask",
    "always_allow_tool_actions": false
  },

  // ── Extensions to auto-install ───────────────────────────────
  // Note: Spaceduck is not in Zed's extension registry; it's installed as a
  // user theme JSON in ~/.config/zed/themes/spaceduck.json.
  "auto_install_extensions": {
    "material-icon-theme": true,
    "toml": true,
    "dockerfile": true,
    "docker-compose": true,
    "nix": true,
    "ruby": true,
    "lua": true,
    "perl": true,
    "zig": true,
    "make": true,
    "nu": true,
    "fish": true,
    "powershell": true,
    "terraform": true,
    "ansible": true,
    "html": true,
    "git-firefly": true,
    "log": true,
    "env": true,
    "scss": true
  }
}

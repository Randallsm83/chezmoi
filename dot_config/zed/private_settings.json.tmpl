// ╚══════╝╚══════╝╚═════╝
// High-performance multiplayer code editor.
//

{
  "$schema": "https://zed.dev/schema/settings.json",

  // ── Theme & UI ────────────────────────────────────
  // Theme name is rendered from .chezmoidata/theme.yaml → theme_mappings.zed[.theme].
  // Change `.theme.name` to flip every editor in lockstep.
  "theme": {
    "mode": "dark",
    "light": "{{ index .theme_mappings.zed .theme }}",
    "dark": "{{ index .theme_mappings.zed .theme }}"
  },
  "icon_theme": "Material Icon Theme",
  "ui_font_family": "Hack Nerd Font",
  "ui_font_size": 15,
  "buffer_font_family": "Hack Nerd Font Mono",
  "buffer_font_fallbacks": ["Fira Code", "Symbols Nerd Font Mono", "Noto Color Emoji"],
  "buffer_font_size": 14,
  "buffer_font_features": {
    "calt": true,
    "ss02": true,
    "ss03": true,
    "ss04": true,
    "ss05": true,
    "ss08": true,
    "cv15": true,
    "cv24": true,
    "cv29": true
  },
  "buffer_line_height": "comfortable",

  // ── Editor behavior ────────────────────────────────
  "vim_mode": true,
  "relative_line_numbers": true,
  "cursor_blink": false,
  "show_whitespaces": "boundary",
  "soft_wrap": "editor_width",
  "preferred_line_length": 100,
  "wrap_guides": [80, 100],
  "tab_size": 2,
  "hard_tabs": false,
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "autosave": "on_focus_change",
  "restore_on_startup": "last_workspace",
  "confirm_quit": false,
  "use_smartcase_search": true,

  // ── Files & exclusions ─────────────────────────────
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    "**/target",
    "**/dist",
    "**/build",
    "**/.venv",
    "**/__pycache__"
  ],
  "auto_update": true,

  // ── Telemetry / Privacy ─────────────────────────────
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },

  // ── Terminal ─────────────────────────────────────
  "terminal": {
    "shell": {
      "program": "/bin/zsh"
    },
    "font_family": "Hack Nerd Font Mono",
    "font_size": 13,
    "copy_on_select": false,
    "blinking": "off",
    "working_directory": "current_project_directory"
  },

  // ── Git & version control ─────────────────────────────
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 600
    }
  },

  // ── Project panel & UI ─────────────────────────────
  "project_panel": {
    "dock": "left",
    "default_width": 280,
    "git_status": true,
    "indent_size": 16
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": true
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "close_position": "right"
  },
  "scrollbar": {
    "show": "auto",
    "git_diff": true,
    "selected_symbol": true
  },
  "minimap": {
    "show": "auto"
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },

  // ── Language defaults ───────────────────────────────
  "languages": {
    "Rust": {
      "tab_size": 4,
      "format_on_save": "on"
    },
    "Python": {
      "tab_size": 4,
      "format_on_save": "on",
      "language_servers": ["pyright", "ruff"],
      "formatter": [
        { "language_server": { "name": "ruff" } }
      ]
    },
    "Go": {
      "tab_size": 4,
      "hard_tabs": true,
      "format_on_save": "on"
    },
    "Ruby": {
      "tab_size": 2,
      "format_on_save": "on"
    },
    "Perl": {
      "tab_size": 4
    },
    "Lua": {
      "tab_size": 2
    },
    "Zig": {
      "tab_size": 4,
      "format_on_save": "on"
    },
    "JavaScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "JSON": {
      "tab_size": 2
    },
    "TOML": {
      "tab_size": 2
    },
    "YAML": {
      "tab_size": 2
    },
    "Markdown": {
      "soft_wrap": "preferred_line_length",
      "format_on_save": "off"
    }
  },

  // ── LSP tweaks ────────────────────────────────────
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": { "command": "clippy" },
        "cargo": { "features": "all" }
      }
    },
    "pyright": {
      "settings": {
        "python": {
          "analysis": {
            "typeCheckingMode": "basic"
          }
        }
      }
    }
  },

  // ── MCP / Context servers ─────────────────────────────
  // pam is the SOLE source of MCP servers — every tool (tavily, context7,
  // sequential-thinking, etc.) is exposed through the single pam stdio proxy.
  // Do NOT add additional context_servers entries here. To add or remove an
  // MCP backend, edit .chezmoidata/mcp.yaml and `pam sync --client zed`.
  // TODO: convert this file to .tmpl and template the --token=... via $secretsTpl
  // so it isn't committed to git in plaintext.
  "context_servers": {
    "pam": {
      "args": [
        "mcpd-stdio",
        "--token=cb2390154ee6f9954b41f86acddb5acdf84274de901e16318cdd9d95208e82d8"
      ],
      "command": "pam",
      "source": "custom"
    }
  },

  // ── AI / Agent ────────────────────────────────────
  "features": {
    "edit_prediction_provider": "zed"
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "default_profile": "mine",
    "always_allow_tool_actions": false,
    "default_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-7-latest",
      "enable_thinking": true,
      "effort": "high"
    },
    "profiles": {
      "mine": {
        "name": "Mine",
        "default_model": {
          "provider": "anthropic",
          "model": "claude-opus-4-7-latest",
          "enable_thinking": true,
          "effort": "high"
        },
        "tools": {
          "update_plan": true,
          "terminal": true,
          "spawn_agent": true,
          "save_file": true,
          "restore_file_from_disk": true,
          "read_file": true,
          "open": true,
          "now": true,
          "move_path": true,
          "list_directory": true,
          "grep": true,
          "find_path": true,
          "fetch": true,
          "edit_file": true,
          "diagnostics": true,
          "delete_path": true,
          "create_directory": true,
          "copy_path": true
        },
        // pam exposes every MCP backend in .chezmoidata/mcp.yaml — enable them
        // all here instead of pinning a per-server allow-list that drifts.
        "enable_all_context_servers": true
      }
    }
  },

  // ── Extensions to auto-install ───────────────────────
  // Note: Spaceduck is not in Zed's extension registry; it's installed as a
  // user theme JSON in ~/.config/zed/themes/spaceduck.json.
  "auto_install_extensions": {
    "material-icon-theme": true,
    "toml": true,
    "dockerfile": true,
    "docker-compose": true,
    "nix": true,
    "ruby": true,
    "lua": true,
    "perl": true,
    "zig": true,
    "make": true,
    "nu": true,
    "fish": true,
    "powershell": true,
    "terraform": true,
    "ansible": true,
    "html": true,
    "git-firefly": true,
    "log": true,
    "env": true,
    "scss": true
  }
}

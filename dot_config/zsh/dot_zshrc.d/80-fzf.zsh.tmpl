# Command-line fuzzy finder.
#

#!/usr/bin/env zsh

(( $+commands[fzf] )) || return 1

# Default options — colors rendered from .chezmoidata/theme.yaml → theme.<active>.
# `.theme.name` at this scope is the active theme name string (set in .chezmoi.toml.tmpl);
# the palette dict for that theme lives in .chezmoidata/theme.yaml under `theme.<name>`.
# Same indirection used by wezterm.lua.tmpl and the bat/opencode generators.
# Change `.theme.name` in .chezmoidata/theme.yaml to flip every editor (including fzf) in lockstep.
{{- $themes := index (fromYaml (include ".chezmoidata/theme.yaml")) "theme" }}
{{- $p := index $themes .theme.name }}
export FZF_DEFAULT_OPTS="
  --color=bg+:{{ $p.background }},bg:{{ $p.background }},spinner:{{ $p.blue }},hl:{{ $p.purple }}
  --color=fg:{{ $p.foreground }},header:{{ $p.blue }},info:{{ $p.green }},pointer:{{ $p.orange }}
  --color=marker:{{ $p.yellow }},fg+:{{ $p.foreground }},prompt:{{ $p.blue }},hl+:{{ $p.purple }}
  --border --height=40% --layout=reverse --info=inline
  --margin=1 --padding=1
"

# CTRL-Y to copy the command into clipboard using pbcopy
export FZF_CTRL_R_OPTS="
  --bind 'ctrl-y:execute-silent(echo -n {2..} | pbcopy)+abort'
  --color header:italic
  --header 'Press CTRL-Y to copy command into clipboard'"

# Preview file content using bat (https://github.com/sharkdp/bat)
export FZF_CTRL_T_OPTS="
  --walker-skip .git,node_modules,target
  --preview 'bat -n --color=always {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"

# Print tree structure in the preview window
export FZF_ALT_C_OPTS="
  --walker-skip .git,node_modules,target
  --preview 'tree -C {}'"

# Source the shell integration from a version-keyed cache (regenerated only
# when the fzf binary changes) instead of spawning `fzf --zsh` every startup.
zsh_cache_eval fzf-init fzf --zsh


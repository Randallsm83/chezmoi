{{- /* This file is part of the golang package */ -}}
{{- /* Controlled by .package_features.golang flag in .chezmoidata.yaml */ -}}
#!/usr/bin/env zsh

update_golang_env() {
  local go_bin_path="${commands[go]-}"
  if [[ -n "${go_bin_path}" ]]; then
    export GOROOT="${go_bin_path:A:h:h}"
    export GOPATH="${GOROOT:A:h}/packages"
  fi
}

autoload -U add-zsh-hook
add-zsh-hook precmd update_golang_env


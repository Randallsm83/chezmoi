{{- /*
Windows-side unbound: loopback-only recursive caching resolver for public DNS.

Role:
  Windows physical adapters point at 127.0.0.1 only.
  Local apps (Windows resolver -> 127.0.0.1:53)
    -> unbound here (loopback-only cache; DNSSEC validation off)
    -> unbound's iterator recurses directly from the root/auth DNS over IPv4
       for public DNS answers.

No upstream forwarders are configured for public DNS. Windows adapters stay
pinned to local unbound; unbound performs direct recursion instead of
forwarding to upstream recursive resolvers.

DNSSEC validation is OFF. Re-enabling would require unbound-anchor to
bootstrap the root key on Windows, which adds maintenance for marginal
benefit on this workstation-local cache.

Edit this template; chezmoi re-runs the install script if its sha256
changes (same trigger pattern as the librewolf script).
*/ -}}
server:
    # ── Logging ─────────────────────────────────────────────────────────
    verbosity: 1
    use-syslog: no
    log-time-ascii: yes

    # ── Listen ──────────────────────────────────────────────────────────
    interface: 127.0.0.1@53
    port: 53

    # ── ACL ─────────────────────────────────────────────────────────────
    # Loopback only. Nothing else on the LAN can use this resolver.
    access-control: 127.0.0.0/8 allow
    access-control: 0.0.0.0/0 refuse
    access-control: ::/0 refuse

    # ── Behavior ────────────────────────────────────────────────────────
    do-tcp: yes
    do-udp: yes
    # IPv6 disabled: this host has no usable IPv6 DNS path. Without this,
    # unbound's iterator tries IPv6 root/auth servers and floods the Windows
    # Application log with "udp connect failed: No error" entries. Local apps
    # resolve via 127.0.0.1, so no ::1 listener is needed.
    do-ip4: yes
    do-ip6: no
    # Recursive caching resolver. The iterator sends IPv4 queries directly to
    # root/auth servers for public DNS; Windows adapters remain configured to
    # 127.0.0.1 so apps use this local cache.
    module-config: "iterator"

    # Performance tuning for a single-user workstation.
    num-threads: 2
    msg-cache-size: 32m
    rrset-cache-size: 64m
    cache-min-ttl: 60
    cache-max-ttl: 86400
    prefetch: yes
    prefetch-key: yes
    serve-expired: yes
    serve-expired-ttl: 86400
    serve-expired-client-timeout: 1800

    # Hardening safe for direct recursion on a loopback-only workstation cache.
    hide-identity: yes
    hide-version: yes
    harden-glue: yes
    harden-dnssec-stripped: yes
    use-caps-for-id: no

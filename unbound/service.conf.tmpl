{{- /*
Windows-side unbound: a tiny DoT-forwarding stub resolver.

Role:
  Local apps (Windows resolver -> 127.0.0.1:53)
    -> unbound here (no recursion, no validation)
    -> DoT (TCP/853 + TLS) to raspi.tailf7fd34.ts.net (via LAN or tailnet IP)
         - LE cert, ACL on the Pi accepts our LAN + tailnet CIDRs
         - terminates DoT and forwards to Pi-hole, which gives us the
           homelab's ad-blocked, locally-overridden DNS

No public DoT fallback ON PURPOSE. Earlier iteration included Cloudflare +
Quad9 as fallbacks for off-network scenarios, but unbound's forwarder
selection (WP2) was preferring the public anycast resolvers over the LAN
raspi by RTT, silently bypassing Pi-hole filtering. Single upstream means:
  - raspi up    -> DNS works, fully encrypted, ad-blocked
  - raspi down  -> DNS fails (browsers will cache for a while; user fixes Pi)
If you ever need the public fallback (laptop scenario), switch this conf
to use only the tailnet IP and add `1.1.1.1@853#cloudflare-dns.com` back.
Documented in dotfiles README under "Windows DNS".

DNSSEC validation is OFF. The Pi forwards via dnscrypt-proxy to Cloudflare
which validates upstream. Re-enabling would require unbound-anchor to
bootstrap the root key on Windows, which adds maintenance for marginal
benefit (validation already done upstream).

The TLS cert bundle path below is rendered at chezmoi-apply time. cacert
is in always_install.scoop so it's guaranteed present.

Edit this template; chezmoi re-runs the install script if its sha256
changes (same trigger pattern as the librewolf script).
*/ -}}
server:
    # ── Logging ─────────────────────────────────────────────────────────
    verbosity: 1
    use-syslog: no
    log-time-ascii: yes

    # ── Listen ──────────────────────────────────────────────────────────
    interface: 127.0.0.1@53
    interface: ::1@53
    port: 53

    # ── ACL ─────────────────────────────────────────────────────────────
    # Loopback only. Nothing else on the LAN can use this resolver.
    access-control: 127.0.0.0/8 allow
    access-control: ::1 allow
    access-control: 0.0.0.0/0 refuse
    access-control: ::/0 refuse

    # ── Behavior ────────────────────────────────────────────────────────
    do-tcp: yes
    do-udp: yes
    # We're a forwarder, not a recursor. Disable the validator module
    # (Pi/cloudflare/quad9 all DNSSEC-validate for us).
    module-config: "iterator"

    # Performance tuning for a single-user workstation.
    num-threads: 2
    msg-cache-size: 32m
    rrset-cache-size: 64m
    cache-min-ttl: 60
    cache-max-ttl: 86400
    prefetch: yes
    prefetch-key: yes
    serve-expired: yes
    serve-expired-ttl: 86400
    serve-expired-client-timeout: 1800

    # ── TLS ─────────────────────────────────────────────────────────────
    # System CA bundle (scoop "cacert" package, file is cacert.pem).
    # Required for unbound to validate the Let's Encrypt cert on the raspi
    # DoT terminator and the public DoT fallbacks.
    tls-cert-bundle: "{{ .chezmoi.homeDir | replace "\\" "/" }}/scoop/apps/cacert/current/cacert.pem"

    # Hardening (forwarder-safe set only).
    # Removed for forwarder mode:
    #   - qname-minimisation: forces unbound into recursive query path,
    #     which silently switches to plain UDP/53 to root servers and
    #     bypasses our forward-zone.
    #   - harden-referral-path: same — a recursor-only feature that
    #     causes unbound to consult NS records and walk the tree itself.
    # Both were verified empirically: with them on, unbound contacts root
    # servers on UDP/53. Off, it cleanly forwards via DoT.
    hide-identity: yes
    hide-version: yes
    harden-glue: yes
    harden-dnssec-stripped: yes
    use-caps-for-id: no

forward-zone:
    name: "."
    # Use TLS for every upstream.
    forward-tls-upstream: yes
    # Try in order; on failure unbound moves to the next forward-addr.
    # forward-first must be NO so unbound never silently bypasses TLS.
    forward-first: no

    # raspi DoT terminator, LAN address. The Pi's ACL accepts 192.168.0.0/16.
    # The "#authname" suffix supplies the SNI / certificate validation
    # hostname; LE cert is for raspi.tailf7fd34.ts.net regardless of which
    # IP we connect to, so cert validation still passes via the system CA
    # bundle.
    forward-addr: 192.168.0.26@853#raspi.tailf7fd34.ts.net

    # Same terminator via tailnet. Used when off-LAN but Tailscale is up.
    # Listed second so unbound's WP2 prefers the LAN path when both work
    # (LAN handshake is generally lower RTT).
    forward-addr: 100.100.149.88@853#raspi.tailf7fd34.ts.net

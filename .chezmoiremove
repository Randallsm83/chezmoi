# ============================================================================
# Chezmoi Remove Patterns
# ============================================================================
# https://www.chezmoi.io/reference/special-files-and-directories/chezmoiremove/
#
# Files listed here will be DELETED from the destination on `chezmoi apply`
# when the corresponding feature flag is disabled.
#
# IMPORTANT: These patterns mirror .chezmoiignore feature flag sections.
# When a feature is disabled, .chezmoiignore stops managing the files and
# .chezmoiremove actively removes them from the destination.
#
# Validation: Run `chezmoi execute-template < .chezmoiremove` to test syntax
# ============================================================================

{{- if eq .chezmoi.os "windows" }}
# Windows mise does not activate conf.d fragments. Remove the stale managed
# fragment and use ~/.config/mise/config.toml instead.
.config/mise/conf.d/00-managed.toml
{{- end }}

{{- if ne .chezmoi.os "windows" }}
# Git config is XDG-managed at ~/.config/git/config on Unix. Remove stale
# ~/.gitconfig files that shadow or partially override the managed config.
.gitconfig
{{- end }}


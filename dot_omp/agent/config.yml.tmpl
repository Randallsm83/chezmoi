{{- $isWSL := and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
providers:
  webSearch: codex
  image: openai
  kimiApiFormat: openai
setupVersion: 1
theme:
  dark: dark-tokyo-night
symbolPreset: nerd
statusLine:
  preset: nerd
  separator: powerline-thin
  sessionAccent: true
  showHookStatus: true
terminal:
  showImages: true
tui:
  hyperlinks: auto
display:
  shimmer: kitt
  showTokenUsage: true
{{- if eq .chezmoi.os "darwin" }}
shellPath: /bin/zsh
{{- else if eq .chezmoi.os "linux" }}
shellPath: /usr/bin/zsh
{{- end }}
showHardwareCursor: true
task:
  showResolvedModelBadge: true
memory:
  backend: mnemopi
mnemopi:
  scoping: per-project-tagged
vault:
  enabled: true
github:
  enabled: true
secrets:
  enabled: true
modelRoles:
  vision: anthropic/claude-opus-4-8:high
  plan: anthropic/claude-fable-5:high
  slow: anthropic/claude-opus-4-8:xhigh
  default: anthropic/claude-opus-4-8:high
  designer: anthropic/claude-opus-4-8:high
  task: openai-codex/gpt-5.5:xhigh
  commit: openai-codex/gpt-5.5:xhigh
  smol: openai-codex/gpt-5.5:medium
  advisor: anthropic/claude-fable-5:high
defaultThinkingLevel: auto
autoResume: false
steeringMode: one-at-a-time
followUpMode: one-at-a-time
interruptMode: immediate
loop:
  mode: compact
doubleEscapeAction: tree
treeFilterMode: all
stt:
  enabled: true
compaction:
  handoffSaveToDisk: true
collapseChangelog: false
todo:
  reminders:
    max: 1
dev:
  autoqa:
    consent: granted
hideThinkingBlock: false
{{ if $isWSL }}
disabledExtensions:
  - mcp:pam
{{ end }}

# SSH Configuration
# Works across Windows, WSL, macOS, and Linux via 1Password SSH agent.
#
# Key selection strategy:
#   All platforms — IdentityFile .pub hints tell OpenSSH to offer exactly one
#                   key per host, avoiding the 6-key MaxAuthTries limit.
#                   OpenSSH matches the .pub fingerprint against the agent and
#                   uses the corresponding private key in 1Password for signing.
#                   Private keys never leave 1Password.
#
# Key rotation: edit the SSH Key item in the 1Password app (generate new key).
# Run `chezmoi apply` afterward — .pub files update automatically, no template
# edits needed as long as item names stay stable.
#
# Platform-specific overrides (WSL, etc.): ~/.ssh/config.d/<platform>
Include config.d/*

# ── Git Hosting ───────────────────────────────────────────────────────────────

# GitHub  (alias: gh)
# Use git@gh:user/repo.git or git@github.com:user/repo.git interchangeably.
Host gh github.com
  HostName github.com
  User git
  IdentitiesOnly yes
  IdentityFile ~/.ssh/github_com.pub

# GitLab  (alias: gl)
# Use git@gl:user/repo.git or git@gitlab.com:user/repo.git interchangeably.
Host gl gitlab.com
  HostName gitlab.com
  User git
  IdentitiesOnly yes
  IdentityFile ~/.ssh/gitlab_com.pub

# DreamHost Git  (alias: dh-git)
Host dh-git git.dreamhost.com
  HostName git.dreamhost.com
  User rmiller
  IdentitiesOnly yes
  IdentityFile ~/.ssh/dh_git.pub

# ── DreamHost Servers ─────────────────────────────────────────────────────────
# ForwardAgent enabled on all — git deployments run from these servers.

Host yakko
  HostName ***REMOVED***
  User rmiller
  ForwardAgent yes
  IdentitiesOnly yes
  IdentityFile ~/.ssh/dh_yakko.pub

Host porky
  HostName ***REMOVED***
  User rmiller
  ForwardAgent yes
  IdentitiesOnly yes
  IdentityFile ~/.ssh/dh_porky.pub

# VPS running ***REMOVED*** app — git deploy access required.
Host ***REMOVED***
  HostName ***REMOVED***
  User ***REMOVED***
  ForwardAgent yes
  IdentitiesOnly yes
  IdentityFile ~/.ssh/***REMOVED***.pub

# DreamPress WordPress server — git deploy access required.
Host fp3
  HostName ***REMOVED***
  User ***REMOVED***
  ForwardAgent yes
  IdentitiesOnly yes
  IdentityFile ~/.ssh/fp3.pub

# ── Home Lab ──────────────────────────────────────────────────────────────────

# Raspberry Pi on the local network.
Host raspi raspi.local
  HostName raspi.local
  User ranmil
  IdentitiesOnly yes
  IdentityFile ~/.ssh/raspi.pub

# ── Global Defaults ───────────────────────────────────────────────────────────
# IMPORTANT: Host * must be last so per-host overrides take effect first.
Host *
{{- if not .is_remote }}
  # 1Password SSH agent path (platform-specific).
  # Omitted on remote machines so the forwarded agent ($SSH_AUTH_SOCK) is used.
{{-   if eq .chezmoi.os "windows" }}
  IdentityAgent "//./pipe/openssh-ssh-agent"
{{-   else }}
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
#  IdentityAgent ~/.1password/agent.sock
{{-   end }}
{{- end }}
  # Allow the agent to offer keys not listed in IdentityFile.
  # Per-host blocks above override this with yes + a specific .pub hint.
  IdentitiesOnly no
  AddKeysToAgent no
  ForwardAgent no
  HashKnownHosts yes
  PreferredAuthentications publickey
  GSSAPIAuthentication no
  # Keep connections alive across idle periods.
  ServerAliveInterval 60
  ServerAliveCountMax 3
{{- if ne .chezmoi.os "windows" }}
  # Connection multiplexing — reuse one TCP/SSH session for multiple ops.
  # Reduces 1Password SSH agent prompts: N back-to-back git ops = 1 signing
  # request instead of N. ControlPath uses %C (hashed conn tuple).
  # Excluded on Windows: native OpenSSH advertises ControlMaster but fails
  # with "getsockname failed: Not a socket" — Unix-domain socket paths don't
  # work as ssh control sockets on Windows.
  ControlMaster auto
  ControlPath ~/.ssh/cm-%C
  ControlPersist 10m
{{- end }}

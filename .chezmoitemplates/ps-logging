# =============================================================================
# Canonical PowerShell logging helpers — included via {{ "{{ template \"ps-logging\" . }}" }}
# =============================================================================
# Source of truth: .chezmoitemplates/ps-logging
#
# Provides:
#   - Write-Status -Message <s> -Type Info|Success|Warning|Error  (UI-formatted, file-mirrored)
#   - Write-LogLine -Message <s> [-Color <s>]                     (raw line, file-mirrored)
#   - Get-StatusLogFile                                           (resolves the XDG log path)
#
# Both Write-Status and Write-LogLine emit a timestamped line to
# $env:XDG_STATE_HOME\dotfiles\logs\<script>.log (falling back to
# $HOME\.local\state\dotfiles\logs\<script>.log when XDG_STATE_HOME is unset).
# Logging failures are swallowed so the UI path never breaks because of a
# permission/path issue on the disk side.
#
# Two plain .ps1 consumers (bootstrap.ps1, scripts/rollback.ps1) keep an
# inlined verbatim copy of these functions because they are downloaded and
# run via `iwr | iex` before chezmoi exists on the machine. Update both
# sites in lockstep when changing the canonical body.

function Get-StatusLogFile {
    <#
    .SYNOPSIS
        Resolve the per-script log file path under $env:XDG_STATE_HOME\dotfiles\logs\
    .DESCRIPTION
        Returns the absolute path to <script>.log under the dotfiles log
        directory, creating the directory on demand. Returns $null when the
        directory cannot be created so callers can no-op cleanly.
    #>
    [CmdletBinding()]
    param()

    $stateRoot = if ($env:XDG_STATE_HOME) { $env:XDG_STATE_HOME }
    else { Join-Path $HOME '.local\state' }

    $logDir = Join-Path $stateRoot 'dotfiles\logs'
    try {
        if (-not (Test-Path -LiteralPath $logDir)) {
            New-Item -ItemType Directory -Path $logDir -Force -ErrorAction Stop | Out-Null
        }
    } catch {
        return $null
    }

    $scriptLeaf =
        if ($PSCommandPath) { [System.IO.Path]::GetFileNameWithoutExtension($PSCommandPath) }
        elseif ($MyInvocation -and $MyInvocation.ScriptName) { [System.IO.Path]::GetFileNameWithoutExtension($MyInvocation.ScriptName) }
        else { 'ps-logging' }

    Join-Path $logDir ("$scriptLeaf.log")
}

function Write-Status {
    <#
    .SYNOPSIS
        Write a formatted status message with a colored icon and mirror it to the script log file.
    #>
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$Message,

        [ValidateSet('Info', 'Success', 'Warning', 'Error')]
        [string]$Type = 'Info',

        [string]$LogFile
    )

    $colors  = @{ Info = 'Cyan';  Success = 'Green';   Warning = 'Yellow'; Error = 'Red' }
    $symbols = @{ Info = "$([char]0x2139)"; Success = "$([char]0x2713)"; Warning = "$([char]0x26A0)"; Error = "$([char]0x2717)" }

    Write-Host "$($symbols[$Type]) " -ForegroundColor $colors[$Type] -NoNewline
    Write-Host $Message

    if (-not $LogFile) { $LogFile = Get-StatusLogFile }
    if ($LogFile) {
        $timestamp = Get-Date -Format 'yyyy-MM-ddTHH:mm:ss.fff'
        try { Add-Content -LiteralPath $LogFile -Value "[$timestamp] [$Type] $Message" -ErrorAction Stop }
        catch { }
    }
}

function Write-LogLine {
    <#
    .SYNOPSIS
        Write a raw line to console (optionally colored) and mirror it to the script log file.
    #>
    [CmdletBinding()]
    param(
        [Parameter(Mandatory)]
        [string]$Message,

        [string]$Color = 'White',

        [string]$LogFile
    )

    Write-Host $Message -ForegroundColor $Color

    if (-not $LogFile) { $LogFile = Get-StatusLogFile }
    if ($LogFile) {
        $timestamp = Get-Date -Format 'yyyy-MM-ddTHH:mm:ss.fff'
        try { Add-Content -LiteralPath $LogFile -Value "[$timestamp] $Message" -ErrorAction Stop }
        catch { }
    }
}

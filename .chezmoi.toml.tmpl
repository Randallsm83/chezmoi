# Chezmoi configuration file
# https://www.chezmoi.io/reference/configuration-file/
# Version 2

{{- /* ========================================================================== */ -}}
{{- /* User Information (can be overridden in .chezmoi.local.toml)            */ -}}
{{- /* ========================================================================== */ -}}

{{- $email := "randallsm83@gmail.com" -}}
{{- $name := "Randall" -}}
{{- $github_username := "Randallsm83" -}}

{{- /* ========================================================================== */ -}}
{{- /* Platform Detection                                                      */ -}}
{{- /* ========================================================================== */ -}}

{{- $is_windows := eq .chezmoi.os "windows" -}}
{{- $is_darwin := eq .chezmoi.os "darwin" -}}
{{- $is_linux := eq .chezmoi.os "linux" -}}
{{- $is_wsl := and $is_linux (or (.chezmoi.kernel.osrelease | lower | contains "microsoft") (.chezmoi.kernel.osrelease | lower | contains "wsl")) -}}

{{- /* ========================================================================== */ -}}
{{- /* Machine Type Detection (Remote/Personal/Work)                          */ -}}
{{- /* ========================================================================== */ -}}

{{- $hostname := .chezmoi.hostname | lower -}}

{{- /* Check for remote indicators */ -}}
{{- $is_remote := or (ne (env "SSH_CONNECTION") "") (ne (env "SSH_CLIENT") "") (ne (env "SSH_TTY") "") (eq (env "TERM_PROGRAM") "vscode") -}}

{{- /* Check for container */ -}}
{{- $is_container := false -}}
{{- if $is_linux -}}
  {{- if stat "/.dockerenv" -}}
    {{- $is_container = true -}}
  {{- end -}}
{{- end -}}

{{- /* Classify machine based on hostname patterns */ -}}
{{- $is_work := false -}}
{{- $is_personal := false -}}
{{- $is_raspi := false -}}

{{- if or (contains "raspi" $hostname) (contains "raspberrypi" $hostname) (contains "rpi" $hostname) -}}
  {{- $is_raspi = true -}}
{{- end -}}

{{- if or (contains "work" $hostname) (contains "corp" $hostname) (contains "company" $hostname) (contains "office" $hostname) -}}
  {{- $is_work = true -}}
{{- else if or (contains "home" $hostname) (contains "personal" $hostname) (contains "laptop" $hostname) (contains "desktop" $hostname) -}}
  {{- $is_personal = true -}}
{{- else if $is_raspi -}}
  {{- /* Pi machines are personal */ -}}
  {{- $is_personal = true -}}
{{- else if not $is_remote -}}
  {{- /* Default local machines to personal */ -}}
  {{- $is_personal = true -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Remote tier selection: minimal | medium | full                          */ -}}
{{- /* - minimal: tiny SSH-only servers (current default for is_remote)        */ -}}
{{- /* - medium:  curated set for ARM SBCs / dev VMs (Pi, etc.)                */ -}}
{{- /* - full:    parity with desktop                                          */ -}}
{{- /* ========================================================================== */ -}}
{{- $remote_tier := "" -}}
{{- if $is_raspi -}}
  {{- $remote_tier = "medium" -}}
{{- else if $is_remote -}}
  {{- $remote_tier = "minimal" -}}
{{- else -}}
  {{- $remote_tier = "full" -}}
{{- end -}}

{{- /* Compat alias: remote_minimal stays a bool for existing templates */ -}}
{{- $remote_minimal := eq $remote_tier "minimal" -}}

{{- /* ========================================================================== */ -}}
{{- /* Permission Detection                                                    */ -}}
{{- /* ========================================================================== */ -}}

{{- /* On Unix, we'll check sudo at runtime, but we can make educated guesses */ -}}
{{- $has_sudo := false -}}
{{- if $is_windows -}}
  {{- /* Windows always has admin capability (elevation) */ -}}
  {{- $has_sudo = true -}}
{{- else if not $is_remote -}}
  {{- /* Local machines typically have sudo */ -}}
  {{- $has_sudo = true -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* XDG Base Directory Specification                                        */ -}}
{{- /* https://specifications.freedesktop.org/basedir-spec/basedir-spec-latest.html */ -}}
{{- /* ========================================================================== */ -}}

{{- $xdg_config_home := "" -}}
{{- $xdg_data_home := "" -}}
{{- $xdg_state_home := "" -}}
{{- $xdg_cache_home := "" -}}

{{- if $is_windows -}}
  {{- $xdg_config_home = joinPath .chezmoi.homeDir ".config" -}}
  {{- $xdg_data_home = joinPath .chezmoi.homeDir ".local" "share" -}}
  {{- $xdg_state_home = joinPath .chezmoi.homeDir ".local" "state" -}}
  {{- $xdg_cache_home = joinPath .chezmoi.homeDir ".cache" -}}
{{- else -}}
  {{- $xdg_config_home = joinPath .chezmoi.homeDir ".config" -}}
  {{- $xdg_data_home = joinPath .chezmoi.homeDir ".local" "share" -}}
  {{- $xdg_state_home = joinPath .chezmoi.homeDir ".local" "state" -}}
  {{- $xdg_cache_home = joinPath .chezmoi.homeDir ".cache" -}}
{{- end -}}

{{- /* ========================================================================== */ -}}
{{- /* Chezmoi Core Settings (top-level keys; must precede any [section])      */ -}}
{{- /* ========================================================================== */}}

# sourceDir intentionally not set — chezmoi's default is
# ~/.local/share/chezmoi on every platform, which is where this repo lives.
# Previously this was overridden to ~/.local/share/dotfiles, but that path
# was never populated and broke hooks (.install-1password.ps1) and template
# resolution. To override per-machine, set it in .chezmoi.local.toml instead.

{{- /* ========================================================================== */ -}}
{{- /* Data Section - Exposed to all templates                                 */ -}}
{{- /* ========================================================================== */}}

[data]
    # User information
    email = {{ $email | quote }}
    name = {{ $name | quote }}
    github_username = {{ $github_username | quote }}
    
    # Platform detection flags
    is_windows = {{ $is_windows }}
    is_darwin = {{ $is_darwin }}
    is_linux = {{ $is_linux }}
    is_wsl = {{ $is_wsl }}
    is_container = {{ $is_container }}
    
    # Machine type classification
    is_remote = {{ $is_remote }}
    is_personal = {{ $is_personal }}
    is_work = {{ $is_work }}
    is_raspi = {{ $is_raspi }}
    has_sudo = {{ $has_sudo }}  # Estimated, scripts should verify at runtime
    hostname = {{ .chezmoi.hostname | quote }}
    remote_tier = {{ $remote_tier | quote }}  # minimal | medium | full
    
    # XDG Base Directory paths
    xdg_config_home = {{ $xdg_config_home | quote }}
    xdg_data_home = {{ $xdg_data_home | quote }}
    xdg_state_home = {{ $xdg_state_home | quote }}
    xdg_cache_home = {{ $xdg_cache_home | quote }}

    # Package manager preferences
{{- if $is_windows }}
    package_manager_cli = "scoop"
    package_manager_gui = "winget"
    runtime_manager = "mise"
{{- else if $is_darwin }}
    package_manager = "homebrew"
    runtime_manager = "mise"
{{- else }}
    package_manager = "mise"
    runtime_manager = "mise"
{{- end }}

    # Shell preferences
{{- if $is_windows }}
    shell = "pwsh"
    shell_profile = {{ joinPath .chezmoi.homeDir "Documents" "PowerShell" "Microsoft.PowerShell_profile.ps1" | quote }}
{{- else }}
    shell = "zsh"
    shell_profile = {{ joinPath .chezmoi.homeDir ".config" "zsh" ".zshrc" | quote }}
{{- end }}

    # Font/styling defaults. Theme is defined in .chezmoidata/theme.yaml as a
    # map (.theme.name) and is NOT mirrored here as a plain string. Doing so
    # would shadow the map with a string, causing template errors in any file
    # that references .theme.name. Per-machine override: [data.theme] name = "..."
    # in .chezmoi.local.toml, not a top-level `theme = "..."` key.
    font = "Hack"
    font_fallback = "FiraCode"
    nerd_font = "Hack Nerd Font"
    
    # Feature flags (can be overridden in .chezmoi.local.toml)
    install_packages = {{ and (not $is_remote) (not $is_container) }}  # Skip on remote/containers by default
    install_runtimes = true
    setup_git_ssh = true
    setup_1password = {{ and (not $is_remote) (not $is_raspi) }}  # Skip on remote/Pi by default
    remote_minimal = {{ $remote_minimal }}  # Compat alias: true iff remote_tier == "minimal"

    # ---- Infrastructure identifiers (per-machine; EMPTY in public source) ----
    # Sensitive hostnames / IPs / remote usernames are NOT committed. The public
    # source ships empty defaults; real values live in gitignored
    # .chezmoi.local.toml under [data.infra] and are regenerated from 1Password
    # via the security runbook. Templates MUST guard each use with
    # `with .infra.<key>` so an empty value omits the block instead of rendering
    # broken config. Resolved WITHOUT op inject, so it can never empty .secrets.
{{- $infra := dict "dh_user" "" "ssh_host_yakko" "" "ssh_host_porky" "" "ssh_host_dhshell" "" "ssh_user_dhshell" "" "ssh_host_fp3" "" "ssh_user_fp3" "" "ssh_host_cass" "" "pi_fqdn" "" "pi_dog_ip" "" "omp_gateway_base_url" "" "omp_broker_url" "" "lm_studio_base_url" "" "vpn_pritunl_ns" "" "vpn_pritunl_domains" "" "dns_pi_addrs" "" -}}
{{- $infraLocalToml := joinPath .chezmoi.sourceDir ".chezmoi.local.toml" -}}
{{- if stat $infraLocalToml -}}
{{-   $liInfra := index (index (include $infraLocalToml | fromToml) "data" | default dict) "infra" | default dict -}}
{{-   $infra = mergeOverwrite $infra $liInfra -}}
{{- end }}
[data.infra]
{{- range $k, $v := $infra }}
    {{ $k }} = {{ $v | quote }}
{{- end }}


# ============================================================================
# 1Password Secrets - Single Batched Resolution
# ============================================================================
# Strategy: ONE `op inject` call resolves ALL op:// refs at chezmoi init time,
# producing a TOML block exposed as `.secrets.*` in templates.
#
# Cost: 1 biometric prompt per `chezmoi apply --init`.
# Routine `chezmoi apply` reuses cached chezmoi.toml — ZERO prompts.
#
# Refresh after key/PAT rotation:  chezmoi apply --init
# Skip 1Password entirely:         set CHEZMOI_SKIP_1P=1
#
# To add a new secret:
#   1. Append a line to $secretsTpl below (key = "op://vault/item/field").
#   2. Reference it as `.secrets.<key>` in any template.
#   3. Run `chezmoi apply --init`.
[data.secrets]
{{- /* Note: raspi item title contains '@' which is illegal in op:// refs,
       so we reference by stable item ID instead. */ -}}
{{- $secretsTpl := `ssh_pub_github_com  = "{{ op://Personal/GitHub SSH Key/public key }}"
ssh_pub_gitlab_com  = "{{ op://Personal/GitLab SSH Key/public key }}"
ssh_pub_dh_git      = "{{ op://DH/jc6rk4l6qqwva26fzs2e4k27iu/public key }}"
ssh_pub_dh_yakko    = "{{ op://DH/Yakko SSH Key/public key }}"
ssh_pub_dh_porky    = "{{ op://DH/Porky SSH Key/public key }}"
ssh_pub_dhshell     = "{{ op://Personal/DreamHost Shell SSH Key/public key }}"
ssh_pub_fp3         = "{{ op://Personal/fp3 SSH Key/public key }}"
ssh_pub_raspi       = "{{ op://Homelab/qdreol3xtwen3z6lcdcjkbkvw4/public key }}"
ssh_pub_openclaw    = "{{ op://Personal/Openclaw SSH Key/public key }}"
warp_api_key        = "{{ op://Personal/Warp API Key/credential }}"
gitlab_pat          = "{{ op://Personal/4mxqh5hwci5jq7h2on23s56pia/credential }}"
dh_gitlab_pat       = "{{ op://DH/ndmvgzl7uyaiikhdpquzwlzwde/credential }}"
dh_clickup_api_key  = "{{ op://DH/fw4qmg4qxp4pjzatmwpcvkodym/credential }}"
github_pat          = "{{ op://Personal/GitHub Token/token }}"` -}}
{{ "" }}
{{- if and (lookPath "op") (ne (env "CHEZMOI_SKIP_1P") "1") -}}
{{- if eq .chezmoi.os "windows" -}}
{{- /*
Windows op inject strategy: write the template to a temp file and run
`op inject -i FILE -o FILE`. The file-based form avoids stdin-pipe quirks
in the chezmoi subprocess (which previously caused op inject to silently
return empty under -NonInteractive).

The pwsh helper:
  - reads the rendered file as bytes (preserves Unicode key material)
  - normalizes CRLF -> LF so multi-line secret values (e.g. SSH keys with
    embedded newlines) don't produce broken TOML lines
  - trims a single trailing newline so the result lines up cleanly under
    the [data.secrets] header (which we emit on its own line above)
  - writes a diagnostic log to %TEMP%\chezmoi-op-inject.log so failures
    are debuggable without re-running
  - falls back to placeholder-stripping if op fails for any reason
*/ -}}
{{ printf "\n%s" (output "pwsh" "-NoProfile" "-NonInteractive" "-Command" (printf "$ErrorActionPreference='SilentlyContinue'; $log = Join-Path $env:TEMP 'chezmoi-op-inject.log'; $t = @'\n%s\n'@; $tmpIn = [System.IO.Path]::GetTempFileName(); $tmpOut = [System.IO.Path]::GetTempFileName(); $stamp = (Get-Date).ToString('o'); try { [System.IO.File]::WriteAllText($tmpIn, $t, [System.Text.UTF8Encoding]::new($false)); $opErr = & op inject -i $tmpIn -o $tmpOut --force 2>&1; $code = $LASTEXITCODE; $opPath = (Get-Command op -ErrorAction SilentlyContinue).Source; Add-Content -Path $log -Value (\"[$stamp] op=$opPath exit=$code outExists=$(Test-Path $tmpOut) errLen=$($opErr.Length)\"); if ($opErr) { Add-Content -Path $log -Value (\"[$stamp] STDERR: \" + ($opErr -join '|')) }; if ($code -eq 0 -and (Test-Path $tmpOut)) { $rendered = [System.IO.File]::ReadAllText($tmpOut); $rendered = $rendered -replace \"`r`n\", \"`n\"; $rendered = $rendered.TrimEnd(\"`n\"); Add-Content -Path $log -Value (\"[$stamp] rendered len=$($rendered.Length)\"); Write-Output $rendered } else { Add-Content -Path $log -Value (\"[$stamp] FALLBACK to placeholder strip\"); $fallback = $t -replace '\\{\\{ op://[^}]+ \\}\\}', ''; Write-Output $fallback.TrimEnd(\"`n\") } } catch { Add-Content -Path $log -Value (\"[$stamp] EXCEPTION: $($_.Exception.Message)\"); $fallback = $t -replace '\\{\\{ op://[^}]+ \\}\\}', ''; Write-Output $fallback.TrimEnd(\"`n\") } finally { Remove-Item -Force -ErrorAction SilentlyContinue $tmpIn, $tmpOut }; exit 0" $secretsTpl)) }}
{{- else -}}
{{ printf "\n%s" (output "sh" "-c" (printf "T=$(cat <<'__OP_EOT__'\n%s\n__OP_EOT__\n); printf '%%s\\n' \"$T\" | op inject 2>/dev/null || printf '%%s\\n' \"$T\" | sed -E 's/\\{\\{ op:\\/\\/[^}]+ \\}\\}//g'" $secretsTpl)) }}
{{- end -}}
{{- else -}}
{{- /*
FAIL LOUDLY when setup_1password is true but `op` is missing. Without this,
the template silently strips every op:// placeholder, leaving every
.secrets.* value empty (SSH public keys, API tokens, PATs, etc.) and
cascading into:
  - .chezmoiignore excluding every ~/.ssh/*.pub hint
  - dot_ssh/private_config.tmpl losing `IdentitiesOnly yes` bindings
  - .chezmoitemplates/1password-agent.toml rendering empty vault entries
  - Every Warp/GitLab/GitHub/Anthropic credential set to ""

Surface the problem at init time so the user can install op (or set
CHEZMOI_SKIP_1P=1 to opt out explicitly).
*/ -}}
{{- /* $setup_1password mirrors the inline computation on line ~188 above.
       We cannot use .setup_1password here because the [data] block is
       parsed by chezmoi only AFTER this template fully renders, so the
       value is not yet available within this same template file. */ -}}
{{- $setup_1password := and (not $is_remote) (not $is_raspi) -}}
{{- if and $setup_1password (ne (env "CHEZMOI_SKIP_1P") "1") -}}
{{- fail "1Password CLI (op) not found in PATH but setup_1password=true.\n\nWithout op, every .secrets.* value would be silently emptied (SSH pubkeys, PATs, API tokens). Refusing to apply.\n\nFix options:\n  - Arch:    paru -S 1password-cli  OR  yay -S 1password-cli\n  - Debian:  see https://1password.com/downloads/linux\n  - macOS:   brew install 1password-cli\n  - Bypass:  CHEZMOI_SKIP_1P=1 chezmoi apply (accepts empty secrets)" -}}
{{- end -}}
{{ printf "\n%s" (regexReplaceAll "\\{\\{ op://[^}]+ \\}\\}" $secretsTpl "") }}
{{- end }}

{{- /* ========================================================================== */ -}}
{{- /* Chezmoi Tool Configuration                                              */ -}}
{{- /* ========================================================================== */}}

# Tool configuration - these may not be available on first run
# Chezmoi will use built-in defaults if commands not found
[edit]
    command = "nvim"

[diff]
    # Disable the pager so `chezmoi apply` never blocks on `more`/`less`
    # waiting for stdin. When the apply also calls `sudo -v` (e.g. the
    # vpn-dns reconcile script), a stuck pager owns the TTY and causes
    # sudo to silently fail with 3 incorrect password attempts.
    pager = ""
    # Delta provides nice diffs; falls back to built-in diff if not found
    # Uncomment after first chezmoi apply installs delta via mise
    # command = "delta"
    # args = ["--paging=never"]

[merge]
    command = "nvim"
    args = ["-d"]

{{- if $is_windows }}
# Use PowerShell 7 (pwsh.exe) instead of Windows PowerShell 5.1
[interpreters.ps1]
    command = "pwsh"
    args = ["-NoLogo", "-NoProfile", "-NonInteractive", "-ExecutionPolicy", "Bypass", "-File"]
{{- end }}

{{- /* ========================================================================== */ -}}
{{- /* 1Password Integration                                                   */ -}}
{{- /* ========================================================================== */}}

{{- if eq .chezmoi.os "windows" }}
[hooks.read-source-state.pre]
    command = "pwsh"
    args = ["-NoProfile", "-NonInteractive", "-ExecutionPolicy", "Bypass", "-File", "{{ .chezmoi.sourceDir }}/.install-1password.ps1"]
{{- else }}
[hooks.read-source-state.pre]
    command = "{{ .chezmoi.sourceDir }}/.install-1password.sh"
{{- end }}

[onepassword]
    prompt = false
{{- if $is_windows }}
    command = {{ lookPath "op" | quote }}
{{- end }}

{{- /* ========================================================================== */ -}}
{{- /* Git Repository Settings                                                 */ -}}
{{- /* ========================================================================== */}}

[git]
    autoCommit = false
    autoPush = false

{{- /* ========================================================================== */ -}}
{{- /* Local Overrides                                                         */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Per-machine overrides live in .chezmoi.local.toml in the chezmoi source */ -}}
{{- /* dir (gitignored). Its contents are appended verbatim below; because     */ -}}
{{- /* chezmoi/TOML merge duplicate tables, a [data] / [data.package_features] */ -}}
{{- /* table here overrides the values emitted above. This is what makes the   */ -}}
{{- /* documented override mechanism actually work — previously this section    */ -}}
{{- /* was comments only and local overrides were silently ignored.            */ -}}
{{- /*                                                                          */ -}}
{{- /* Example .chezmoi.local.toml:                                            */ -}}
{{- /*   [data]                                                                */ -}}
{{- /*       is_work = true                                                    */ -}}
{{- /*   [data.package_features]                                               */ -}}
{{- /*       vscode = false                                                    */ -}}
{{- /* ========================================================================== */ -}}
{{- /* Load the local override file once. Only [data.package_features] is
      merged here, because package_features are NOT emitted elsewhere in this
      config (they come from .chezmoidata/packages.yaml at template time), so
      re-declaring the table cannot cause a TOML duplicate-key error. The
      other [data] keys above already have their final values; to override
      those per-machine, extend this block deliberately (each key must be
      emitted in exactly ONE place to avoid duplicate-key parse errors). */ -}}
{{- $localToml := joinPath .chezmoi.sourceDir ".chezmoi.local.toml" -}}
{{- if stat $localToml }}
{{-   $local := include $localToml | fromToml -}}
{{-   $localData := index $local "data" | default dict -}}
{{-   $localPF := index $localData "package_features" | default dict -}}
{{-   if $localPF }}

# ---- per-machine package_features overrides (.chezmoi.local.toml) ----
[data.package_features]
{{-     range $k, $v := $localPF }}
    {{ $k }} = {{ $v }}
{{-     end }}
{{-   end }}
{{- end }}

# Chezmoi repository .gitignore

# Bootstrap binary directory at repo root only (chezmoi.exe lands here during install).
# Anchored with leading slash so we don't accidentally ignore subtree bin/ dirs
# like dot_local/bin/ which ARE managed content.
/bin/

# Editor temp files
*.swp
*.swo
*~
.DS_Store

# Logs
*.log

# Temporary files
*.tmp
tmp/

# Local machine-specific configuration (never commit)
.chezmoi.local.toml
.chezmoi.local.yaml
.chezmoi.local.json

# Backup files
*.bak
*.backup

# Agent/session runtime state
.omo/

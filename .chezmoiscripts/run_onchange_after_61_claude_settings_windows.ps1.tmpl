#!/usr/bin/env pwsh
<#
.SYNOPSIS
    Reconcile chezmoi-managed top-level keys in ~/.claude/settings.json
    without overwriting Claude Code's runtime additions (theme, etc.).

.DESCRIPTION
    Claude Code mutates ~/.claude/settings.json on its own — picking a
    theme via the UI rewrites `theme`, toggling plugins flips
    `enabledPlugins`, and the file's key order shuffles between launches.
    Tracking the whole file as a chezmoi template causes perpetual drift.

    Instead, this script owns a fixed set of top-level keys
    (permissions, model, enabledPlugins, extraKnownMarketplaces, env,
    fastMode, defaultShell). Every other key in the live file — most
    notably `theme` and any future runtime additions — is preserved
    verbatim.

    Because this is a `run_onchange_*` script with the rendered managed
    JSON embedded inline, chezmoi re-executes it only when the managed
    content actually changes. Idempotent applies do no work.

.NOTES
    Mirrors the pattern in run_onchange_after_60_claude_mcp_windows.ps1.tmpl
    Source of truth: this script's $managedJson block (Windows-specific
    fields gated behind a chezmoi template conditional).
#>

$ErrorActionPreference = 'Stop'
$settingsPath = Join-Path $HOME '.claude\settings.json'

# --- Managed top-level keys (rendered from the chezmoi template) ----------
# Anything NOT in this block is left alone in the live file. To stop
# managing a key, remove it here. To start managing a new key, add it.
$managedJson = @'
{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "LS",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(npm run *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "WebSearch",
      "Bash(chezmoi apply *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "neon@claude-plugins-official": true,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
{{- if eq .chezmoi.os "windows" }}
  "env": {
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "defaultShell": "powershell",
{{- end }}
  "fastMode": true
}
'@

try {
    $managed = $managedJson | ConvertFrom-Json -AsHashtable -Depth 100
} catch {
    Write-Error "claude_settings: failed to parse rendered managed JSON: $_"
    exit 1
}

# --- Load existing ~/.claude/settings.json (or start with {}) -------------
if (Test-Path -LiteralPath $settingsPath) {
    try {
        $existing = Get-Content -LiteralPath $settingsPath -Raw -Encoding UTF8 |
            ConvertFrom-Json -AsHashtable -Depth 100
    } catch {
        Write-Warning "claude_settings: ~/.claude/settings.json is not valid JSON; backing up and starting fresh."
        Copy-Item -LiteralPath $settingsPath -Destination "$settingsPath.bak-$(Get-Date -Format 'yyyyMMddHHmmss')" -Force
        $existing = [ordered]@{}
    }
    if ($null -eq $existing) { $existing = [ordered]@{} }
} else {
    $parent = Split-Path -Parent $settingsPath
    if (-not (Test-Path -LiteralPath $parent)) {
        New-Item -ItemType Directory -Path $parent -Force | Out-Null
    }
    $existing = [ordered]@{}
}

# --- No-op short-circuit: only rewrite if any managed key differs ---------
$needsWrite = $false
foreach ($key in $managed.Keys) {
    if (-not $existing.ContainsKey($key)) {
        $needsWrite = $true
        break
    }
    $currentJson = $existing[$key] | ConvertTo-Json -Depth 100 -Compress
    $managedKeyJson = $managed[$key] | ConvertTo-Json -Depth 100 -Compress
    if ($currentJson -ne $managedKeyJson) {
        $needsWrite = $true
        break
    }
}

if (-not $needsWrite) {
    Write-Host "claude_settings: ~/.claude/settings.json managed keys already in sync."
    exit 0
}

# --- Replace each managed key, preserve everything else (theme, etc.) -----
foreach ($key in $managed.Keys) {
    $existing[$key] = $managed[$key]
}

# --- Atomic write ---------------------------------------------------------
$tmp = "$settingsPath.tmp-$(Get-Random)"
try {
    $existing | ConvertTo-Json -Depth 100 |
        Set-Content -LiteralPath $tmp -Encoding UTF8 -NoNewline
    Move-Item -LiteralPath $tmp -Destination $settingsPath -Force
    $keys = ($managed.Keys | Sort-Object) -join ', '
    Write-Host "claude_settings: synced ~/.claude/settings.json keys -> [$keys]"
} catch {
    if (Test-Path -LiteralPath $tmp) { Remove-Item -LiteralPath $tmp -Force -ErrorAction SilentlyContinue }
    throw
}

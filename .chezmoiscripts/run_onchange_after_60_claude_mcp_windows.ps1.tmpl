#!/usr/bin/env pwsh
<#
.SYNOPSIS
    Reconcile ~/.claude.json's `mcpServers` block with the chezmoi-managed
    inventory in .chezmoidata/mcp.yaml.

.DESCRIPTION
    Claude Code rewrites ~/.claude.json on every launch (OAuth tokens, project
    caches, machine paths), so the FILE is excluded from chezmoi. But the
    `mcpServers` key inside it is stable, declarative, and the same on every
    machine — exactly what dotfiles should own.

    This script merges only that one key. All other keys in ~/.claude.json
    are preserved verbatim. Add/remove/change a server in
    .chezmoidata/mcp.yaml and the next `chezmoi apply` reconciles the file.

    Because this is a `run_onchange_*` script with the rendered server JSON
    embedded inline, chezmoi re-executes it only when the rendered content
    actually changes — no work on idempotent applies.

.NOTES
    Source of truth: .chezmoidata/mcp.yaml
    See:             SECRETS.md (Pattern B / `op run` wrapper)
                     ~/.config/op/claude.env (env vars referenced as ${VAR})
#>

# rendered-mcp-hash: {{ .mcp.servers | toJson | sha256sum }}

$ErrorActionPreference = 'Stop'
$claudeJson = Join-Path $HOME '.claude.json'

# --- Managed mcpServers block (rendered from .chezmoidata/mcp.yaml) -------
$managedJson = @'
{{ .mcp.servers | toJson }}
'@

try {
    $managed = $managedJson | ConvertFrom-Json -AsHashtable -Depth 100
} catch {
    Write-Error "Failed to parse rendered mcp.servers JSON: $_"
    exit 1
}

# --- Load existing ~/.claude.json (or start with {}) ----------------------
if (Test-Path -LiteralPath $claudeJson) {
    try {
        $existing = Get-Content -LiteralPath $claudeJson -Raw -Encoding UTF8 |
            ConvertFrom-Json -AsHashtable -Depth 100
    } catch {
        Write-Warning "~/.claude.json is not valid JSON; backing up and starting fresh."
        Copy-Item -LiteralPath $claudeJson -Destination "$claudeJson.bak-$(Get-Date -Format 'yyyyMMddHHmmss')" -Force
        $existing = [ordered]@{}
    }
    if ($null -eq $existing) { $existing = [ordered]@{} }
} else {
    $existing = [ordered]@{}
}

# --- No-op short-circuit --------------------------------------------------
if ($existing.ContainsKey('mcpServers')) {
    $currentJson = ($existing.mcpServers | ConvertTo-Json -Depth 100 -Compress)
    $managedCmp  = ($managed             | ConvertTo-Json -Depth 100 -Compress)
    if ($currentJson -eq $managedCmp) {
        Write-Host "claude_mcp: ~/.claude.json mcpServers already matches managed inventory."
        exit 0
    }
}

# --- Replace mcpServers, preserve everything else -------------------------
$existing['mcpServers'] = $managed

# --- Atomic write ---------------------------------------------------------
$tmp = "$claudeJson.tmp-$(Get-Random)"
try {
    $existing | ConvertTo-Json -Depth 100 |
        Set-Content -LiteralPath $tmp -Encoding UTF8 -NoNewline
    Move-Item -LiteralPath $tmp -Destination $claudeJson -Force
    $names = ($managed.Keys | Sort-Object) -join ', '
    Write-Host "claude_mcp: synced ~/.claude.json mcpServers -> [$names]"
} catch {
    if (Test-Path -LiteralPath $tmp) { Remove-Item -LiteralPath $tmp -Force -ErrorAction SilentlyContinue }
    throw
}

{{- if eq .chezmoi.os "windows" -}}
#Requires -Version 7.0
<#
.SYNOPSIS
    Validate secrets-management setup on Windows before any other chezmoi
    apply script touches the system.

.DESCRIPTION
    Windows counterpart to .chezmoiscripts/run_onchange_before_01_validate-secrets.sh.tmpl
    on Unix. Runs identical probes:
      - 1Password CLI (`op`) present on PATH and authenticated.
      - Required items exist in 1Password (verified via `op item get … --fields …`).
      - Fail-loud on missing items so downstream scripts don't render
        templates with silently-empty .secrets.* values.

    Hash: {{ include ".chezmoidata.yaml" | sha256sum }}

.NOTES
    Behavior parity with the .sh.tmpl, expressed in pwsh idioms:
      - log_info/log_success/log_warning/log_error → Write-Status (Info/…/Error)
      - validate_1password_secrets → Test-OnePasswordItems
      - get_secrets_manager → Get-SecretsManager
#>

$ErrorActionPreference = 'Stop'

# ─── Logging helpers (matches bootstrap.ps1:79-108 + Unix .sh.tmpl semantics) ─
function Write-Status {
    param(
        [Parameter(Mandatory)][string]$Message,
        [ValidateSet('Info', 'Success', 'Warning', 'Error')]
        [string]$Type = 'Info'
    )
    $colors  = @{ Info = 'Cyan';  Success = 'Green';  Warning = 'Yellow'; Error = 'Red' }
    $symbols = @{ Info = 'i';    Success = 'OK';     Warning = '!';      Error = 'X'   }
    Write-Host "[$($symbols[$Type])] " -ForegroundColor $colors[$Type] -NoNewline
    Write-Host $Message
}

# ─── 1Password helpers ──────────────────────────────────────────────────────
function Test-OnePasswordCli {
    $null -ne (Get-Command op -ErrorAction SilentlyContinue)
}

function Test-OnePasswordAuth {
    if (-not (Test-OnePasswordCli)) { return $false }
    try {
        & op whoami 2>$null | Out-Null
        return $LASTEXITCODE -eq 0
    } catch {
        return $false
    }
}

function Test-OnePasswordItems {
    <#
    .SYNOPSIS
        Verify each required item exists in 1Password by probing `op item get`.
        Mirrors validate_1password_secrets in .chezmoitemplates/1password.
    #>
    param([Parameter(Mandatory)][string[]]$Items)

    if (-not (Test-OnePasswordAuth)) {
        Write-Status "1Password not authenticated — cannot validate secrets" -Type Error
        return $false
    }

    $missing = @()
    Write-Status "Validating 1Password secrets..." -Type Info
    foreach ($item in $Items) {
        & op item get $item --format=json 2>$null | Out-Null
        if ($LASTEXITCODE -eq 0) {
            Write-Status "  ${item}: found" -Type Success
        } else {
            Write-Status "  ${item}: missing" -Type Warning
            $missing += $item
        }
    }

    if ($missing.Count -gt 0) {
        Write-Status ("Missing {0} required secret(s)" -f $missing.Count) -Type Error
        Write-Status "Please create these items in 1Password:" -Type Error
        foreach ($m in $missing) { Write-Status "  - $m" -Type Error }
        return $false
    }

    Write-Status "All required secrets found" -Type Success
    return $true
}

function Get-SecretsManager {
    if (Test-OnePasswordCli -and (Test-OnePasswordAuth)) { return '1password' }
    return 'none'
}

# ─── Main ──────────────────────────────────────────────────────────────────
Write-Status "===========================================" -Type Info
Write-Status "   Validating Secrets Management" -Type Info
Write-Status "===========================================" -Type Info
Write-Host ""

$manager = Get-SecretsManager

switch ($manager) {
    '1password' {
        Write-Status "Validating 1Password configuration..." -Type Info

        $requiredSecrets = @(
            {{- if .setup_git_ssh }}
            'SSH Private Key',
            {{- end }}
            {{- if .setup_1password }}
            'GitHub Token'
            {{- end }}
        )

        # Trim trailing comma artifacts if the previous template branch
        # rendered no comma (PowerShell tolerates trailing commas in array
        # literals, but the parser doesn't tolerate a literal `null` entry).
        $requiredSecrets = @($requiredSecrets | Where-Object { $_ })

        if ($requiredSecrets.Count -gt 0) {
            if (Test-OnePasswordItems -Items $requiredSecrets) {
                Write-Status "1Password secrets validated successfully" -Type Success
            } else {
                Write-Status "Some 1Password secrets are missing" -Type Warning
                Write-Status "Continuing anyway — secrets will be skipped where needed" -Type Warning
            }
        } else {
            Write-Status "No secrets validation required for this configuration" -Type Info
        }
    }

    'none' {
        Write-Status "No secrets manager configured" -Type Warning
        Write-Status "Some features requiring secrets will be disabled:" -Type Info
        {{- if .setup_git_ssh }}
        Write-Status "  - SSH key management" -Type Warning
        {{- end }}
        {{- if .setup_1password }}
        Write-Status "  - GitHub token integration" -Type Warning
        {{- end }}
        Write-Host ""
        Write-Status "To enable secrets management:" -Type Info
        Write-Status "  scoop install 1password-cli" -Type Info
        Write-Status "  op signin" -Type Info
        Write-Host ""

        # Interactive confirmation (skip in CI / SSH / non-TTY contexts).
        $isInteractive = [Environment]::UserInteractive -and `
            -not $env:CI -and `
            -not $env:SSH_CONNECTION -and `
            -not $env:SSH_CLIENT -and `
            -not $env:SSH_TTY
        if ($isInteractive) {
            $reply = Read-Host "Continue without secrets management? [y/N]"
            if ($reply -notmatch '^[Yy]$') {
                Write-Status "Bootstrap cancelled" -Type Info
                exit 0
            }
        }
        Write-Status "Continuing without secrets management..." -Type Info
    }
}

Write-Host ""
Write-Status "Secrets validation completed" -Type Success
Write-Host ""
{{- end -}}

{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# Re-inject pam's MCP pointer into ~/.config/opencode/opencode.json on every
# `chezmoi apply`.
#
# opencode.json is fully chezmoi-managed (template-rendered), and its `mcp`
# block is intentionally empty there — MCP servers are owned by pam
# (~/.config/pam/manifest.toml). Whenever chezmoi rewrites the file (even
# when the template content hasn't changed), the live `mcp.pam` pointer gets
# wiped, so this script runs `pam sync --client opencode` on every apply to
# re-add the single `mcp.pam` pointer entry (with its per-client auth token).
#
# `pam sync` is atomic, format-aware, idempotent, and leaves every other key
# in the target file untouched, so running it on every apply is safe and
# cheap. If the daemon isn't running we skip silently.
#
# File is `run_after_` (not `run_onchange_after_`) so it fires on every apply
# — an onchange variant only re-runs when the template content hashes
# differently, which lets the pointer drift away on plain re-applies.

set -euo pipefail

if ! command -v pam >/dev/null 2>&1; then
    echo "[opencode_pam_sync] pam CLI not on PATH; skipping" >&2
    exit 0
fi

if ! pam status >/dev/null 2>&1; then
    echo "[opencode_pam_sync] pam daemon not running; skipping ('pam start' to enable)" >&2
    exit 0
fi

echo "[opencode_pam_sync] running 'pam sync --client opencode'..."
pam sync --client opencode
{{- end }}

{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# Point core.hooksPath at the tracked .githooks/ in the chezmoi source repo so
# the secret-scan pre-commit hook runs when authoring dotfiles commits.
#
# The hook is FAIL-CLOSED, so activation is gated on gitleaks actually being
# present: on a host without the scanner (brew-less/minimal/remote) the hook is
# NOT enabled — commits are never locked out. If gitleaks later disappears, a
# previously-set hooksPath is unset so it can't silently block commits.
# Idempotent; reruns when the hook or its config changes.
# Hash: {{ printf "%s%s" (include ".githooks/pre-commit") (include ".gitleaks.toml") | sha256sum }}
set -euo pipefail
src="{{ .chezmoi.sourceDir }}"
git -C "$src" rev-parse --git-dir >/dev/null 2>&1 || exit 0

for d in "$HOME/scoop/shims" "$HOME/.local/bin" "$HOME/.local/share/mise/shims" \
         /opt/homebrew/bin /usr/local/bin /usr/bin; do
  [ -d "$d" ] && case ":$PATH:" in *":$d:"*) ;; *) PATH="$d:$PATH" ;; esac
done

if command -v gitleaks >/dev/null 2>&1; then
  git -C "$src" config core.hooksPath .githooks
  printf '[git-hooks] secret-scan pre-commit enabled (core.hooksPath -> .githooks)\n'
else
  if [ "$(git -C "$src" config --get core.hooksPath 2>/dev/null || true)" = ".githooks" ]; then
    git -C "$src" config --unset core.hooksPath
  fi
  printf '[git-hooks] gitleaks not installed — secret-scan hook not enabled on this host\n'
fi
{{- end }}

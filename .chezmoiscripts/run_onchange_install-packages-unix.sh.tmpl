{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# Declarative package installation for Unix (Linux/macOS)
# This script only runs when package lists change
# Hash: {{ printf "%s%s%s%s%s%s" (include ".chezmoidata/packages.yaml") (include ".chezmoidata/theme.yaml") (include ".chezmoidata/ssh.yaml") (include ".chezmoidata/dns.yaml") (include ".chezmoidata/fonts.yaml") (include ".chezmoidata/mcp.yaml") | sha256sum }}

# Fail fast: surface install failures instead of swallowing them silently.
# Individual commands that are intentionally allowed to fail (e.g. "package
# may already be installed", optional brew/mise installs) use explicit `|| true`
# or `|| echo 'Warning: ...'` at the call site below.
set -euo pipefail

echo "Checking package installation..."
{{- if not .install_packages }}
echo "install_packages=false; skipping managed package and mise tool installation."
exit 0
{{- end }}

# Ensure Arch perl scripts are in PATH (for pod2man used by Homebrew builds)
if [ -d /usr/bin/core_perl ]; then
    export PATH="/usr/bin/core_perl:/usr/bin/vendor_perl:/usr/bin/site_perl:$PATH"
fi

# Detect system package manager
detect_pkg_manager() {
    if command -v apt-get >/dev/null 2>&1; then
        echo "apt"
    elif command -v dnf >/dev/null 2>&1; then
        echo "dnf"
    elif command -v pacman >/dev/null 2>&1; then
        echo "pacman"
    else
        echo ""
    fi
}

# Ensure mise is installed
if ! command -v mise >/dev/null 2>&1; then
    echo "mise not found. Installing..."
    curl https://mise.run | sh
    export PATH="$HOME/.local/bin:$PATH"
fi

# Set up Homebrew on PATH for this script. Three possible prefixes:
#   * /opt/homebrew                  (macOS, conventional)
#   * /home/linuxbrew/.linuxbrew     (Linux non-remote, conventional)
#   * $XDG_DATA_HOME/homebrew        (Linux remote, user-prefix shim)
# See run_onchange_before_install_base_packages_unix.sh.tmpl for bootstrap.
if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)" 2>/dev/null || true
elif [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)" 2>/dev/null || true
elif [ -x "${XDG_DATA_HOME:-$HOME/.local/share}/homebrew/bin/brew" ]; then
    eval "$("${XDG_DATA_HOME:-$HOME/.local/share}/homebrew/bin/brew" shellenv)" 2>/dev/null || true
fi

# Collect system packages per manager (mise is declarative via config files;
# paru is the AUR helper for Arch, only consumed when pacman is detected)
{{- if eq .chezmoi.os "linux" }}
apt_packages=""
dnf_packages=""
pacman_packages=""
paru_packages=""

# Add always_install system packages
{{- range .always_install.pacman }}
pacman_packages="$pacman_packages {{ . }}"
{{- end }}
{{- range .always_install.apt }}
apt_packages="$apt_packages {{ . }}"
{{- end }}
{{- range .always_install.dnf }}
dnf_packages="$dnf_packages {{ . }}"
{{- end }}
{{- if hasKey .always_install "paru" }}
{{- range .always_install.paru }}
paru_packages="$paru_packages {{ . }}"
{{- end }}
{{- end }}

# Add feature-gated system packages
{{- range $feature, $enabled := .package_features }}
{{- if $enabled }}
{{- if hasKey $.package_mapping $feature }}
{{- $mapping := index $.package_mapping $feature }}
{{- if hasKey $mapping "linux" }}
{{- $platform := index $mapping "linux" }}
{{- if and (hasKey $platform "apt") $platform.apt }}
{{- range $platform.apt }}
apt_packages="$apt_packages {{ . }}"
{{- end }}
{{- end }}
{{- if and (hasKey $platform "dnf") $platform.dnf }}
{{- range $platform.dnf }}
dnf_packages="$dnf_packages {{ . }}"
{{- end }}
{{- end }}
{{- if and (hasKey $platform "pacman") $platform.pacman }}
{{- range $platform.pacman }}
pacman_packages="$pacman_packages {{ . }}"
{{- end }}
{{- end }}
{{- if and (hasKey $platform "paru") $platform.paru }}
{{- range $platform.paru }}
paru_packages="$paru_packages {{ . }}"
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

# ============================================================================
# Package Installation Order (per user rules):
#   1. mise - primary package manager for CLI tools and runtimes
#   2. brew bundle - fallback for tools not available in mise
#   3. system pkg manager - ONLY for bootstrap/build dependencies
# ============================================================================

# ----------------------------------------------------------------------------
# GitHub API authentication for mise
# ----------------------------------------------------------------------------
# mise backends (ubi, aqua, cargo-binstall, github-releases) query the GitHub
# API to resolve tool versions and download assets. Anonymous requests are
# throttled to 60/hour per IP which is trivially exhausted on a fresh machine
# install. Authenticated requests get 5,000/hour.
#
# Resolution order:
#   1. Respect an existing GITHUB_TOKEN / MISE_GITHUB_TOKEN in the environment
#   2. Pull a PAT from 1Password ("GitHub Token" item) when op is authenticated
#   3. Fall back to anonymous (script will warn and continue)
setup_github_token() {
    # Already provided by the caller / shell env
    if [ -n "${GITHUB_TOKEN:-}" ]; then
        export MISE_GITHUB_TOKEN="${MISE_GITHUB_TOKEN:-$GITHUB_TOKEN}"
        export GH_TOKEN="${GH_TOKEN:-$GITHUB_TOKEN}"
        echo "  Using GITHUB_TOKEN from environment"
        return 0
    fi
    if [ -n "${MISE_GITHUB_TOKEN:-}" ]; then
        export GITHUB_TOKEN="${MISE_GITHUB_TOKEN}"
        export GH_TOKEN="${GH_TOKEN:-$MISE_GITHUB_TOKEN}"
        echo "  Using MISE_GITHUB_TOKEN from environment"
        return 0
    fi

    # Try 1Password CLI (if installed and signed in)
    if command -v op >/dev/null 2>&1 && op whoami >/dev/null 2>&1; then
        local token=""
        for field in token credential password; do
            token="$(op item get "GitHub Token" --fields "$field" --reveal 2>/dev/null || true)"
            # Strip accidental quoting that op sometimes emits around secret refs
            token="${token%\"}"
            token="${token#\"}"
            if [ -n "$token" ]; then
                export GITHUB_TOKEN="$token"
                export MISE_GITHUB_TOKEN="$token"
                export GH_TOKEN="$token"
                echo "  Loaded GITHUB_TOKEN from 1Password (field: $field)"
                return 0
            fi
        done
    fi

    echo "  Warning: no GITHUB_TOKEN available - mise installs may hit GitHub's 60 req/hr anonymous rate limit"
    echo "           Set GITHUB_TOKEN or add a 'GitHub Token' item to 1Password to avoid this."
    return 1
}

echo ""
echo "Configuring GitHub API authentication for mise..."
setup_github_token || true

# 1. Install mise tools declared in config (PRIMARY)
# Baseline tools are declared in ~/.config/mise/conf.d/00-managed.toml (chezmoi
# template); `mise install` also picks up user pins in ~/.config/mise/config.toml.
echo ""
echo "Installing mise tools/runtimes from config..."
mise install --yes 2>&1 || echo "Warning: Some mise tools failed to install"

# Ensure shims are in PATH for subsequent operations
export PATH="$HOME/.local/share/mise/shims:$PATH"

{{- if or (eq .chezmoi.os "darwin") (and (eq .chezmoi.os "linux") (not .is_remote)) }}
# 2. Install brew packages via Brewfile.
# Runs on macOS and on non-remote Linux. On remote Linux the user-prefix
# Homebrew shim is bootstrapped (see run_onchange_before_install_base_packages_unix.sh.tmpl)
# but `brew bundle` is skipped there — source builds against a non-canonical
# prefix take hours per formula since upstream bottles aren't available.
BREWFILE="$HOME/.config/homebrew/Brewfile"
# Regenerate Brewfile from chezmoi template before running brew bundle.
# Scripts in .chezmoiscripts/ sort before dot_config/ alphabetically,
# so they run before chezmoi writes managed files to disk.
if command -v chezmoi >/dev/null 2>&1 && chezmoi cat "$BREWFILE" >/dev/null 2>&1; then
    chezmoi cat "$BREWFILE" > "${BREWFILE}.new" && mv "${BREWFILE}.new" "$BREWFILE" || true
fi
if [ -f "$BREWFILE" ] && command -v brew >/dev/null 2>&1; then
    echo ""
    echo "Installing brew packages from Brewfile..."
    brew bundle --file="$BREWFILE"{{- if .is_remote }} --cleanup{{- end }} || echo "Warning: Some brew packages failed to install"

    # Dedupe: bootstrap installs mise to ~/.local/bin/mise (via mise.run)
    # before Homebrew is available. Once brew owns mise, drop the
    # standalone copy so there is a single canonical install on PATH.
    if brew list --formula 2>/dev/null | grep -qx mise; then
        brew_mise_prefix="$(brew --prefix mise 2>/dev/null)"
        if [ -n "$brew_mise_prefix" ] \
           && [ -x "$brew_mise_prefix/bin/mise" ] \
           && [ -f "$HOME/.local/bin/mise" ] \
           && [ "$(readlink -f "$HOME/.local/bin/mise" 2>/dev/null || echo "$HOME/.local/bin/mise")" != "$brew_mise_prefix/bin/mise" ]; then
            echo "Removing standalone mise ($HOME/.local/bin/mise); brew install at $brew_mise_prefix/bin/mise is canonical"
            rm -f "$HOME/.local/bin/mise"
        fi
    fi
fi
{{- end }}

{{- if not .is_remote }}

# 3. Install system packages (ONLY for bootstrap/build dependencies)
{{- if eq .chezmoi.os "linux" }}
pkg_manager=$(detect_pkg_manager)
if [ -n "$pkg_manager" ]; then
    case "$pkg_manager" in
        apt)
            if [ -n "$apt_packages" ]; then
                echo ""
                echo "Installing build dependencies via apt..."
                sudo apt-get update -qq
                for pkg in $apt_packages; do
                    if ! dpkg -l "$pkg" 2>/dev/null | grep -q "^ii"; then
                        echo "  Installing: $pkg"
                        sudo apt-get install -y -qq "$pkg"
                    else
                        echo "  Already installed: $pkg"
                    fi
                done
            fi
            ;;
        dnf)
            if [ -n "$dnf_packages" ]; then
                echo ""
                echo "Installing build dependencies via dnf..."
                for pkg in $dnf_packages; do
                    if ! rpm -q "$pkg" >/dev/null 2>&1; then
                        echo "  Installing: $pkg"
                        sudo dnf install -y -q "$pkg"
                    else
                        echo "  Already installed: $pkg"
                    fi
                done
            fi
            ;;
        pacman)
            if [ -n "$pacman_packages" ]; then
                echo ""
                echo "Installing build dependencies via pacman..."
                for pkg in $pacman_packages; do
                    if ! pacman -Q "$pkg" >/dev/null 2>&1; then
                        echo "  Installing: $pkg"
                        sudo pacman -S --noconfirm --needed "$pkg"
                    else
                        echo "  Already installed: $pkg"
                    fi
                done
            fi
            # AUR packages via paru. paru is bootstrapped by the
            # install_aur_helper function in
            # run_onchange_before_install_base_packages_unix.sh.tmpl, so it
            # MUST already be on PATH by the time we get here.
            if [ -n "$paru_packages" ] && command -v paru >/dev/null 2>&1; then
                echo ""
                echo "Installing AUR packages via paru..."
                for pkg in $paru_packages; do
                    if ! pacman -Q "$pkg" >/dev/null 2>&1; then
                        echo "  Installing (AUR): $pkg"
                        paru -S --noconfirm --needed --skipreview --batchinstall "$pkg" || echo "  Warning: failed to install $pkg"
                    else
                        echo "  Already installed: $pkg"
                    fi
                done
            elif [ -n "$paru_packages" ]; then
                echo ""
                echo "Warning: paru not on PATH but AUR packages are queued: $paru_packages"
            fi
            ;;
    esac
fi
{{- end }}
{{- else }}
echo ""
echo "Remote machine detected - skipping system package installs (require sudo)"
{{- end }}

# Helper to check if a command exists AND works (not a broken Windows interop path)
command_works() {
    command -v "$1" >/dev/null 2>&1 && "$1" --version >/dev/null 2>&1
}

{{- if and .package_features.nvim .package_features.python }}
# pip pynvim package (for Python provider)
echo ""
echo "Installing Neovim Python provider..."
if command_works pip || command_works pip3; then
    pip_cmd="pip"
    command_works pip || pip_cmd="pip3"
    if ! $pip_cmd show pynvim >/dev/null 2>&1; then
        echo "  Installing: pynvim (Python provider)"
        $pip_cmd install --user pynvim || echo "  Warning: Failed to install pynvim"
    else
        echo "  Already installed: pynvim"
    fi
else
    echo "  pip not available, skipping Python provider"
fi
{{- end }}

{{- if and .package_features.nvim .package_features.node }}
# npm neovim package (for Node.js provider)
echo ""
echo "Installing Neovim Node.js provider..."
if command_works npm; then
    if ! npm list -g neovim >/dev/null 2>&1; then
        echo "  Installing: npm neovim (Node.js provider)"
        npm install -g neovim || echo "  Warning: Failed to install neovim npm package"
    else
        echo "  Already installed: npm neovim"
    fi
else
    echo "  npm not available, skipping Node.js provider"
fi
{{- end }}

{{- if and .package_features.nvim .package_features.ruby }}
# gem neovim package (for Ruby provider)
echo ""
echo "Installing Neovim Ruby provider..."
if command_works ruby && command_works gem; then
    if ! gem list neovim 2>/dev/null | grep -q "^neovim "; then
        echo "  Installing: neovim gem (Ruby provider)"
        gem install neovim || echo "  Warning: Failed to install neovim gem"
    else
        echo "  Already installed: neovim gem"
    fi
else
    echo "  ruby/gem not available, skipping Ruby provider"
fi
{{- end }}

{{- if and .package_features.nvim .package_features.perl }}
# cpan Neovim::Ext module (for Perl provider).
# Install into ~/.local via local::lib so modules land in XDG-aligned paths:
#   ~/.local/lib/perl5    -- module .pm files (PERL5LIB)
#   ~/.local/bin          -- module-installed scripts (already on PATH)
#   ~/.local/share/man    -- module man pages (XDG_DATA_HOME-aligned)
# Avoids needing root/sudo (no /usr/share/man permission errors) and keeps
# the home directory clean (no ~/perl5 sprawl).
echo ""
echo "Installing Neovim Perl provider..."
PERL5LIB="$HOME/.local/lib/perl5${PERL5LIB:+:$PERL5LIB}"
export PERL5LIB
# Only use Linux perl, not Windows Strawberry Perl via WSL interop
if [ -x /usr/bin/perl ] || command_works perl; then
    if ! perl -MNeovim::Ext -e 1 >/dev/null 2>&1; then
        echo "  Installing: Neovim::Ext (Perl provider) into ~/.local"
        if command_works cpanm; then
            cpanm -n --local-lib="$HOME/.local" Neovim::Ext || echo "  Warning: Failed to install Neovim::Ext"
        elif command -v cpan >/dev/null 2>&1; then
            PERL_MM_OPT="INSTALL_BASE=$HOME/.local" \
            PERL_MB_OPT="--install_base $HOME/.local" \
                cpan -T Neovim::Ext || echo "  Warning: Failed to install Neovim::Ext"
        else
            echo "  Neither cpanm nor cpan available, skipping Perl provider"
        fi
    else
        echo "  Already installed: Neovim::Ext"
    fi
else
    echo "  perl not available, skipping Perl provider"
fi
{{- end }}

echo ""
echo "✓ Package installation complete"
{{- end -}}

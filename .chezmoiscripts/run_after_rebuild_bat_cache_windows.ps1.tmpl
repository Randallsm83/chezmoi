{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
# Ensure bat theme cache is current after every chezmoi apply
# Handles cases where bat is updated/reinstalled and its cache is wiped
$env:BAT_CONFIG_DIR = if ($env:XDG_CONFIG_HOME) {
    Join-Path $env:XDG_CONFIG_HOME 'bat'
} else {
    Join-Path $HOME '.config\bat'
}

if (Get-Command bat -ErrorAction SilentlyContinue) {
    try {
        bat cache --build 2>&1 | Out-Null
    } catch {
        Write-Warning "bat cache rebuild failed: $($_.Exception.Message)"
    }
}
{{- end }}

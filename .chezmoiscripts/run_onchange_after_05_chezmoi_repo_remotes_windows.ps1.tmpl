{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
#
# Configure the chezmoi-source git remotes with the documented mirror layout:
#
#   origin   fetch/push = git@gitlab.com:Randallsm83/chezmoi.git  (canonical)
#   github   fetch/push = git@github.com:Randallsm83/chezmoi.git  (mirror)
#
# Multi-host pushes go through the `git pushall` alias (see
# dot_config/git/config.tmpl), which pushes origin then github serially with
# bounded retry. The previous dual-pushurl-on-origin layout fanned out two SSH
# signing requests over the Windows 1Password named-pipe agent in the same
# `git push` invocation; the second sign occasionally returned
# "communication with agent failed". Splitting the pushes makes each one
# independent and individually retryable.
#
# Idempotent — exits silently when remotes already match. Strips any stale
# `remote.origin.pushurl` / `remote.github.pushurl` left over from the old dual-pushurl layout.

$ErrorActionPreference = 'Stop'

$RepoDir       = {{ .chezmoi.sourceDir | quote }}
$WantOriginUrl = 'git@gitlab.com:Randallsm83/chezmoi.git'
$WantGithubUrl = 'git@github.com:Randallsm83/chezmoi.git'

if (-not (Test-Path (Join-Path $RepoDir '.git'))) { exit 0 }

Push-Location $RepoDir
try {
    $haveOrigin     = (& git config --get remote.origin.url 2>$null)
    $haveOriginPush = (& git config --get-all remote.origin.pushurl 2>$null)
    $haveGithub     = (& git config --get remote.github.url 2>$null)
    $haveGithubPush = (& git config --get-all remote.github.pushurl 2>$null)

    if ($haveOrigin -eq $WantOriginUrl -and `
        [string]::IsNullOrEmpty($haveOriginPush) -and `
        $haveGithub -eq $WantGithubUrl -and `
        [string]::IsNullOrEmpty($haveGithubPush)) {
        exit 0
    }

    Write-Host "[chezmoi-repo-remotes] Configuring origin (GitLab) + github (GitHub) remotes in $RepoDir"

    $existingOrigin = & git remote get-url origin 2>$null
    if (-not [string]::IsNullOrEmpty($existingOrigin)) {
        & git remote set-url origin $WantOriginUrl | Out-Null
    } else {
        & git remote add origin $WantOriginUrl | Out-Null
    }
    & git config --unset-all remote.origin.pushurl 2>$null

    $existingGithub = & git remote get-url github 2>$null
    if (-not [string]::IsNullOrEmpty($existingGithub)) {
        & git remote set-url github $WantGithubUrl | Out-Null
    } else {
        & git remote add github $WantGithubUrl | Out-Null
    }
    & git config --unset-all remote.github.pushurl 2>$null

    Write-Host "[chezmoi-repo-remotes] Done. Push both with: git pushall (see CONTRIBUTING.md)"
}
finally {
    Pop-Location
}
{{- end -}}

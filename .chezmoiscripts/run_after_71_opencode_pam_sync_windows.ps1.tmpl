{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
<#
.SYNOPSIS
    Re-inject pam's MCP pointer into ~/.config/opencode/opencode.json after
    every `chezmoi apply`.

.DESCRIPTION
    opencode.json is managed by a chezmoi modify-template at
    `dot_config/opencode/modify_opencode.json` that preserves the live
    `mcp` key verbatim from the existing file on every apply. The
    per-machine pam auth token therefore never enters chezmoi source.

    This script runs `pam sync --client opencode` after each apply so that:
    1. On a fresh install (live file just created with `mcp: {}`), pam
       injects the `mcp.pam` pointer with the per-client auth token.
    2. If pam's manifest.toml changes (e.g. token rotation, new MCP server
       added), the live `mcp.pam` block is updated to match.
    3. The modify-template then preserves whatever pam wrote on subsequent
       applies — no drift loop.

    `pam sync` is atomic, format-aware, idempotent, and leaves every other
    key in the target file untouched, so running it on every apply is safe
    and cheap. If the daemon isn't running we skip silently.

.NOTES
    File is `run_after_` (not `run_onchange_after_`) so it fires on every
    apply — the previous onchange variant only re-ran when the template
    content hashed differently, which let the pointer drift away on plain
    re-applies.
#>

$ErrorActionPreference = "Stop"

if (-not (Get-Command pam -ErrorAction SilentlyContinue)) {
    Write-Host "opencode_pam_sync: 'pam' not on PATH; skipping."
    exit 0
}

pam status *> $null
if ($LASTEXITCODE -ne 0) {
    Write-Host "opencode_pam_sync: pam daemon not running; skipping ('pam start' to enable)."
    exit 0
}

Write-Host "opencode_pam_sync: running 'pam sync --client opencode'..."
pam sync --client opencode
{{- end }}

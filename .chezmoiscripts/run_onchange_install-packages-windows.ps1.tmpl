{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
# Declarative package installation for Windows
# This script only runs when package lists change
# Hash: {{ printf "%s%s%s%s%s%s" (include ".chezmoidata/packages.yaml") (include ".chezmoidata/theme.yaml") (include ".chezmoidata/ssh.yaml") (include ".chezmoidata/dns.yaml") (include ".chezmoidata/fonts.yaml") (include ".chezmoidata/mcp.yaml") | sha256sum }}

Write-Host "Checking package installation..." -ForegroundColor Cyan

# Ensure scoop is installed
if (!(Get-Command scoop -ErrorAction SilentlyContinue)) {
    Write-Host "Scoop not found. Please run bootstrap.ps1 first." -ForegroundColor Yellow
    exit 0
}

# Helper: refresh $env:PATH with persisted Machine + User PATH plus a few
# common dynamic locations (mise shims, scoop shims). Used after each install
# stage so subsequent stages see freshly installed binaries within the same
# pwsh session (e.g. pip/npm/gem after mise installs python/node/ruby).
function Update-SessionPath {
    $machinePath = [System.Environment]::GetEnvironmentVariable('Path', 'Machine')
    $userPath    = [System.Environment]::GetEnvironmentVariable('Path', 'User')
    $extra = @(
        "$env:USERPROFILE\scoop\shims",
        "$env:LOCALAPPDATA\mise\shims",
        (Join-Path ($env:XDG_DATA_HOME ? $env:XDG_DATA_HOME : "$env:USERPROFILE\.local\share") 'mise\shims')
    ) | Where-Object { $_ -and (Test-Path $_) }
    $parts = @()
    if ($machinePath) { $parts += $machinePath.Split(';') }
    if ($userPath)    { $parts += $userPath.Split(';') }
    $parts += $extra
    $env:PATH = ($parts | Where-Object { $_ } | Select-Object -Unique) -join ';'
}

# Helper: import the abgox.PSCompletions module from its scoop install
# directory and run its init routine.
#
# The scoop package does NOT place the module on PSModulePath, so
# `Import-Module PSCompletions` by name won't find it. We resolve it
# explicitly.
#
# IMPORTANT: The module exports a function named `PSCompletions` AND sets
# up a global `$PSCompletions` state object. Internal commands like
# `PSCompletions add` require `$PSCompletions.init_data()` to have been
# called first (this normally happens in the user's pwsh profile). Without
# init, calls fail with errors like "property '__need_update_data' cannot
# be found". The `psc` alias is created during module load but its scope
# is unreliable across non-interactive contexts (chezmoi's script runner);
# callers should invoke `PSCompletions` directly.
function Import-PSCompletionsModule {
    $candidates = @(
        "$env:USERPROFILE\scoop\apps\abgox.PSCompletions\current\PSCompletions.psd1",
        "$env:USERPROFILE\scoop\modules\PSCompletions\PSCompletions.psd1"
    )
    $imported = $false
    foreach ($p in $candidates) {
        if (Test-Path $p) {
            Import-Module $p -Global -Force -ErrorAction SilentlyContinue
            if (Get-Command PSCompletions -ErrorAction SilentlyContinue) {
                $imported = $true
                break
            }
        }
    }
    if (-not $imported) {
        Import-Module PSCompletions -Global -Force -ErrorAction SilentlyContinue
        $imported = ($null -ne (Get-Command PSCompletions -ErrorAction SilentlyContinue))
    }
    if (-not $imported) { return $false }

    # Initialize the module's global state object. Without this, downstream
    # commands fail because $PSCompletions.data and friends are unpopulated.
    try {
        if ($global:PSCompletions -and $global:PSCompletions.init_data) {
            $global:PSCompletions.init_data() | Out-Null
        }
    } catch {
        Write-Host "  PSCompletions.init_data() failed: $($_.Exception.Message)" -ForegroundColor Yellow
        return $false
    }
    return $true
}

# ------------------------------------------------------------------------
# Always-install packages (installed FIRST so aria2 / 7zip / etc. are
# available before any feature-flag packages start downloading).
# Order is preserved from .chezmoidata.yaml -> always_install.scoop.
# ------------------------------------------------------------------------
$alwaysInstallScoop = @(
{{- range .always_install.scoop }}
    "{{ . }}",
{{- end }}
    $null
) | Where-Object { $_ }

# ------------------------------------------------------------------------
# Feature-flag packages (deduped, but installed AFTER always_install).
# ------------------------------------------------------------------------
$featureScoopPackages = @()
$wingetPackages = @()
$misePackages = @()
$pipPackages = @()
$pwshModules = @()
$pscCompletions = @()

{{- range $feature, $enabled := .package_features }}
{{- if $enabled }}
{{- $mapping := index $.package_mapping $feature }}
{{- if $mapping }}
{{- $win := index $mapping "windows" }}
{{- if $win }}
{{- range $win.scoop }}
$featureScoopPackages += "{{ . }}"
{{- end }}
{{- range $win.winget }}
$wingetPackages += "{{ . }}"
{{- end }}
{{- range $win.mise }}
$misePackages += "{{ . }}"
{{- end }}
{{- if index $win "pip" }}
{{- range $win.pip }}
$pipPackages += "{{ . }}"
{{- end }}
{{- end }}
{{- if index $win "pwsh_modules" }}
{{- range $win.pwsh_modules }}
$pwshModules += "{{ . }}"
{{- end }}
{{- end }}
{{- if index $win "psc_completions" }}
{{- range $win.psc_completions }}
$pscCompletions += "{{ . }}"
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

# Ensure required scoop buckets
$requiredBuckets = @(
{{- range $name, $url := .scoop_buckets }}
    @{ Name = '{{ $name }}'; Url = '{{ $url }}' }
{{- end }}
)
foreach ($bucket in $requiredBuckets) {
    $existing = scoop bucket list 2>$null | Where-Object { $_.Name -eq $bucket.Name }
    if (!$existing) {
        Write-Host "  Adding scoop bucket: $($bucket.Name)" -ForegroundColor Green
        scoop bucket add $($bucket.Name) $($bucket.Url)
    }
}

# Helper: install a list of scoop packages, preserving input order, skipping
# any that scoop already reports as installed.
function Install-ScoopList {
    param(
        [Parameter(Mandatory)] [string[]]$Packages,
        [string]$Heading = 'Installing scoop packages...'
    )
    $unique = [System.Collections.Generic.List[string]]::new()
    foreach ($p in $Packages) { if ($p -and ($unique -notcontains $p)) { $unique.Add($p) } }
    if ($unique.Count -eq 0) { return }
    Write-Host "`n$Heading" -ForegroundColor Cyan
    foreach ($pkg in $unique) {
        if (!(scoop list $pkg 2>$null)) {
            Write-Host "  Installing: $pkg" -ForegroundColor Green
            scoop install $pkg
        } else {
            Write-Host "  Already installed: $pkg" -ForegroundColor Gray
        }
    }
}

# 1) Install always_install FIRST (aria2, 7zip, gsudo, jq, ...) so subsequent
#    scoop downloads benefit from aria2 multi-connection downloads.
Install-ScoopList -Packages $alwaysInstallScoop -Heading 'Installing always-install scoop packages (aria2 first)...'
Update-SessionPath

# 2) Install feature-flag scoop packages
Install-ScoopList -Packages $featureScoopPackages -Heading 'Installing feature scoop packages...'
Update-SessionPath

# Run vcredist-aio to install all Visual C++ Redistributables
{{- if .package_features.windows_utilities }}
if (scoop list vcredist-aio 2>$null) {
    $vcredistExe = Join-Path $env:USERPROFILE 'scoop\apps\vcredist-aio\current\vcredist-aio.exe'
    if (Test-Path $vcredistExe) {
        Write-Host "`nInstalling Visual C++ Redistributables via vcredist-aio..." -ForegroundColor Cyan
        gsudo $vcredistExe /ai
    }
}
{{- end }}

# Install and start Everything search service (requires admin)
{{- if .package_features.windows_utilities }}
if (scoop list everything 2>$null) {
    $everythingExe = Join-Path $env:USERPROFILE 'scoop\apps\everything\current\everything.exe'
    if (Test-Path $everythingExe) {
        $svc = Get-Service -Name 'Everything' -ErrorAction SilentlyContinue
        if (!$svc) {
            Write-Host "`nInstalling Everything search service..." -ForegroundColor Cyan
            gsudo $everythingExe -install-service
            gsudo Start-Service 'Everything'
            Write-Host "  Everything service installed and started" -ForegroundColor Green
        } elseif ($svc.Status -ne 'Running') {
            Write-Host "`nStarting Everything search service..." -ForegroundColor Cyan
            gsudo Start-Service 'Everything'
            Write-Host "  Everything service started" -ForegroundColor Green
        } else {
            Write-Host "  Everything service already running" -ForegroundColor Gray
        }
    }
}
{{- end }}


# Install winget packages
if ($wingetPackages.Count -gt 0) {
    if (Get-Command winget -ErrorAction SilentlyContinue) {
        $wingetPackages = $wingetPackages | Select-Object -Unique
        Write-Host "`nInstalling winget packages..." -ForegroundColor Cyan
        foreach ($pkg in $wingetPackages) {
            $installed = winget list --id $pkg --exact 2>$null
            if ($LASTEXITCODE -ne 0) {
                Write-Host "  Installing: $pkg" -ForegroundColor Green
                winget install --id $pkg --silent --accept-source-agreements --accept-package-agreements
            } else {
                Write-Host "  Already installed: $pkg" -ForegroundColor Gray
            }
        }
    } else {
        Write-Host "`nwinget not available, skipping GUI app installation" -ForegroundColor Yellow
    }
}

# Install mise packages (language runtimes)
if ($misePackages.Count -gt 0) {
    if (Get-Command mise -ErrorAction SilentlyContinue) {
        $misePackages = $misePackages | Select-Object -Unique
        Write-Host "`nInstalling mise tools/runtimes..." -ForegroundColor Cyan
        foreach ($pkg in $misePackages) {
            $toolName = $pkg -replace '@.*$', ''
            $installed = mise list $toolName 2>$null
            if (!$installed -or $installed -notmatch $toolName) {
                Write-Host "  Installing: $pkg" -ForegroundColor Green
                mise install $pkg
            } else {
                Write-Host "  Already installed: $pkg" -ForegroundColor Gray
            }
        }
        # Reshim so newly-installed runtimes register their shims, then refresh
        # this session's PATH so subsequent pip/npm/gem/perl calls find them.
        try { mise reshim 2>$null | Out-Null } catch { }
    } else {
        Write-Host "`nmise not available. Install via: scoop install mise" -ForegroundColor Yellow
    }
}
Update-SessionPath

# Install PowerShell modules
if ($pwshModules.Count -gt 0) {
    $pwshModules = $pwshModules | Select-Object -Unique
    Write-Host "`nInstalling PowerShell modules..." -ForegroundColor Cyan
    foreach ($module in $pwshModules) {
        if (!(Get-Module -ListAvailable -Name $module)) {
            Write-Host "  Installing: $module" -ForegroundColor Green
            Install-Module $module -Scope CurrentUser -Force -SkipPublisherCheck
        } else {
            Write-Host "  Already installed: $module" -ForegroundColor Gray
        }
    }
}

# Install PSCompletions (psc) completion definitions.
# abgox.PSCompletions ships its module inside the scoop app dir, NOT on
# PSModulePath, so Import-Module by name fails. Resolve it explicitly.
#
# We run the install loop in a fresh `pwsh -File` subprocess. The chezmoi
# script runner's PowerShell context has subtle differences from a clean
# pwsh session (likely around -Command vs -File semantics and global scope
# propagation across nested Import-Module calls) that cause
# `$PSCompletions.init_data()` to populate state imperfectly, leaving
# `PSCompletions add` to emit non-fatal `__need_update_data` property
# errors. A clean subprocess sidesteps the issue entirely.
if ($pscCompletions.Count -gt 0) {
    $pscModule = $null
    foreach ($p in @(
        "$env:USERPROFILE\scoop\apps\abgox.PSCompletions\current\PSCompletions.psd1",
        "$env:USERPROFILE\scoop\modules\PSCompletions\PSCompletions.psd1"
    )) {
        if (Test-Path $p) { $pscModule = $p; break }
    }
    if (-not $pscModule) {
        Write-Host "`nPSCompletions module not found, skipping PSCompletions setup" -ForegroundColor Yellow
    } else {
        $pscCompletions = $pscCompletions | Select-Object -Unique
        $sidecar = Join-Path $env:TEMP "chezmoi-psc-install-$([guid]::NewGuid().ToString('N')).ps1"
        $compsLiteral = ($pscCompletions | ForEach-Object { "'" + ($_ -replace "'", "''") + "'" }) -join ','
        $sidecarBody = @"
param([string]`$ModulePath)
Import-Module `$ModulePath -Global -Force -ErrorAction Stop
`$global:PSCompletions.init_data() | Out-Null
`$installed = @()
if (`$global:PSCompletions.data -and `$global:PSCompletions.data.list) {
    `$installed = @(`$global:PSCompletions.data.list)
}
`$desired = @($compsLiteral)
foreach (`$comp in `$desired) {
    if (`$comp -in `$installed) {
        Write-Host "  Already added: `$comp" -ForegroundColor Gray
        continue
    }
    Write-Host "  Adding: `$comp" -ForegroundColor Green
    try { PSCompletions add `$comp *>`$null } catch {
        Write-Host "    PSCompletions add `$comp failed: `$(`$_.Exception.Message)" -ForegroundColor Yellow
    }
}
"@
        Set-Content -Path $sidecar -Value $sidecarBody -Encoding utf8
        try {
            Write-Host "`nInstalling PSCompletions definitions..." -ForegroundColor Cyan
            pwsh -NoProfile -NoLogo -File $sidecar -ModulePath $pscModule
            if ($LASTEXITCODE -ne 0) {
                Write-Host "  PSCompletions sidecar exited with code $LASTEXITCODE" -ForegroundColor Yellow
            }
        } finally {
            Remove-Item $sidecar -ErrorAction SilentlyContinue
        }
    }
}

# Install pip packages (packages not available via scoop/winget/mise on Windows)
# NOTE: mise shims `python` and `uv` but NOT `pip`. Always go through
# `python -m pip` so this works regardless of whether a separate `pip.exe`
# is on PATH.
if ($pipPackages.Count -gt 0) {
    if (Get-Command python -ErrorAction SilentlyContinue) {
        $pipPackages = $pipPackages | Select-Object -Unique
        Write-Host "`nInstalling pip packages..." -ForegroundColor Cyan
        foreach ($pkg in $pipPackages) {
            $installed = python -m pip show $pkg 2>$null
            if ($LASTEXITCODE -ne 0) {
                Write-Host "  Installing: $pkg" -ForegroundColor Green
                python -m pip install --user $pkg
            } else {
                Write-Host "  Already installed: $pkg" -ForegroundColor Gray
            }
        }
        # Ensure pipx PATH is configured
        if ($pipPackages -contains "pipx") {
            $pipxPath = "$env:APPDATA\Python\Python*\Scripts\pipx.exe"
            if (Test-Path $pipxPath) {
                Write-Host "  Configuring pipx PATH..." -ForegroundColor Cyan
                & (Get-Item $pipxPath | Select-Object -First 1).FullName ensurepath 2>$null
            }
        }
    } else {
        Write-Host "`npython not available, skipping pip package installation (mise python may not be on PATH yet)" -ForegroundColor Yellow
    }
}

{{- if and .package_features.nvim .package_features.python }}
# pynvim package (for Python provider)
# Use `python -m pip` since mise doesn't shim `pip` directly.
Write-Host "`nInstalling Neovim Python provider..." -ForegroundColor Cyan
if (Get-Command python -ErrorAction SilentlyContinue) {
    $pipNvimCheck = python -m pip show pynvim 2>$null
    if ($LASTEXITCODE -ne 0) {
        Write-Host "  Installing: pynvim (Python provider)" -ForegroundColor Green
        python -m pip install --user pynvim
    } else {
        Write-Host "  Already installed: pynvim" -ForegroundColor Gray
    }
} else {
    Write-Host "  python not available, skipping Python provider" -ForegroundColor Yellow
}
{{- end }}

{{- if and .package_features.nvim .package_features.node }}
# npm neovim package (for Node.js provider)
Write-Host "`nInstalling Neovim Node.js provider..." -ForegroundColor Cyan
if (Get-Command npm -ErrorAction SilentlyContinue) {
    $npmGlobalList = npm list -g neovim 2>$null
    if ($LASTEXITCODE -ne 0 -or $npmGlobalList -notmatch "neovim") {
        Write-Host "  Installing: npm neovim (Node.js provider)" -ForegroundColor Green
        npm install -g neovim
    } else {
        Write-Host "  Already installed: npm neovim" -ForegroundColor Gray
    }
} else {
    Write-Host "  npm not available, skipping Node.js provider" -ForegroundColor Yellow
}
{{- end }}

{{- if and .package_features.nvim .package_features.ruby }}
# gem neovim package (for Ruby provider)
Write-Host "`nInstalling Neovim Ruby provider..." -ForegroundColor Cyan
if (Get-Command gem -ErrorAction SilentlyContinue) {
    $gemList = gem list neovim 2>$null
    if ($gemList -notmatch "^neovim ") {
        # neovim gem requires native extensions - ensure MSYS2 toolchain is installed
        if (Get-Command ridk -ErrorAction SilentlyContinue) {
            Write-Host "  Ensuring MSYS2 toolchain is installed..." -ForegroundColor Cyan
            ridk install 3
        }
        Write-Host "  Installing: neovim gem (Ruby provider)" -ForegroundColor Green
        gem install neovim
    } else {
        Write-Host "  Already installed: neovim gem" -ForegroundColor Gray
    }
} else {
    Write-Host "  gem not available, skipping Ruby provider" -ForegroundColor Yellow
}
{{- end }}

{{- if and .package_features.nvim .package_features.perl }}
# cpan Neovim::Ext module (for Perl provider)
Write-Host "`nInstalling Neovim Perl provider..." -ForegroundColor Cyan
if (Get-Command perl -ErrorAction SilentlyContinue) {
    # Ensure .cpanm directory exists for cpanm to work
    $cpanmHome = "$env:USERPROFILE\.cpanm"
    if (!(Test-Path $cpanmHome)) {
        New-Item -ItemType Directory -Path $cpanmHome -Force | Out-Null
    }
    
    $perlCheck = perl -MNeovim::Ext -e "1" 2>&1
    if ($LASTEXITCODE -ne 0) {
        Write-Host "  Installing: Neovim::Ext (Perl provider)" -ForegroundColor Green
        # Use -T to skip tests (IO::Async tests fail on Windows)
        cpan -T Neovim::Ext
    } else {
        Write-Host "  Already installed: Neovim::Ext" -ForegroundColor Gray
    }
} else {
    Write-Host "  perl not available, skipping Perl provider" -ForegroundColor Yellow
}
{{- end }}

Write-Host "`n✓ Package installation complete" -ForegroundColor Green
{{- end -}}

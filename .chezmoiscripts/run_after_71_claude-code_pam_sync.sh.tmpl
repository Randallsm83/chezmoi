{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# Re-inject pam's MCP pointer into ~/.claude.json on every `chezmoi apply`.
#
# `.claude.json` is in .chezmoiignore (Claude Code auto-rewrites it constantly
# with caches, OAuth tokens, MCP creds, machine-specific project paths), so
# chezmoi never writes the file itself — only this script touches the
# `mcpServers.pam` pointer. The legacy #60 script that previously reconciled
# the rest of mcpServers from .chezmoidata/mcp.yaml was retired in
# commit cb8a04d when MCP ownership migrated fully to pam.
#
# Claude Code can drop the `pam` entry between mcp.yaml changes (runtime
# rewrites of .claude.json), so an onchange trigger keyed on the mcp.yaml
# inventory isn't sufficient — we need to re-assert the pointer on every
# apply. `pam sync` is atomic, format-aware, idempotent, and leaves every
# other mcpServers entry untouched, so per-apply cost is trivial.

set -euo pipefail

if ! command -v pam >/dev/null 2>&1; then
    echo "[claude-code_pam_sync] pam CLI not on PATH; skipping" >&2
    exit 0
fi

if ! pam status >/dev/null 2>&1; then
    echo "[claude-code_pam_sync] pam daemon not running; skipping ('pam start' to enable)" >&2
    exit 0
fi

echo "[claude-code_pam_sync] running 'pam sync --client claude-code'..."
pam sync --client claude-code
{{- end }}

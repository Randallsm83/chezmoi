{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# Reconcile Claude Code user-level MCP servers (github, gitlab, tavily).
#
# Source of truth lives in this template; we delegate to `claude mcp add-json`
# so Claude owns the on-disk schema in ~/.claude.json. We construct the JSON
# via `jq -n --arg` to avoid argv-parsing surprises in `claude mcp add`
# (variadic `-e` greedily consumes positional args).
#
# Idempotent: each server is removed first, then re-added.
#
# Re-runs automatically whenever the rendered script changes — which happens
# when any of the embedded 1Password secrets rotate, since they are
# interpolated directly into the variable assignments below.
#
# Companion: `dot_config/opencode/opencode.json.tmpl` mirrors the same three
# servers for opencode. Keep both in sync when adding/removing servers here.

set -euo pipefail

# claude is installed via mise; on remote-minimal tiers it may be absent.
if ! command -v claude >/dev/null 2>&1; then
    echo "[claude-mcp] claude CLI not found; skipping" >&2
    exit 0
fi

# jq is required to safely build the JSON payloads.
if ! command -v jq >/dev/null 2>&1; then
    echo "[claude-mcp] jq not found; skipping" >&2
    exit 0
fi

GITHUB_PAT="{{ .secrets.github_pat }}"
DH_GITLAB_PAT="{{ .secrets.dh_gitlab_pat }}"
TAVILY_API_KEY="{{ .secrets.tavily_api_key }}"

# If any secret resolved empty (1Password unavailable, item renamed, etc.),
# skip rather than register a broken server.
for var in GITHUB_PAT DH_GITLAB_PAT TAVILY_API_KEY; do
    if [ -z "${!var:-}" ]; then
        echo "[claude-mcp] secret \$$var is empty; skipping reconcile" >&2
        exit 0
    fi
done

# `claude mcp remove` exits non-zero if the server isn't registered. Swallow.
remove_if_present() {
    claude mcp remove --scope user "$1" 2>/dev/null || true
}

echo "[claude-mcp] reconciling user-scope MCP servers"

# 1) github — remote HTTP with PAT.
#    https://github.com/github/github-mcp-server (works for all plans, no Copilot req'd)
remove_if_present github
github_json=$(jq -nc \
    --arg url "https://api.githubcopilot.com/mcp/" \
    --arg auth "Bearer ${GITHUB_PAT}" \
    '{type:"http", url:$url, headers:{Authorization:$auth}}')
claude mcp add-json --scope user github "$github_json" >/dev/null
echo "  ✓ github"

# 2) gitlab — local stdio via @zereight/mcp-gitlab against DH self-hosted.
#    Official GitLab MCP needs >= 18.6 + Duo + OAuth-only; zereight is PAT-friendly
#    and supports custom GITLAB_API_URL.
remove_if_present gitlab
gitlab_json=$(jq -nc \
    --arg pat "${DH_GITLAB_PAT}" \
    --arg api "https://git.dreamhost.com/api/v4" \
    '{type:"stdio", command:"npx", args:["-y","@zereight/mcp-gitlab"], env:{GITLAB_PERSONAL_ACCESS_TOKEN:$pat, GITLAB_API_URL:$api}}')
claude mcp add-json --scope user gitlab "$gitlab_json" >/dev/null
echo "  ✓ gitlab (DH)"

# 3) tavily — remote HTTP with apiKey in URL (Tavily docs' "easy path").
remove_if_present tavily
tavily_json=$(jq -nc \
    --arg url "https://mcp.tavily.com/mcp/?tavilyApiKey=${TAVILY_API_KEY}" \
    '{type:"http", url:$url}')
claude mcp add-json --scope user tavily "$tavily_json" >/dev/null
echo "  ✓ tavily"

echo "[claude-mcp] done"
{{- end }}

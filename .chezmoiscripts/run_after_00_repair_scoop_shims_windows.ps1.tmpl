{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
# Repair Scoop reparse-point trust after package installs/updates.
#
# Scoop creates per-app `current` and per-version `persist` junctions as the
# user, which recent Windows 11 Insider builds reject as "untrusted mount
# points" on enumeration. This runs after every chezmoi apply and reuses the
# same shared logic the runtime PowerShell profile uses (see
# Documents/PowerShell/Scripts/lib/Repair-ScoopReparseTrust.ps1) so behavior
# stays aligned across both code paths.

$ErrorActionPreference = 'Continue'

$ScoopRoot = if ($env:SCOOP -and (Test-Path -LiteralPath $env:SCOOP)) {
    $env:SCOOP
} else {
    Join-Path $HOME 'scoop'
}
if (-not (Test-Path -LiteralPath (Join-Path $ScoopRoot 'apps'))) {
    exit 0
}

$Lib = Join-Path $HOME 'Documents\PowerShell\Scripts\lib\Repair-ScoopReparseTrust.ps1'
if (-not (Test-Path -LiteralPath $Lib)) {
    Write-Warning "[scoop-trust] Shared lib not found: $Lib (skipping)"
    exit 0
}

# -Repair triggers full discover+repair; the function inside auto-elevates via
# gsudo when run from a non-admin shell.
& pwsh -NoProfile -File $Lib -Repair -ScoopRoot $ScoopRoot
{{- end -}}

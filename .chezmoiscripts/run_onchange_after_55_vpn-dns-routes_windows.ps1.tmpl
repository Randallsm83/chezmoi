{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
# Install DNS routing NRPT rules. Renders from .infra.vpn_pritunl_ns +
# .infra.vpn_pritunl_domains (in .chezmoi.local.toml). Reruns on data hash change.
# Hash: {{ printf "%s%s%s%s%s%s" (include ".chezmoidata/packages.yaml") (include ".chezmoidata/theme.yaml") (include ".chezmoidata/ssh.yaml") (include ".chezmoidata/dns.yaml") (include ".chezmoidata/fonts.yaml") (include ".chezmoidata/mcp.yaml") | sha256sum }}
#
# What this does:
#   For each (profile, domain) pair in the Pritunl route data, ensures a Name
#   Resolution Policy Table rule exists routing that explicit namespace
#   (for example, '.internal.example') to the profile's VPN-internal resolver.
#   Do not configure a localhost catch-all namespace here: if 127.0.0.1:53 is
#   not responsive, Windows loses all hostname resolution.
#
# Why NRPT instead of just setting per-adapter DNS:
#   Windows resolves queries using the DNS list on the outgoing interface.
#   When a VPN attaches its own DNS to its tunnel adapter, queries leaving
#   the box bypass the loopback resolver entirely. NRPT is a system-wide
#   policy layer that runs before per-interface DNS, so it cannot be
#   silently overridden by adapter configuration.

# Build the desired rule set from chezmoi data.
$desired = @(
{{- $ns := .infra.vpn_pritunl_ns }}
{{- with $ns }}{{ range ($.infra.vpn_pritunl_domains | splitList ",") }}
    @{ Domain = '.{{ . }}'; NameServer = '{{ $ns }}'; Vpn = 'pritunl' },
{{- end }}{{ end }}
    $null
) | Where-Object { $_ }

if (-not $desired) {
    Write-Host "[vpn-dns] no routes resolved from data; nothing to do"
    exit 0
}

# All Get/Add/Remove-DnsClientNrptRule cmdlets need admin.
# Re-run this script under gsudo if not already elevated.
function Test-IsAdmin {
    $id = [Security.Principal.WindowsIdentity]::GetCurrent()
    $p  = [Security.Principal.WindowsPrincipal]$id
    $p.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
}

if (-not (Test-IsAdmin)) {
    if (Get-Command gsudo -ErrorAction SilentlyContinue) {
        Write-Host "[vpn-dns] elevating via gsudo to apply NRPT rules" -ForegroundColor Cyan
        # Re-invoke this exact script under elevation. $PSCommandPath is the
        # temp file chezmoi rendered; the elevated child takes the
        # Test-IsAdmin = $true branch and runs the rest.
        gsudo pwsh -NoProfile -File $PSCommandPath
        exit $LASTEXITCODE
    }
    Write-Host "[vpn-dns] need admin to manage NRPT rules and gsudo isn't installed; skipping." -ForegroundColor Yellow
    exit 0
}

Write-Host "[vpn-dns] reconciling NRPT rules from .infra.vpn_pritunl_* (.chezmoi.local.toml)" -ForegroundColor Cyan

# Index existing rules by namespace for fast lookup. NRPT keeps a list, not a
# map, so two rules can target the same namespace; we treat any matching one
# as "already configured" and only add if none exists.
$existing = @{}
Get-DnsClientNrptRule -ErrorAction SilentlyContinue | ForEach-Object {
    foreach ($ns in $_.Namespace) {
        if (-not $existing.ContainsKey($ns)) { $existing[$ns] = @() }
        $existing[$ns] += $_
    }
}

$comment = 'chezmoi: vpn-dns-route'

foreach ($r in $desired) {
    $matches = $existing[$r.Domain]
    $matchesThisServer = $matches | Where-Object { $_.NameServers -contains $r.NameServer }

    if ($matchesThisServer) {
        Write-Host ("  ok      {0,-25} -> {1}  [{2}]" -f $r.Domain, $r.NameServer, $r.Vpn) -ForegroundColor Gray
        continue
    }

    # Drop any stale rules for this domain pointing at a different server,
    # but only the ones we manage (chezmoi-tagged via Comment).
    $stale = $matches | Where-Object { $_.Comment -eq $comment }
    foreach ($s in $stale) {
        Write-Host ("  drop    {0,-25} -> {1}  (stale)" -f $s.Namespace, $s.NameServers -join ',') -ForegroundColor DarkYellow
        Remove-DnsClientNrptRule -Name $s.Name -Force
    }

    Add-DnsClientNrptRule -Namespace $r.Domain -NameServers $r.NameServer -Comment $comment | Out-Null
    Write-Host ("  add     {0,-25} -> {1}  [{2}]" -f $r.Domain, $r.NameServer, $r.Vpn) -ForegroundColor Green
}

# Optional: drop chezmoi-managed rules whose domains are no longer in the data
# file. Without this, removing a domain from the Pritunl route data leaves the
# rule live forever.
$desiredNamespaces = $desired | ForEach-Object { $_.Domain } | Sort-Object -Unique
$ourRules = Get-DnsClientNrptRule -ErrorAction SilentlyContinue | Where-Object { $_.Comment -eq $comment }
foreach ($r in $ourRules) {
    foreach ($ns in $r.Namespace) {
        if ($desiredNamespaces -notcontains $ns) {
            Write-Host ("  remove  {0,-25}  (no longer in the Pritunl route data)" -f $ns) -ForegroundColor DarkYellow
            Remove-DnsClientNrptRule -Name $r.Name -Force
            break
        }
    }
}

Write-Host "[vpn-dns] done" -ForegroundColor Green
{{- end }}

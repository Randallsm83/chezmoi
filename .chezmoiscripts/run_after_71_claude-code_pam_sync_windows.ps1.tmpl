{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
<#
.SYNOPSIS
    Re-inject pam's MCP pointer into ~/.claude.json on every `chezmoi apply`.

.DESCRIPTION
    `.claude.json` is in .chezmoiignore — Claude Code auto-rewrites it
    constantly (caches, OAuth tokens, MCP creds, machine-specific project
    paths), so chezmoi never writes the file itself. The legacy #60 script
    that used to reconcile `mcpServers` from .chezmoidata/mcp.yaml was
    retired in commit cb8a04d when MCP ownership migrated fully to pam, so
    this is now the only chezmoi-side hook that touches the file.

    Claude Code can drop the `mcpServers.pam` entry between mcp.yaml
    changes (runtime rewrites of .claude.json), so an onchange trigger keyed
    on the mcp.yaml inventory isn't sufficient — we need to re-assert the
    pointer on every apply. `pam sync --client claude-code` is atomic,
    format-aware, idempotent, and leaves every other mcpServers entry
    untouched.

.NOTES
    File is `run_after_` (not `run_onchange_after_`) so it fires on every
    apply. If pam isn't on PATH or the daemon isn't running, we skip silently.
#>

$ErrorActionPreference = "Stop"

if (-not (Get-Command pam -ErrorAction SilentlyContinue)) {
    Write-Host "claude-code_pam_sync: 'pam' not on PATH; skipping."
    exit 0
}

pam status *> $null
if ($LASTEXITCODE -ne 0) {
    Write-Host "claude-code_pam_sync: pam daemon not running; skipping ('pam start' to enable)."
    exit 0
}

Write-Host "claude-code_pam_sync: running 'pam sync --client claude-code'..."
pam sync --client claude-code
{{- end }}

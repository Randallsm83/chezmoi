{{- if ne .chezmoi.os "windows" -}}
#!/bin/bash
#
# Configure the chezmoi-source git remotes with the documented mirror layout:
#
#   origin   fetch/push = git@gitlab.com:Randallsm83/chezmoi.git   (canonical)
#   github   fetch/push = git@github.com:Randallsm83/chezmoi.git   (mirror)
#
# Multi-host pushes go through the `git pushall` alias (see
# dot_config/git/config.tmpl), which pushes origin then github serially with
# bounded retry. The previous dual-pushurl-on-origin layout fanned out two
# SSH signing requests in the same `git push` invocation; on Windows the
# 1Password named-pipe agent occasionally dropped the second sign with
# "communication with agent failed". Splitting the pushes makes each one
# independent and individually retryable. The same layout is applied on
# Unix for consistency (and so `git land` behaves identically everywhere).
#
# Why this script exists: the README bootstrap path uses GitHub URLs
# (`raw.githubusercontent.com/Randallsm83/chezmoi/...`) and
# `chezmoi init Randallsm83/chezmoi` defaults to GitHub, leaving a single-
# URL `origin` pointed at GitHub on every fresh install. This script
# reconciles to the canonical GitLab-as-origin + GitHub-as-mirror layout.
#
# Idempotent: detects current state and skips silently when already
# canonical. Safe to re-run. Strips any stale dual-pushurl entries on
# origin or github left over from the old layout.

set -euo pipefail

REPO_DIR={{ .chezmoi.sourceDir | quote }}
WANT_ORIGIN_URL="git@gitlab.com:Randallsm83/chezmoi.git"
WANT_GITHUB_URL="git@github.com:Randallsm83/chezmoi.git"

# Bail if the source dir isn't a git checkout (chezmoi was installed via
# `chezmoi init --source=/some/extracted/tarball` or similar).
if [ ! -d "$REPO_DIR/.git" ]; then
    exit 0
fi

cd "$REPO_DIR"

have_origin=$(git config --get remote.origin.url 2>/dev/null || true)
have_origin_push=$(git config --get-all remote.origin.pushurl 2>/dev/null || true)
have_github=$(git config --get remote.github.url 2>/dev/null || true)

if [ "$have_origin" = "$WANT_ORIGIN_URL" ] \
    && [ -z "$have_origin_push" ] \
    && [ "$have_github" = "$WANT_GITHUB_URL" ]; then
    exit 0
fi

echo "[chezmoi-repo-remotes] Configuring origin (GitLab) + github (GitHub) remotes in $REPO_DIR"

# Canonical origin = GitLab (single URL, single pushurl by default).
git remote set-url origin "$WANT_ORIGIN_URL"
git config --unset-all remote.origin.pushurl 2>/dev/null || true

# Separate `github` remote so `git push github main` (and
# `--force-with-lease` recovery) is available.
if git remote get-url github >/dev/null 2>&1; then
    git remote set-url github "$WANT_GITHUB_URL"
else
    git remote add github "$WANT_GITHUB_URL"
fi
git config --unset-all remote.github.pushurl 2>/dev/null || true

echo "[chezmoi-repo-remotes] Done. Push both with: git pushall (see CONTRIBUTING.md)"
{{- end -}}

{{- /*
LibreWolf configuration writer.

Three files, all at non-XDG paths chezmoi can't manage as targets:
  1. policies.json
       Source: librewolf/distribution/policies.json
       Target: C:\Program Files\LibreWolf\distribution\policies.json
             (winget LibreWolf.LibreWolf install location)
       Owns: force-installed extensions (uBlock, Bitwarden, ClearURLs,
             LocalCDN, SponsorBlock, Dark Reader, Multi-Account
             Containers), default search engine + add/remove list,
             telemetry/update lockdown.
       Clobber risk: winget upgrades may replace the distribution dir;
             this script reapplies after every chezmoi run.
  2. user.js
       Source: librewolf/profile/user.js
       Target: %APPDATA%/LibreWolf/Profiles/<id>.default-default/user.js
       Owns: per-profile preference overrides (network/fingerprinting
             hardening, cookies-on-shutdown, HTTPS-only, WebRTC off, etc).
       Clobber risk: lost on profile recreation. The profile id is
             generated per-install, so we discover it at apply time
             from %APPDATA%/LibreWolf/profiles.ini rather than hardcoding.
  3. chrome/userChrome.css
       Source: librewolf/profile/chrome/userChrome.css
       Target: %APPDATA%/LibreWolf/Profiles/<id>.default-default/chrome/userChrome.css
       Owns: Spaceduck UI theme (toolbar, tabs, urlbar, menus).
       Requires: toolkit.legacyUserProfileCustomizations.stylesheets=true
             (set in user.js above).

Why a script instead of normal target-tree management:
  Both targets sit outside the home-relative tree chezmoi expects. Same
  pattern we use for D:\dh\mise.toml in run_onchange_after_50_*.

Trigger semantics:
  `run_onchange_` re-runs when the rendered script body changes. The
  embedded sha256 comments below pick up source-file changes.

Idempotency:
  Each write checks for an existing identical target and skips silently.

Profile-id discovery (from notes/02 Atlas/Reference/Windows/LibreWolf Setup.md):
  Always verify the active profile via profiles.ini.

Install switch from scoop -> winget (LibreWolf.LibreWolf):
  Install path moved from ~/scoop/apps/librewolf/current/LibreWolf to
  C:\Program Files\LibreWolf. Winget registers cleanly under HKLM
  StartMenuInternet\LibreWolf with a single ProgID (LibreWolfHTM).
*/}}
{{- if eq .chezmoi.os "windows" -}}
# policies.json   sha256: {{ include (joinPath .chezmoi.sourceDir "librewolf" "distribution" "policies.json") | sha256sum }}
# user.js         sha256: {{ include (joinPath .chezmoi.sourceDir "librewolf" "profile" "user.js") | sha256sum }}
# userChrome.css  sha256: {{ include (joinPath .chezmoi.sourceDir "librewolf" "profile" "chrome" "userChrome.css") | sha256sum }}
$ErrorActionPreference = 'Stop'

$srcPolicies     = '{{ joinPath .chezmoi.sourceDir "librewolf" "distribution" "policies.json" | replace "\\" "/" }}'
$srcUserJs       = '{{ joinPath .chezmoi.sourceDir "librewolf" "profile" "user.js" | replace "\\" "/" }}'
$srcUserChromeCss = '{{ joinPath .chezmoi.sourceDir "librewolf" "profile" "chrome" "userChrome.css" | replace "\\" "/" }}'

function Write-IfChanged {
    param([string]$Src, [string]$Dst)
    if (-not (Test-Path -LiteralPath $Src)) {
        Write-Warning "[librewolf] source missing: $Src"
        return
    }
    $srcText = ([System.IO.File]::ReadAllText($Src)) -replace "`r`n", "`n"
    if (Test-Path -LiteralPath $Dst) {
        $dstText = ([System.IO.File]::ReadAllText($Dst)) -replace "`r`n", "`n"
        if ($dstText -eq $srcText) { return }
    }
    $dstDir = Split-Path -Parent $Dst
    if (-not (Test-Path -LiteralPath $dstDir)) {
        New-Item -ItemType Directory -Path $dstDir -Force | Out-Null
    }
    [System.IO.File]::WriteAllText($Dst, $srcText, [System.Text.UTF8Encoding]::new($false))
    Write-Host "[librewolf] wrote $Dst ($($srcText.Length) bytes)"
}

# === policies.json -> install dir ===
# Try winget install location first, then fall back to scoop for backwards-compat.
# Program Files requires elevation; scoop dir is user-writable.
$installDistCandidates = @(
    @{ Path = 'C:\Program Files\LibreWolf\distribution'; NeedsAdmin = $true },
    @{ Path = "$env:USERPROFILE\scoop\apps\librewolf\current\LibreWolf\distribution"; NeedsAdmin = $false }
)
$chosen = $installDistCandidates | Where-Object { Test-Path -LiteralPath (Split-Path -Parent $_.Path) } | Select-Object -First 1
if ($chosen) {
    $installDist = $chosen.Path
    $policiesDst = Join-Path $installDist 'policies.json'
    $srcText = ([System.IO.File]::ReadAllText($srcPolicies)) -replace "`r`n", "`n"
    $needsWrite = $true
    if (Test-Path -LiteralPath $policiesDst) {
        $dstText = ([System.IO.File]::ReadAllText($policiesDst)) -replace "`r`n", "`n"
        if ($dstText -eq $srcText) { $needsWrite = $false }
    }
    if ($needsWrite) {
        if ($chosen.NeedsAdmin) {
            Write-Host "[librewolf] elevating via gsudo to write $policiesDst"
            $tmp = [System.IO.Path]::GetTempFileName()
            [System.IO.File]::WriteAllText($tmp, $srcText, [System.Text.UTF8Encoding]::new($false))
            gsudo --loglevel none -- powershell -NoProfile -Command "if (-not (Test-Path -LiteralPath '$installDist')) { New-Item -ItemType Directory -Path '$installDist' -Force | Out-Null }; Copy-Item -LiteralPath '$tmp' -Destination '$policiesDst' -Force"
            Remove-Item -LiteralPath $tmp -Force -ErrorAction SilentlyContinue
            Write-Host "[librewolf] wrote $policiesDst ($($srcText.Length) bytes)"
        } else {
            Write-IfChanged -Src $srcPolicies -Dst $policiesDst
        }
    }
} else {
    Write-Warning "[librewolf] install dir not found - is LibreWolf installed via winget (LibreWolf.LibreWolf) or scoop?"
}

# === user.js -> active profile (id discovered from profiles.ini) ===
$lwAppData = "$env:APPDATA\LibreWolf"
$profilesIni = Join-Path $lwAppData 'profiles.ini'
if (-not (Test-Path -LiteralPath $profilesIni)) {
    Write-Warning "[librewolf] profiles.ini not found ($profilesIni) - launch LibreWolf once to create it, then re-run chezmoi apply"
    exit 0
}

$iniLines = Get-Content -LiteralPath $profilesIni
$relPath  = $null

# Prefer [InstallXXX] -> Default= (the locked-to-this-install pointer).
$inInstall = $false
foreach ($line in $iniLines) {
    if ($line -match '^\[Install') { $inInstall = $true; continue }
    if ($line -match '^\[' -and $line -notmatch '^\[Install') { $inInstall = $false; continue }
    if ($inInstall -and $line -match '^Default=(.+)$') {
        $relPath = $Matches[1].Trim()
        break
    }
}

# Fallback: first [ProfileN] section with Default=1.
if (-not $relPath) {
    $inProfile = $false
    $candidate = $null
    foreach ($line in $iniLines) {
        if ($line -match '^\[Profile\d') { $inProfile = $true; $candidate = $null; continue }
        if ($line -match '^\[' -and $line -notmatch '^\[Profile\d') { $inProfile = $false; continue }
        if ($inProfile -and $line -match '^Path=(.+)$')  { $candidate = $Matches[1].Trim() }
        if ($inProfile -and $line -match '^Default=1\s*$' -and $candidate) {
            $relPath = $candidate
            break
        }
    }
}

if (-not $relPath) {
    Write-Warning "[librewolf] could not determine active profile from $profilesIni"
    exit 0
}

# Auto-repair: collapse divergent [InstallX] sections that point to different
# profiles back to the canonical one. Happens after install path changes
# (e.g. scoop -> winget) when LibreWolf creates a fresh empty profile under
# a new install hash.
function Repair-IniInstallSections {
    param([string]$Path, [string]$Pattern, [string]$CanonicalPath)
    if (-not (Test-Path -LiteralPath $Path)) { return }
    $text = [System.IO.File]::ReadAllText($Path)
    $orig = $text
    $rx = [regex]::new("(?m)^($Pattern)\r?\n((?:(?!^\[).*\r?\n)*)")
    $text = $rx.Replace($text, {
        param($m)
        $header = $m.Groups[1].Value
        $body   = $m.Groups[2].Value
        $body   = [regex]::Replace($body, '(?m)^Default=.+', "Default=$CanonicalPath")
        "$header`n$body"
    })
    if ($text -ne $orig) {
        [System.IO.File]::WriteAllText($Path, $text, [System.Text.UTF8Encoding]::new($false))
        Write-Host "[librewolf] auto-repaired divergent install sections in $Path -> $CanonicalPath"
    }
}
Repair-IniInstallSections -Path $profilesIni -Pattern '\[Install[0-9A-F]+\]' -CanonicalPath $relPath
Repair-IniInstallSections -Path (Join-Path $lwAppData 'installs.ini') -Pattern '\[[0-9A-F]{16}\]' -CanonicalPath $relPath

$activeProfile = Join-Path $lwAppData ($relPath -replace '/', '\')
if (-not (Test-Path -LiteralPath $activeProfile)) {
    Write-Warning "[librewolf] active profile dir not found: $activeProfile"
    exit 0
}

Write-IfChanged -Src $srcUserJs       -Dst (Join-Path $activeProfile 'user.js')
Write-IfChanged -Src $srcUserChromeCss -Dst (Join-Path $activeProfile 'chrome\userChrome.css')
{{- end -}}

{{- /*
Windows unbound: loopback forwarding cache for raspi/Pi-hole DoT.

Pipeline:
  1. Render service.conf.tmpl from `unbound/service.conf.tmpl` into the
     scoop persist dir (~/scoop/persist/unbound/service.conf). Scoop's
     `unbound` package symlinks the persist file into apps/unbound/current,
     so updates survive scoop upgrades.
  2. Validate via `unbound-checkconf`.
  3. Install / refresh the Windows "unbound" service (unbound.exe -w
     install).
  4. Start the service and wait for 127.0.0.1:53 to resolve through the local
     forwarding cache to raspi/Pi-hole.
  5. ONLY if the local cache is verified responsive: switch every active IPv4
     ethernet/Wi-Fi adapter to use 127.0.0.1 as its local DNS cache. If the
     cache is not responsive, reset any adapter that only points at 127.0.0.1
     and emit a warning.

Trigger semantics: same `run_onchange_` pattern as the librewolf script.
The embedded sha256 comments below pick up changes to the rendered
service.conf so this script re-runs only when needed.

Recovery: to unwind everything,
  Set-DnsClientServerAddress -InterfaceAlias <name> -ResetServerAddresses
  gsudo Stop-Service unbound; gsudo & "$env:USERPROFILE\scoop\apps\unbound\current\unbound.exe" -w remove
*/}}
{{- if eq .chezmoi.os "windows" -}}
# rendered service.conf sha256: {{ includeTemplate "unbound/service.conf.tmpl" . | sha256sum }}
$ErrorActionPreference = 'Stop'

$srcConfig = @'
{{ includeTemplate "unbound/service.conf.tmpl" . -}}
'@

# ── Resolve scoop install + persist dirs ──────────────────────────────────────
$scoopRoot = "$env:USERPROFILE\scoop"
$unboundApp = Join-Path $scoopRoot 'apps\unbound\current'
$unboundPersist = Join-Path $scoopRoot 'persist\unbound'
$unboundExe = Join-Path $unboundApp 'unbound.exe'
$checkConfExe = Join-Path $unboundApp 'unbound-checkconf.exe'

if (-not (Test-Path -LiteralPath $unboundExe)) {
    Write-Warning "[unbound] unbound is not installed via scoop (missing $unboundExe). Skipping. Run 'scoop install unbound' first or wait for the next install-packages-windows pass."
    exit 0
}

if (-not (Test-Path -LiteralPath $unboundPersist)) {
    New-Item -ItemType Directory -Path $unboundPersist -Force | Out-Null
}

# Warn about cacert only when the rendered config references a TLS cert bundle.
# Filename is cacert.pem in the scoop package, not ca-bundle.crt.
$cacertPath = Join-Path $scoopRoot 'apps\cacert\current\cacert.pem'
$usesTlsCertBundle = $srcConfig -match '(?m)^\s*tls-cert-bundle\s*:'
if ($usesTlsCertBundle -and -not (Test-Path -LiteralPath $cacertPath)) {
    Write-Warning "[unbound] cacert.pem not found at $cacertPath, but service.conf references tls-cert-bundle:. Install via 'scoop install cacert'."
}

# ── Write service.conf (LF, UTF-8 no BOM) if changed ────────────────────────
$dstConfig = Join-Path $unboundPersist 'service.conf'
$dstAppLink = Join-Path $unboundApp 'service.conf'
$srcText = ($srcConfig -replace "`r`n", "`n")
$previousConfigText = $null
$needsWrite = $true
if (Test-Path -LiteralPath $dstConfig) {
    $previousConfigText = ([System.IO.File]::ReadAllText($dstConfig)) -replace "`r`n", "`n"
    if ($previousConfigText -eq $srcText) { $needsWrite = $false }
}
if ($needsWrite) {
    [System.IO.File]::WriteAllText($dstConfig, $srcText, [System.Text.UTF8Encoding]::new($false))
    Write-Host "[unbound] wrote $dstConfig ($($srcText.Length) bytes)"
}

function Restore-PreviousUnboundConfig {
    param([string]$Reason)

    $resetLocalDnsScript = @'
$ErrorActionPreference = 'SilentlyContinue'
if ((Get-Service unbound -ErrorAction SilentlyContinue).Status -eq 'Running') {
    Restart-Service unbound
} else {
    Start-Service unbound
}
Get-NetAdapter | Where-Object { $_.Status -eq 'Up' } | ForEach-Object {
    $dns = Get-DnsClientServerAddress -InterfaceAlias $_.InterfaceAlias -AddressFamily IPv4 -ErrorAction SilentlyContinue
    $servers = @($dns.ServerAddresses)
    if ($servers.Count -eq 1 -and $servers[0] -eq '127.0.0.1') {
        Set-DnsClientServerAddress -InterfaceAlias $_.InterfaceAlias -ResetServerAddresses
    }
}
ipconfig /flushdns | Out-Null
'@

    if ($needsWrite -and $previousConfigText) {
        Write-Warning "[unbound] $Reason Restoring previous service.conf so the local resolver keeps working."
        [System.IO.File]::WriteAllText($dstConfig, $previousConfigText, [System.Text.UTF8Encoding]::new($false))
        gsudo --loglevel none -- powershell -NoProfile -Command $resetLocalDnsScript 2>&1 | Out-Null
    } else {
        Write-Warning "[unbound] $Reason"
    }
}

# Scoop's unbound install symlinks $unboundApp\service.conf to the persist
# copy at install time, but if scoop was bypassed or the symlink got broken
# we re-link here so unbound.exe -c "$dir\service.conf" finds the right file.
if (-not (Test-Path -LiteralPath $dstAppLink) -or
    ((Get-Item -LiteralPath $dstAppLink -Force).LinkType -ne 'SymbolicLink' -and
     (Get-Item -LiteralPath $dstAppLink -Force).LinkType -ne 'HardLink')) {
    if (Test-Path -LiteralPath $dstAppLink) {
        Remove-Item -LiteralPath $dstAppLink -Force
    }
    try {
        New-Item -ItemType SymbolicLink -Path $dstAppLink -Target $dstConfig | Out-Null
        Write-Host "[unbound] linked $dstAppLink -> $dstConfig"
    } catch {
        # Symlink requires Windows Developer Mode (the user has it on per
        # rules) but if it ever fails fall back to a hard copy.
        Copy-Item -LiteralPath $dstConfig -Destination $dstAppLink -Force
        Write-Host "[unbound] copied (no symlink) $dstConfig -> $dstAppLink"
    }
}

# ── Validate ────────────────────────────────────────────────────────────────
Write-Host "[unbound] running unbound-checkconf..."
& $checkConfExe $dstConfig
if ($LASTEXITCODE -ne 0) {
    Restore-PreviousUnboundConfig "config validation failed; leaving system DNS unchanged."
    exit 1
}

# ── Install or refresh the Windows service ─────────────────────────────
# unbound.exe -w install registers the service but hardcodes binPath to
# `<exe> -w service` with NO config flag, which causes the daemon to look
# for service.conf at C:\Program Files\Unbound (the upstream default).
# Scoop installs to a different path, so we must override binPath via
# `sc config` to add `-c <our-persist-conf>`. cmd.exe is required for the
# -w flag because pwsh parses it as its own -WindowStyle parameter.
$wantBin = '"' + $unboundExe + '" -w service -c "' + $dstConfig + '"'
$serviceNeedsRestart = $needsWrite

$svc = Get-Service -Name 'unbound' -ErrorAction SilentlyContinue
if (-not $svc) {
    Write-Host "[unbound] installing Windows service via gsudo (cmd.exe)..."
    $installCmd = '"' + $unboundExe + '" -w install'
    gsudo --loglevel none -- cmd.exe /c $installCmd
    Start-Sleep -Seconds 2
    $svc = Get-Service -Name 'unbound' -ErrorAction SilentlyContinue
    if ($svc) { $serviceNeedsRestart = $true }
}

if (-not $svc) {
    Write-Warning "[unbound] service install did not register; check gsudo output and re-run"
    exit 1
}

# Ensure binPath includes our explicit -c <conf>. unbound -w install hardcodes
# the path to '<exe> -w service' alone; we need to amend it.
$currentBin = (Get-CimInstance Win32_Service -Filter "Name='unbound'").PathName
$currentBinNormalized = $currentBin -replace '"', ''
$wantBinNormalized = "$unboundExe -w service -c $dstConfig"
if ($currentBinNormalized -ne $wantBinNormalized) {
    Write-Host "[unbound] updating service binPath to use $dstConfig..."
    gsudo --loglevel none -- cmd.exe /c ("sc config unbound binPath= " + ('"' + $wantBin + '"'))
    $serviceNeedsRestart = $true
}

# Ensure auto-start
if ((Get-Service unbound).StartType -ne 'Automatic') {
    gsudo --loglevel none -- cmd.exe /c "sc config unbound start= auto" | Out-Null
}

# Restart when rendered service.conf changed or service registration changed.
# If the service is simply stopped, start it so the localhost health probe
# checks the intended DoT-forwarding cache before adapter DNS is changed.
$svc = Get-Service -Name 'unbound'
if ($serviceNeedsRestart) {
    Write-Host "[unbound] (re)starting service to pick up service changes..."
    $restartServiceScript = @'
$ErrorActionPreference = 'Stop'
$timeout = [TimeSpan]::FromSeconds(30)
$svc = Get-Service -Name 'unbound'

if ($svc.Status -eq 'Running') {
    Stop-Service -Name 'unbound' -ErrorAction Stop
    $svc.WaitForStatus([System.ServiceProcess.ServiceControllerStatus]::Stopped, $timeout)
} elseif ($svc.Status -eq 'StopPending') {
    $svc.WaitForStatus([System.ServiceProcess.ServiceControllerStatus]::Stopped, $timeout)
} elseif ($svc.Status -ne 'Stopped') {
    if ($svc.CanStop) {
        Stop-Service -Name 'unbound' -ErrorAction Stop
        $svc.WaitForStatus([System.ServiceProcess.ServiceControllerStatus]::Stopped, $timeout)
    } else {
        throw "unbound is $($svc.Status) and cannot be stopped"
    }
}

Start-Service -Name 'unbound' -ErrorAction Stop
$svc = Get-Service -Name 'unbound'
$svc.WaitForStatus([System.ServiceProcess.ServiceControllerStatus]::Running, $timeout)
'@
    gsudo --loglevel none -- powershell -NoProfile -Command $restartServiceScript 2>&1 | Out-Null
} elseif ($svc.Status -eq 'Stopped') {
    Write-Host "[unbound] starting service..."
    gsudo --loglevel none -- powershell -NoProfile -Command "Start-Service unbound" 2>&1 | Out-Null
}

$running = $false
for ($i = 0; $i -lt 10; $i++) {
    $svc = Get-Service -Name 'unbound' -ErrorAction SilentlyContinue
    if ($svc -and $svc.Status -eq 'Running') {
        $running = $true
        break
    }
    Start-Sleep -Milliseconds 500
}

if (-not $running) {
    Restore-PreviousUnboundConfig "service did not reach Running within 5s; leaving Windows DNS unchanged."
    exit 0
}

# ── Verify the local raspi/Pi-hole forwarding cache is actually up ──────────
$listening = $false
for ($i = 0; $i -lt 10; $i++) {
    Start-Sleep -Milliseconds 500
    try {
        $r = Resolve-DnsName -Server 127.0.0.1 -Name 'cloudflare.com' -Type A -DnsOnly -QuickTimeout -ErrorAction Stop
        if ($r) { $listening = $true; break }
    } catch {
        # try again
    }
}

if (-not $listening) {
    Restore-PreviousUnboundConfig "local raspi/Pi-hole forwarding cache did not respond on 127.0.0.1:53 within 5s; leaving Windows DNS unchanged."
    exit 0
}

Write-Host "[unbound] local raspi/Pi-hole forwarding cache responsive on 127.0.0.1:53"

# ── Switch active adapters' DNS to 127.0.0.1 ──────────────────────────────
# Physical ethernet/Wi-Fi adapters AND user-space VPN tunnels (ProtonVPN,
# Pritunl, etc.) all get pinned to 127.0.0.1 so the local raspi/Pi-hole
# forwarding cache is the only DNS server in the per-adapter list.
#
# Tailscale is excluded on purpose: it auto-installs an NRPT catch-all
# (`.` -> 100.100.100.100, fd7a:115c:a1e0::53) and that's how MagicDNS
# resolves `*.ts.net` and short tailnet hostnames. Forcing its adapter to
# 127.0.0.1 doesn't kill MagicDNS (NRPT still wins for matching names) but
# leave its DNS settings alone so MagicDNS remains managed by Tailscale.
#
# vEthernet / Loopback are skipped because they're virtual bridges / lo.
#
# Why VPN tunnels need this: when Proton's WireGuard tunnel comes up it
# attaches `10.2.0.1` to its adapter, which Windows happily queries in
# parallel with NRPT catch-all rules and the tunnel DNS server can win the
# race against the loopback raspi/Pi-hole cache. Result: Proton answers DNS
# even though the local resolver should be the adapter DNS path.
# Pinning the tunnel adapter to only 127.0.0.1 removes the competing entry.
#
# Live cleanup on every Proton reconnect is handled by an event-triggered
# Scheduled Task installed by
# .chezmoiscripts/run_onchange_after_59_vpn-dns-watcher_windows.ps1.tmpl,
# which runs dot_config/windows/scripts/clean-vpn-adapter-dns.ps1 whenever
# the `ProtonVPN WireGuard` service enters the running state (System log
# event 7036). This script's adapter pass is the chezmoi-apply-time
# version of the same cleanup and is mostly redundant with the watcher,
# but keeps the post-install state correct on fresh boxes before the
# watcher fires its first event.
# See clean-vpn-adapter-dns.ps1 for why Pritunl is excluded (its adapter
# DNS is empty; it uses NRPT split-DNS instead of adapter injection).
# `ProtonVPN` is the WireGuard adapter alias; `ProtonVPN TUN` is the
# OpenVPN/TUN adapter alias. Both inject a non-loopback DNS server that
# must be stripped.
$vpnTunnelAliasPattern = '^ProtonVPN( TUN)?$'
$physical = Get-NetAdapter -Physical -ErrorAction SilentlyContinue |
    Where-Object { $_.Status -eq 'Up' -and $_.InterfaceAlias -notmatch '^(Tailscale|vEthernet|Loopback)' }
$tunnels = Get-NetAdapter -ErrorAction SilentlyContinue |
    Where-Object { $_.Status -eq 'Up' -and $_.InterfaceAlias -match $vpnTunnelAliasPattern }
$targetAdapters = @($physical) + @($tunnels)

foreach ($a in $targetAdapters) {
    $current = (Get-DnsClientServerAddress -InterfaceAlias $a.InterfaceAlias -AddressFamily IPv4 -ErrorAction SilentlyContinue).ServerAddresses
    if ($current -and ($current.Count -eq 1) -and ($current[0] -eq '127.0.0.1')) {
        # Already pointing at the local cache.
        continue
    }
    Write-Host "[unbound] $($a.InterfaceAlias): switching IPv4 DNS from [$($current -join ', ')] -> [127.0.0.1]"
    # Set-DnsClientServerAddress requires admin ("Access to a CIM resource was
    # not available"); funnel through gsudo. Quote the alias to survive names
    # like "Wi-Fi" with hyphens or spaces.
    $aliasQ = $a.InterfaceAlias.Replace("'", "''")
    gsudo --loglevel none -- powershell -NoProfile -Command "Set-DnsClientServerAddress -InterfaceAlias '$aliasQ' -ServerAddresses '127.0.0.1'"
}

# Flush the Windows DNS client cache so the next query goes through the local raspi/Pi-hole cache.
ipconfig /flushdns | Out-Null

Write-Host "[unbound] done. Active DNS path: Windows -> 127.0.0.1 local cache -> raspi/Pi-hole DoT."
{{- end -}}

{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# Ensure bat theme cache is current after every chezmoi apply
# Handles cases where bat is updated/reinstalled and its cache is wiped
set -euo pipefail

if command -v bat >/dev/null 2>&1; then
    # `bat cache --build` failures should not abort the apply (e.g. when bat's
    # config dir is read-only on certain CI images); log to stderr and continue.
    bat cache --build >/dev/null 2>&1 || echo "Warning: bat cache --build failed" >&2
fi
{{- end }}

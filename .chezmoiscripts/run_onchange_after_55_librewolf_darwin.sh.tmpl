{{- /*
LibreWolf configuration writer (macOS).

Mirrors run_onchange_after_55_librewolf_windows.ps1.tmpl. Three files,
all at non-XDG paths chezmoi can't manage as targets:

  1. policies.json
       Source: librewolf/distribution/policies.json
       Target: /Applications/LibreWolf.app/Contents/Resources/distribution/policies.json
       Owns:   force-installed extensions, default search engine + add/remove
               list, telemetry/update lockdown.
       Notes:  Lives inside the app bundle, so writes need sudo.
               Re-applied after every chezmoi run -- brew cask upgrades may
               replace the distribution dir.

  2. user.js
       Source: librewolf/profile/user.js
       Target: ~/Library/Application Support/LibreWolf/Profiles/<id>/user.js
       Owns:   per-profile preference overrides (network/fingerprinting
               hardening, cookies-on-shutdown, HTTPS-only, WebRTC off, etc).
       Notes:  Profile id is generated per-install; discover it at apply
               time from profiles.ini rather than hardcoding.

  3. chrome/userChrome.css
       Source: librewolf/profile/chrome/userChrome.css
       Target: ~/Library/Application Support/LibreWolf/Profiles/<id>/chrome/userChrome.css
       Owns:   Spaceduck UI theme.
       Requires: toolkit.legacyUserProfileCustomizations.stylesheets=true
                 (set in user.js above).

Trigger semantics:
  `run_onchange_` re-runs when the rendered script body changes. The
  embedded sha256 comments below pick up source-file changes.

Idempotency:
  Each write checks for an identical existing target and skips silently.
*/}}
{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# policies.json   sha256: {{ include (joinPath .chezmoi.sourceDir "librewolf" "distribution" "policies.json") | sha256sum }}
# user.js         sha256: {{ include (joinPath .chezmoi.sourceDir "librewolf" "profile" "user.js") | sha256sum }}
# userChrome.css  sha256: {{ include (joinPath .chezmoi.sourceDir "librewolf" "profile" "chrome" "userChrome.css") | sha256sum }}
set -euo pipefail

SRC_POLICIES='{{ joinPath .chezmoi.sourceDir "librewolf" "distribution" "policies.json" }}'
SRC_USER_JS='{{ joinPath .chezmoi.sourceDir "librewolf" "profile" "user.js" }}'
SRC_USER_CHROME='{{ joinPath .chezmoi.sourceDir "librewolf" "profile" "chrome" "userChrome.css" }}'

LW_APP="/Applications/LibreWolf.app"
LW_DIST_DIR="$LW_APP/Contents/Resources/distribution"
LW_APPSUP="$HOME/Library/Application Support/LibreWolf"
LW_PROFILES_INI="$LW_APPSUP/profiles.ini"

log()  { printf '[librewolf] %s\n' "$*"; }
warn() { printf '[librewolf] WARN: %s\n' "$*" >&2; }

# Compare normalised text (strip CR for cross-platform safety) and return 0
# if dst is missing or differs. Uses cmp via process substitution to avoid
# loading huge files into shell variables.
needs_write() {
    local src="$1" dst="$2" reader="${3:-cat}"
    [ -f "$dst" ] || return 0
    ! cmp -s <(tr -d '\r' < "$src") <($reader "$dst" | tr -d '\r')
}

write_user_file() {
    # Plain (no-sudo) write to a path the current user owns.
    local src="$1" dst="$2"
    if [ ! -f "$src" ]; then
        warn "source missing: $src"
        return 0
    fi
    if ! needs_write "$src" "$dst"; then
        return 0
    fi
    mkdir -p "$(dirname "$dst")"
    install -m 0644 "$src" "$dst"
    log "wrote $dst ($(wc -c <"$src" | tr -d ' ') bytes)"
}

write_root_file() {
    # sudo-elevated write for app-bundle paths.
    local src="$1" dst="$2"
    if [ ! -f "$src" ]; then
        warn "source missing: $src"
        return 0
    fi
    if ! needs_write "$src" "$dst" "sudo cat"; then
        return 0
    fi
    if ! sudo -n true 2>/dev/null; then
        log "sudo needs a password (writing into $LW_APP)"
        sudo -v || { warn "sudo declined; skipping $dst"; return 0; }
    fi
    sudo mkdir -p "$(dirname "$dst")"
    sudo install -m 0644 "$src" "$dst"
    log "wrote $dst ($(wc -c <"$src" | tr -d ' ') bytes)"
}

# === policies.json -> app bundle distribution dir ===
if [ -d "$LW_APP" ]; then
    write_root_file "$SRC_POLICIES" "$LW_DIST_DIR/policies.json"
else
    warn "LibreWolf.app not found at $LW_APP -- install via 'brew install --cask librewolf' then re-run chezmoi apply"
fi

# === user.js + userChrome.css -> active profile (id from profiles.ini) ===
if [ ! -f "$LW_PROFILES_INI" ]; then
    warn "profiles.ini not found ($LW_PROFILES_INI) -- launch LibreWolf once, then re-run chezmoi apply"
    exit 0
fi

# Discover active profile relative path.
# Prefer [InstallXXX] -> Default= (locked-to-this-install pointer).
# Fall back to first [ProfileN] section with Default=1.
discover_profile() {
    awk '
        /^\[Install/                  { in_install=1; in_profile=0; next }
        /^\[Profile[0-9]/             { in_install=0; in_profile=1; cand=""; next }
        /^\[/                         { in_install=0; in_profile=0; next }
        in_install && /^Default=/     { sub(/^Default=/,""); print; exit }
        in_profile && /^Path=/        { sub(/^Path=/,""); cand=$0 }
        in_profile && /^Default=1[ \t]*$/ && cand!="" { print cand; exit }
    ' "$LW_PROFILES_INI"
}

REL_PATH="$(discover_profile)"
if [ -z "$REL_PATH" ]; then
    warn "could not determine active profile from $LW_PROFILES_INI"
    exit 0
fi

ACTIVE_PROFILE="$LW_APPSUP/$REL_PATH"
if [ ! -d "$ACTIVE_PROFILE" ]; then
    warn "active profile dir not found: $ACTIVE_PROFILE"
    exit 0
fi

write_user_file "$SRC_USER_JS"     "$ACTIVE_PROFILE/user.js"
write_user_file "$SRC_USER_CHROME" "$ACTIVE_PROFILE/chrome/userChrome.css"

log "done"
{{- end }}

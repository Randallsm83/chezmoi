{{- if eq .chezmoi.os "windows" -}}
# PowerShell Profile - Managed by chezmoi
# Last updated: {{ now | date "2006-01-02" }}

# Suppress non-fatal GetHistoryItems errors from Starship/PSReadLine
$global:ErrorActionPreference = 'SilentlyContinue'

# XDG Base Directory specification
# Ensure these are always set (even if bootstrap didn't run)
if (-not $env:XDG_CONFIG_HOME) { $env:XDG_CONFIG_HOME = "$HOME\.config" }
if (-not $env:XDG_DATA_HOME) { $env:XDG_DATA_HOME = "$HOME\.local\share" }
if (-not $env:XDG_STATE_HOME) { $env:XDG_STATE_HOME = "$HOME\.local\state" }
if (-not $env:XDG_CACHE_HOME) { $env:XDG_CACHE_HOME = "$HOME\.cache" }

# Default editor / pager (mirrors ~/.zprofile)
$env:EDITOR = 'nvim'
$env:VISUAL = $env:EDITOR
$env:PAGER  = 'less'

# XDG-compliant tool configurations
$env:LESSHISTFILE = "$env:XDG_STATE_HOME\less\history"
$env:PYTHON_HISTORY = "$env:XDG_STATE_HOME\python\history"
$env:PSREADLINE_HISTORY = "$env:XDG_STATE_HOME\powershell\history"

# Ensure XDG state directories for tools exist
$toolStateDirs = @(
    "$env:XDG_STATE_HOME\less",
    "$env:XDG_STATE_HOME\python",
    "$env:XDG_STATE_HOME\powershell"
)
foreach ($dir in $toolStateDirs) {
    if (-not (Test-Path $dir)) {
        New-Item -ItemType Directory -Path $dir -Force | Out-Null
    }
}

# Force UTF-8 for console I/O so Unicode (e.g. box-drawing chars from Node/WSL
# tooling like ldex) renders correctly instead of as CP850/CP1252 garbage.
# Must run before any subprocess inherits the encoding.
[Console]::InputEncoding  = [System.Text.UTF8Encoding]::new()
[Console]::OutputEncoding = [System.Text.UTF8Encoding]::new()
$OutputEncoding           = [System.Text.UTF8Encoding]::new()
$PSDefaultParameterValues['Out-File:Encoding']    = 'utf8'
$PSDefaultParameterValues['Set-Content:Encoding'] = 'utf8'
$PSDefaultParameterValues['Add-Content:Encoding'] = 'utf8'

# Bound the on-disk PSReadLine history file. PSReadLine's MaximumHistoryCount
# caps only the in-memory list; with SaveIncrementally the file on disk grows
# without limit (agent-driven multi-line command blocks pile up fast). A multi-MB
# file makes startup slow AND, with several concurrent sessions + Defender
# real-time scanning, triggers "history file ... is being used by another process"
# lock errors. Trim to the last N lines, serialized across sessions via a mutex,
# before PSReadLine reads the file. zsh bounds its own history natively (SAVEHIST).
if (Test-Path $env:PSREADLINE_HISTORY) {
    if ((Get-Item $env:PSREADLINE_HISTORY).Length -gt 2MB) {
        $histMutex = [System.Threading.Mutex]::new($false, 'Global\dotfiles-psreadline-history-trim')
        $histLocked = $false
        try { $histLocked = $histMutex.WaitOne(0) } catch { $histLocked = $false }
        if ($histLocked) {
            try {
                $histKeep = 20000
                $histLines = [System.IO.File]::ReadAllLines($env:PSREADLINE_HISTORY)
                if ($histLines.Count -gt $histKeep) {
                    $histStart = $histLines.Count - $histKeep
                    # Advance to a command boundary so we never keep a dangling tail
                    # of a multi-line entry (continuation lines end with a backtick).
                    while ($histStart -gt 0 -and $histStart -lt $histLines.Count -and $histLines[$histStart - 1].EndsWith('`')) {
                        $histStart++
                    }
                    if ($histStart -lt $histLines.Count) {
                        $histTmp = "$env:PSREADLINE_HISTORY.trim.tmp"
                        [System.IO.File]::WriteAllLines($histTmp, $histLines[$histStart..($histLines.Count - 1)])
                        Move-Item -LiteralPath $histTmp -Destination $env:PSREADLINE_HISTORY -Force
                    }
                }
            } catch {
                # Best-effort: a concurrent append can briefly hold the file; the
                # next session retries on its next startup.
            } finally {
                $histMutex.ReleaseMutex()
                $histMutex.Dispose()
            }
        } else {
            $histMutex.Dispose()
        }
    }
}

# PSReadLine configuration - load BEFORE Starship to avoid GetHistoryItems errors
if (Get-Module -ListAvailable -Name PSReadLine) {
    Import-Module PSReadLine
    
    # Vi mode
    Set-PSReadLineOption -EditMode Vi
    
    # History settings (XDG-compliant location, mirrors zsh's $XDG_STATE_HOME/zsh/history)
    Set-PSReadLineOption -HistorySavePath $env:PSREADLINE_HISTORY
    Set-PSReadLineOption -HistorySearchCursorMovesToEnd
    Set-PSReadLineOption -HistorySaveStyle SaveIncrementally
    Set-PSReadLineOption -MaximumHistoryCount 10000
    
    # Predictive IntelliSense
    Set-PSReadLineOption -PredictionSource History
    Set-PSReadLineOption -PredictionViewStyle ListView
    
    # Starship uses 2-line prompt - set ExtraPromptLineCount for proper PSFzf rendering
    Set-PSReadLineOption -ExtraPromptLineCount 1
    
    # Key bindings
    Set-PSReadLineKeyHandler -Key UpArrow -Function HistorySearchBackward
    Set-PSReadLineKeyHandler -Key DownArrow -Function HistorySearchForward
    Set-PSReadLineKeyHandler -Key Tab -Function MenuComplete
    Set-PSReadLineKeyHandler -Key Ctrl+d -Function DeleteCharOrExit
}

# PSCompletions intentionally NOT loaded here. Its `handle_completion()`
# installs a full-screen Tab menu that redraws over surrounding buffer
# content. Per-CLI subcommand/option metadata still flows in via
# `Scripts/15-psc-native.ps1`, which reads psc's JSON specs directly off
# disk and registers native `Register-ArgumentCompleter -Native` entries
# for every command in the psc set. Those flow into PSReadLine + PSFzf
# automatically, so Tab completion is argument-aware AND fzf-styled (no
# popup). Saves ~180ms of import cost on every shell start.

# Source all modular scripts from Scripts directory
# (includes starship, zoxide, fzf, completions, aliases, etc.)
$scriptsDir = Join-Path (Split-Path $PROFILE) "Scripts"
if (Test-Path $scriptsDir) {
    Get-ChildItem -Path $scriptsDir -Filter "*.ps1" -File -ErrorAction SilentlyContinue |
        Sort-Object Name |
        ForEach-Object {
        $script = $_
        if ([string]::IsNullOrWhiteSpace($script.FullName)) {
            return
        }
        Write-Verbose "Sourcing: $($script.Name)"
        try {
            . $script.FullName
        } catch {
            Write-Warning "Skipping profile script '$($script.Name)': $($_.Exception.Message)"
        }
    }
}

# GamePerformanceOptimizer - lazy-loaded to avoid ~2s startup cost.
# Stubs for the module's exported commands trigger Import-Module on first use,
# then re-invoke the now-real command.
if (Get-Module -ListAvailable -Name GamePerformanceOptimizer) {
    $gpoCommands = @(
        'Add-GameSecurityExclusion',
        'Remove-GameSecurityExclusion',
        'Get-GameSecurityExclusion',
        'Add-ShaderCacheExclusion',
        'Add-BulkGameExclusions',
        'Set-GameProcessPriority',
        'Remove-GameProcessPriority',
        'Export-GameOptimizations',
        'Import-GameOptimizations'
    )
    foreach ($cmd in $gpoCommands) {
        $sb = [scriptblock]::Create(@"
            Remove-Item Function:\$cmd -ErrorAction SilentlyContinue
            Import-Module GamePerformanceOptimizer
            & $cmd @args
"@)
        Set-Item -Path "Function:\$cmd" -Value $sb -Force
    }
}


# VS Code shell integration
if ($env:TERM_PROGRAM -eq "vscode") {
    . "$(code --locate-shell-integration-path pwsh)"
}

# Set LS_COLORS using Vivid ({{ .theme.name }} theme)
{{- if index .package_features "rust_alternatives" }}
if (Get-Command vivid -ErrorAction SilentlyContinue) {
    $env:LS_COLORS = (vivid generate "$env:XDG_CONFIG_HOME\vivid\themes\{{ .theme.name }}.yml")
}
{{- end }}

# Bash-style history expansion (!!, !$)
Set-PSReadLineKeyHandler -Key Spacebar -ScriptBlock {
    $line = $null
    $cursor = $null
    [Microsoft.PowerShell.PSConsoleReadLine]::GetBufferState([ref]$line, [ref]$cursor)
    
    # Handle !! expansion (repeat last command)
    if ($line -match '!!') {
        $lastCommand = (Get-History -Count 1).CommandLine
        if ($lastCommand) {
            $newLine = $line -replace '!!', $lastCommand
            [Microsoft.PowerShell.PSConsoleReadLine]::Replace(0, $line.Length, $newLine)
            [Microsoft.PowerShell.PSConsoleReadLine]::SetCursorPosition($newLine.Length)
        }
    }
    # Handle !$ expansion (last argument of last command)
    elseif ($line -match '!\$') {
        $lastCommand = (Get-History -Count 1).CommandLine
        if ($lastCommand) {
            # Get last argument (split on whitespace, take last non-empty)
            $lastArg = ($lastCommand -split '\s+' | Where-Object { $_ }) | Select-Object -Last 1
            if ($lastArg) {
                $newLine = $line -replace '!\$', $lastArg
                [Microsoft.PowerShell.PSConsoleReadLine]::Replace(0, $line.Length, $newLine)
                [Microsoft.PowerShell.PSConsoleReadLine]::SetCursorPosition($newLine.Length)
            }
        }
    }
    
    # Insert the space
    [Microsoft.PowerShell.PSConsoleReadLine]::Insert(' ')
}

# Restore error action preference after profile loads
$global:ErrorActionPreference = 'Continue'

# 1Password SSH Agent integration
{{- if .setup_1password }}
$env:SSH_AUTH_SOCK = "\\.\pipe\openssh-ssh-agent"

# Auto-authorize the 1Password CLI on shell startup so `op` / `opr` / any
# tool that shells out to op works without a manual `op signin` first.
#
# Guards:
#   - Interactive sessions only ($Host.Name -eq 'ConsoleHost' + a TTY) so
#     scripts, hooks, and non-interactive pwsh invocations don't block on
#     a biometric prompt.
#   - Skip when OP_SERVICE_ACCOUNT_TOKEN is set (headless service-account
#     flow doesn't need interactive signin).
#   - Skip when $env:OP_AUTOSIGNIN_DISABLE is set (escape hatch for when
#     the biometric prompt would be disruptive, e.g. demos, recordings).
#   - Invoke-OpEnsure already caches a recent successful probe for 5
#     minutes, so back-to-back shells won't each fire a fresh prompt.
if ($Host.Name -eq 'ConsoleHost' `
        -and -not [System.Console]::IsInputRedirected `
        -and -not $env:OP_SERVICE_ACCOUNT_TOKEN `
        -and -not $env:OP_AUTOSIGNIN_DISABLE `
        -and (Get-Command Invoke-OpEnsure -ErrorAction SilentlyContinue)) {
    [void](Invoke-OpEnsure -Quiet)
}
{{- end }}

# Warp API Key (resolved once via batched op inject in .chezmoi.toml.tmpl).
# `dig` returns "" if .secrets is missing (e.g. pre-[data.secrets] config),
# keeping `and` short-circuit-safe.
{{- $warp_key := dig "secrets" "warp_api_key" "" . }}
{{- if and .setup_1password $warp_key }}
$env:WARP_API_KEY = "{{ $warp_key }}"
{{- end }}

# ANTHROPIC_API_KEY: NOT injected globally (was leaking literal value into the
# rendered profile). Claude Code receives it via the `claude` op-run wrapper in
# 99-functions.ps1, which reads ~/.config/op/claude.env. Other tools that need
# the key (Anthropic SDK scripts, aider, etc.) should use their own per-tool
# wrapper or invoke directly: `op run --env-file=~/.config/op/<tool>.env -- ...`

# GITHUB_TOKEN: sourced at shell start from gh's keyring (NOT baked into the
# rendered profile -- same reasoning as ANTHROPIC_API_KEY above; no literal
# secret on disk). Gives mise / gh / git / other CLIs an authenticated token so
# GitHub release fetches (`mise upgrade`, `mise install`, plugin updates) use the
# 5000-req/hr authenticated limit instead of the 60-req/hr unauthenticated one.
# `gh auth token` is non-interactive (no biometric prompt) and reads the Windows
# Credential Manager keyring. The guard lets an explicit override win.
if (-not $env:GITHUB_TOKEN -and (Get-Command gh -ErrorAction SilentlyContinue)) {
    $ghToken = (gh auth token 2>$null)
    if ($LASTEXITCODE -eq 0 -and $ghToken) { $env:GITHUB_TOKEN = $ghToken.Trim() }
}

# Welcome message (optional - comment out if you prefer clean startup)
# Write-Host "PowerShell $($PSVersionTable.PSVersion) - Welcome, {{ .name }}!" -ForegroundColor Cyan
{{- end -}}

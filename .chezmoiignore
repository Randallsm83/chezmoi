{{- /* SSH .pub hints are sourced via .chezmoitemplates/ssh-pub-resolve
      which tries .secrets.ssh_pub_* first, then falls back to the
      running ssh-agent (matched by SSH comment suffix) on Unix.
      If neither source yields a value the rendered file would be
      empty and overwrite a previously-seeded hint, which breaks
      `IdentitiesOnly yes` host blocks in dot_ssh/private_config.tmpl.
      Skip per-target only when its resolved value is empty so other
      hints still deploy. */ -}}
{{- $ssh_pubs := list
    (list "github_com"  "ssh_pub_github_com"  "GitHub SSH Key")
    (list "gitlab_com"  "ssh_pub_gitlab_com"  "GitLab SSH Key")
    (list "dh_git"      "ssh_pub_dh_git"      "Dreamhost GIt SSH Key")
    (list "dh_yakko"    "ssh_pub_dh_yakko"    "Yakko SSH Key")
    (list "dh_porky"    "ssh_pub_dh_porky"    "Porky SSH Key")
    (list "***REMOVED***" "ssh_pub_***REMOVED***" "***REMOVED*** SSH Key")
    (list "fp3"         "ssh_pub_fp3"         "fp3 SSH Key")
    (list "raspi"       "ssh_pub_raspi"       "ranmil@raspi") -}}
{{- range $p := $ssh_pubs -}}
{{- $resolved := includeTemplate "ssh-pub-resolve" (dict "key" (index $p 1) "comment" (index $p 2) "root" $) | trim -}}
{{- if eq $resolved "" }}
.ssh/{{ index $p 0 }}.pub
{{- end -}}
{{- end }}

{{- /* Mise tier-specific configs - keep only the active tier's file */ -}}
{{- $tier := (index . "remote_tier" | default "full") }}
{{- if ne $tier "minimal" }}
# Exclude minimal-tier mise config when not on minimal tier
.config/mise/config.remote.toml
{{- end }}
{{- if ne $tier "medium" }}
# Exclude medium-tier mise config when not on medium tier
.config/mise/config.medium.toml
{{- end }}


# ============================================================================
# Chezmoi Ignore Patterns
# ============================================================================
# https://www.chezmoi.io/reference/special-files-and-directories/chezmoiignore/
#
# IMPORTANT: This file uses Go text/template syntax for conditionals
# Validation: Run `chezmoi execute-template < .chezmoiignore` to test syntax
#
# PLATFORM-SPECIFIC FILE STRATEGY:
# ================================
# For platform-specific files that should only be applied on certain OS:
#
# 1. Files with platform in name (e.g., config.linux.toml, config.windows.toml):
#    - Use .chezmoiignore with OS conditionals to exclude on wrong platforms
#    - Example: Exclude config.linux.toml on Windows, config.windows.toml on Linux
#
# 2. Shell-specific files (e.g., .bashrc, .zshrc, fzf.bash):
#    - Exclude entire Unix shell ecosystem on Windows
#    - Exclude PowerShell ecosystem on Unix/Linux
#
# 3. Cross-platform files with platform-specific content:
#    - Use .tmpl extension with {{"{{"}} if eq .chezmoi.os "windows" {{"}}"}} guards
#    - Example: Microsoft.PowerShell_profile.ps1.tmpl
#
# 4. Directory-level exclusions:
#    - Use ** glob patterns for entire directories (e.g., .config/zsh/**)
#    - More efficient than per-file exclusions
#
# 5. Remote machine exclusions:
#    - GUI applications and heavy tools excluded on remote machines
#    - Minimal installs further reduce configs deployed
#
# ============================================================================
# Windows: junctions / reparse points (chezmoi can't manage through them)
# ============================================================================
# `~/projects` is a directory junction (Windows) or simply a workspace
# folder (Linux/macOS) — either way chezmoi must NOT materialize anything
# under it. The single chezmoi-source file `projects/dh/mise.toml` is
# deployed by run_onchange_after_50_dh-mise-toml_windows.ps1.tmpl directly
# to `D:\dh\mise.toml` (Windows only), bypassing the junction. On other
# platforms there is no consumer.
projects
projects/**

{{- if eq .chezmoi.os "windows" }}
# Flow Launcher (scoop persist): always ignore runtime/cache/log siblings so
# future `chezmoi re-add` doesn't pull them into source. Tracked files live at
# scoop/persist/flow-launcher/UserData/Settings/{Settings.json,Plugins/**}.
scoop/persist/flow-launcher/UserData/Cache/**
scoop/persist/flow-launcher/UserData/Logs/**
scoop/persist/flow-launcher/UserData/Plugins/**
scoop/persist/flow-launcher/UserData/Themes/**
scoop/persist/flow-launcher/UserData/Settings/History.json
scoop/persist/flow-launcher/UserData/Settings/UserSelectedRecord.json
scoop/persist/flow-launcher/UserData/Settings/MultipleTopMostRecord.json
scoop/persist/flow-launcher/UserData/**/*.bak
{{- end }}

# LibreWolf source-only tree (all platforms). The two files we manage —
#   librewolf/distribution/policies.json  (force-installed extensions,
#                                          search engines, telemetry lockdown)
#   librewolf/profile/user.js              (per-profile preference overrides)
# — don't live under $HOME, so chezmoi can't reach them via the normal target
# walker. They sit here as source data and are deployed (Windows only) by:
#   .chezmoiscripts/run_onchange_after_55_librewolf_windows.ps1.tmpl
# On non-Windows hosts no consumer exists, so we still must ignore the tree
# to keep `chezmoi apply` from materializing $HOME/librewolf/...
librewolf
librewolf/**

# unbound source-only tree (Windows). The single file we manage —
#   unbound/service.conf.tmpl  (DoT-forwarding stub resolver config)
# — is rendered + deployed to ~/scoop/persist/unbound/service.conf by:
#   .chezmoiscripts/run_onchange_after_56_unbound_windows.ps1.tmpl
# Same pattern as librewolf: ignore from normal target walk, surface via
# the install script. The script's `includeTemplate` call still finds it
# under .chezmoi.sourceDir.
unbound
unbound/**

# wezterm terminfo source-only tree (Windows). The single file we manage —
#   wezterm-terminfo/wezterm.terminfo  (upstream terminfo source for TERM=wezterm)
# — is compiled with `tic` and installed into Git for Windows' MSYS terminfo
# tree (C:\Program Files\Git\usr\share\terminfo) by:
#   .chezmoiscripts/run_onchange_after_35_wezterm_terminfo_windows.ps1.tmpl
# so `less`, `git diff`, and other MSYS-linked pagers don't error with
# `'wezterm': unknown terminal type.` when wezterm sets TERM=wezterm.
wezterm-terminfo
wezterm-terminfo/**


.cache/zsh/**
.zshrc
.zshrc.d/
.zshenv
.bashrc
.bash_profile
.profile
.p10k.zsh

# Unix-specific scripts (standalone .sh files in home, not chezmoi scripts)
*.sh

# Unix config directories
.config/systemd/
.config/i3/
.config/sway/
.config/hyprland/

# Unix-specific dotfiles
.xinitrc
.Xresources
.tmux.conf

# Linux-specific configs
.config/mise/config.linux.toml
.config/fzf/fzf.bash
.lde.yml

# 1Password agent.toml lives in %LOCALAPPDATA% on Windows, not ~/.config
.config/1Password/**

{{- else }}
# Exclude Windows-specific files on Unix

# Windows PowerShell
Documents/
AppData/

# Windows-specific scripts
*.ps1
*.ps1.tmpl

# Windows configs
.wslconfig
.config/mise/config.windows.toml
.config/windows/**

# Windows Terminal
AppData/Local/Packages/Microsoft.WindowsTerminal_*/

# Scoop persist tree (Flow Launcher etc.) — Windows only
scoop/
scoop/**

{{- end }}


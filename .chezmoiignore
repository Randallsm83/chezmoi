{{- end }}

{{- /* Remote machine exclusions */ -}}
{{- if (index . "is_remote" | default false) }}
# Exclude on remote machines (GUI apps, heavy tools)
.config/wezterm/**
.config/warp/**
.config/alacritty/**
.config/kitty/**
{{- if eq (index . "remote_tier" | default "minimal") "minimal" }}
# Additional exclusions for minimal remote installs (tier=minimal only)
.config/bottom/**
{{- end }}
{{- end }}

{{- /* Mise tier-specific configs - keep only the active tier's file */ -}}
{{- $tier := (index . "remote_tier" | default "full") }}
{{- if ne $tier "minimal" }}
# Exclude minimal-tier mise config when not on minimal tier
.config/mise/config.remote.toml
{{- end }}
{{- if ne $tier "medium" }}
# Exclude medium-tier mise config when not on medium tier
.config/mise/config.medium.toml
{{- end }}

